
{% liquid
  assign block_settings = block.settings
  assign product = closest.product
  assign is_smart_card_product = false
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  if product and product.handle == 'clutch-connect-card'
    assign is_smart_card_product = true
  endif

  assign tracked_print_enabled = false
  if product.metafields.custom.tracked_print_enabled.value == true
    assign tracked_print_enabled = true
  endif

  assign variant = closest.product.selected_or_first_available_variant
  assign inventory_quantity = variant.inventory_quantity
  assign inventory_policy = variant.inventory_policy

  if variant.inventory_management == 'shopify'
    assign inventory_managed = true
  endif

  assign can_add_to_cart = false
  assign add_to_cart_text = 'products.product.unavailable' | t

  if variant
    if variant.quantity_rule.min > variant.inventory_quantity and inventory_managed and inventory_policy == 'deny'
      assign quantity_rule_soldout = true
    endif

    if variant.available
      assign can_add_to_cart = true
      assign add_to_cart_text = 'products.product.add_to_cart' | t
    elsif inventory_managed and inventory_quantity <= 0 and inventory_policy == 'deny' or quantity_rule_soldout
      assign can_add_to_cart = false
      assign add_to_cart_text = 'products.product.sold_out' | t
    else
      assign can_add_to_cart = false
      assign add_to_cart_text = 'products.product.unavailable' | t
    endif
  endif

  if is_smart_card_product
    assign add_to_cart_text = 'Add to Cart'
  endif
%}

<span
  class="buy-buttons-block buy-buttons-block--{{ block.id }}{% if is_smart_card_product %} smart-card-buy-buttons{% endif %}"
  {{ block.shopify_attributes }}
>
  {%- if product != blank -%}
    {%- assign product_form_id = 'BuyButtons-ProductForm-' | append: section.id -%}
    <product-form-component
      data-section-id="{{ section.id }}"
      data-product-id="{{ product.id }}"
      data-product-url="{{ product.url }}"
      on:submit="/handleSubmit"
      data-quantity-default="{% if product.selected_or_first_available_variant.quantity_rule.min %}{{ product.selected_or_first_available_variant.quantity_rule.min }}{% else %}1{% endif %}"
      data-quantity-error-max="{{ 'products.product.quantity_error_max' | t }}"
    >
      <div
        class="visually-hidden"
        aria-live="assertive"
        role="status"
        aria-atomic="true"
        ref="liveRegion"
      ></div>
      {%- form 'product', product, id: product_form_id, data-type: 'add-to-cart-form' -%}
        <input
          type="hidden"
          name="id"
          ref="variantId"
          value="{{ product.selected_or_first_available_variant.id }}"
        >
        {% if is_smart_card_product %}
            <div class="smart-card-plus-cta">
              <p class="smart-card-plus-label">Your Card Includes</p>
            </div>
            <div class="sbc-plus-carousel" aria-label="Clutch Connect Plus highlights">
              <div class="sbc-plus-track">
                <article class="sbc-plus-card">
                  <h3>Add Your Socials</h3>
                  <p>Create a cleaner digital profile with stronger layout, sections, buttons, and brand control.</p>
                </article>
                <article class="sbc-plus-card">
                  <h3>Track Analytics</h3>
                  <p>See more than basic views. Track taps, scans, clicks, and engagement patterns.</p>
                </article>
                <article class="sbc-plus-card">
                  <h3>Capture Leads</h3>
                  <p>Let visitors request quotes, ask questions, or send their contact info from your profile.</p>
                </article>
                <article class="sbc-plus-card">
                  <h3>Guided Setup</h3>
                  <p>Send your details and we help get you started quickly with your Smart Business Card profile.</p>
                </article>

                <article class="sbc-plus-card is-duplicate" aria-hidden="true">
                  <h3>Add Your Socials</h3>
                  <p>Create a cleaner digital profile with stronger layout, sections, buttons, and brand control.</p>
                </article>
                <article class="sbc-plus-card is-duplicate" aria-hidden="true">
                  <h3>Track Analytics</h3>
                  <p>See more than basic views. Track taps, scans, clicks, and engagement patterns.</p>
                </article>
                <article class="sbc-plus-card is-duplicate" aria-hidden="true">
                  <h3>Capture Leads</h3>
                  <p>Let visitors request quotes, ask questions, or send their contact info from your profile.</p>
                </article>
                <article class="sbc-plus-card is-duplicate" aria-hidden="true">
                  <h3>Guided Setup</h3>
                  <p>Send your details and we help get you started quickly with your Smart Business Card profile.</p>
                </article>
            </div>
          </div>
        {% endif %}
        {%- unless product.gift_card? -%}
          {%- render 'clutch-print-product-options', product: product, section_id: section.id -%}
        {%- endunless -%}
        {%- if block_settings.gift_card_form and product.gift_card? -%}
          {%- render 'gift-card-recipient-form', product: product, form: form, section: section, block: block -%}
          <span class="buy-buttons-block__bar">
        {%- endif -%}
        <div
          class="product-form-buttons spacing-style{% if block_settings.stacking %} product-form-buttons--stacked{% endif %}{% if is_smart_card_product %} product-form-buttons--smart-card{% endif %}"
          style="{% render 'spacing-style', settings: block_settings %}"
          ref="productFormButtons"
        >
          {%- unless block_settings.gift_card_form and product.gift_card? -%}
            <span
              class="product-form-text__error hidden"
              ref="addToCartTextError"
            >
              <span class="svg-wrapper">
                {{- 'icon-error.svg' | inline_asset_content -}}
              </span>
            </span>
          {%- endunless -%}

          {%- liquid
            assign has_quantity_rules = false
            if variant.quantity_rule.min > 1 or variant.quantity_rule.increment > 1 or variant.quantity_rule.max != null
              assign has_quantity_rules = true
            endif
          -%}

          {%- if has_quantity_rules -%}
            {%- assign cart_quantity = cart | item_count_for_variant: variant.id -%}
            <div
              class="quantity-label"
              ref="quantityLabel"
            >
              {{ 'products.product.quantity' | t }}
              <span
                class="quantity-label__cart-count{% if cart_quantity == 0 %} hidden{% endif %}"
                ref="quantityLabelCartCount"
                >({{ cart_quantity }}
                {{ 'products.product.in_cart' | t }})</span
              >
            </div>
          {%- endif -%}

          {% content_for 'block', type: 'quantity', id: 'quantity' %}

          {%- if has_quantity_rules -%}
            <div
              class="quantity-rules"
              ref="quantityRules"
            >
              {%- if variant.quantity_rule.increment > 1 -%}
                <span class="quantity-rules__item">
                  {{ 'products.product.quantity_increments' | t: increment: variant.quantity_rule.increment }}
                </span>
              {%- endif -%}
              {%- if variant.quantity_rule.min > 1 -%}
                <span class="quantity-rules__item">
                  {{ 'products.product.quantity_minimum' | t: minimum: variant.quantity_rule.min }}
                </span>
              {%- endif -%}
              {%- if variant.quantity_rule.max != null -%}
                <span class="quantity-rules__item">
                  {{ 'products.product.quantity_maximum' | t: maximum: variant.quantity_rule.max }}
                </span>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if product.quantity_price_breaks_configured? and variant.quantity_price_breaks.size > 0 -%}
            {%- liquid
              assign use_currency = settings.currency_code_enabled_product_pages
            -%}
            <volume-pricing
              class="volume-pricing"
              data-section-id="{{ section.id }}"
              ref="volumePricing"
            >
              <span class="volume-pricing__title">{{ 'content.volume_pricing' | t }}</span>
              <div class="volume-pricing__table">
                <div class="volume-pricing__row volume-pricing__row--even">
                  <span>{{ variant.quantity_rule.min }}+</span>
                  <span>
                    {%- if use_currency -%}
                      {{- variant.price | money_with_currency | strip -}}
                    {%- else -%}
                      {{- variant.price | money | strip -}}
                    {%- endif -%}
                    /{{ 'content.each_abbreviation' | t -}}
                  </span>
                </div>
                {%- for price_break in variant.quantity_price_breaks limit: 2 -%}
                  {%- liquid
                    assign row_index = forloop.index
                    if row_index == 1
                      assign row_class = 'volume-pricing__row volume-pricing__row--odd'
                    else
                      assign row_class = 'volume-pricing__row volume-pricing__row--even'
                    endif
                  -%}
                  <div class="{{ row_class }}">
                    <span>{{ price_break.minimum_quantity }}+</span>
                    <span>
                      {%- if use_currency -%}
                        {{- price_break.price | money_with_currency | strip -}}
                      {%- else -%}
                        {{- price_break.price | money | strip -}}
                      {%- endif -%}
                      /{{ 'content.each_abbreviation' | t -}}
                    </span>
                  </div>
                {%- endfor -%}

                {%- if variant.quantity_price_breaks.size > 2 -%}
                  <div class="volume-pricing__collapsible-wrapper">
                    {%- for price_break in variant.quantity_price_breaks offset: 2 -%}
                      {%- liquid
                        assign collapsed_index = forloop.index
                        assign total_index = collapsed_index | plus: 2
                        assign modulo_result = total_index | modulo: 2
                        if modulo_result == 1
                          assign row_class = 'volume-pricing__row volume-pricing__row--odd'
                        else
                          assign row_class = 'volume-pricing__row volume-pricing__row--even'
                        endif
                      -%}
                      <div class="{{ row_class }}">
                        <span>{{ price_break.minimum_quantity }}+</span>
                        <span>
                          {%- if use_currency -%}
                            {{- price_break.price | money_with_currency | strip -}}
                          {%- else -%}
                            {{- price_break.price | money | strip -}}
                          {%- endif -%}
                          /{{ 'content.each_abbreviation' | t -}}
                        </span>
                      </div>
                    {%- endfor -%}
                  </div>

                  <button
                    type="button"
                    class="volume-pricing__toggle button-unstyled"
                    ref="volumePricingToggle"
                    on:click="/toggleExpanded"
                  >
                    <span class="volume-pricing__toggle-text">
                      <span class="volume-pricing__show-more">+ {{ 'actions.show_more' | t }}</span>
                      <span class="volume-pricing__show-less">- {{ 'actions.show_less' | t }}</span>
                    </span>
                  </button>
                {%- endif -%}
              </div>
            </volume-pricing>
          {%- endif -%}
          {% content_for 'block',
            type: 'add-to-cart',
            id: 'add-to-cart',
            can_add_to_cart: can_add_to_cart,
            add_to_cart_text: add_to_cart_text
          %}

          {% unless is_smart_card_product or tracked_print_enabled %}
            {% content_for 'block',
              type: 'accelerated-checkout',
              id: 'accelerated-checkout',
              can_add_to_cart: can_add_to_cart,
              form_obj: form
            %}
          {% endunless %}
        </div>
        {%- if block_settings.gift_card_form and product.gift_card? -%}
          </span>
        {%- endif -%}
      {%- endform -%}
    </product-form-component>
  {%- else -%}
    <div class="product-form-buttons">
      <button
        type="submit"
        name="add"
        class="button"
        disabled
      >
        {{ 'blocks.sold_out' | t }}
      </button>
    </div>
  {%- endif -%}
</span>

{% if block_settings.show_pickup_availability %}
  <script
    src="{{ 'local-pickup.js' | asset_url }}"
    type="module"
  ></script>

  {%- assign pick_up_availabilities = closest.product.selected_or_first_available_variant.store_availabilities
    | where: 'pick_up_enabled', true
  -%}

  <local-pickup
    class="spacing-style product__pickup-availabilities"
    {% if pick_up_availabilities.size == 0 %}
      hidden
    {% endif %}
    data-section-id="{{ section.id }}"
    data-product-url="{{ closest.product.url }}"
    data-variant-id="{{ closest.product.selected_or_first_available_variant.id }}"
    style="{% render 'spacing-style', settings: block_settings %}"
    ref="localPickupButton"
  >
    {% if can_add_to_cart %}
      <dialog-component>
        <div class="pickup-availability__row">
          <div class="pickup-availability__column">
            <span class="svg-wrapper">
              {% if pick_up_availabilities.first.available %}
                {{- 'icon-available.svg' | inline_asset_content -}}
              {% else %}
                {{- 'icon-unavailable.svg' | inline_asset_content -}}
              {% endif %}
            </span>
          </div>
          <div class="pickup-availability__column">
            {% if pick_up_availabilities.first.available %}
              <p class="pickup-location__text-sm">
                {{ 'content.pickup_available_at_html' | t: location: pick_up_availabilities.first.location.name }}
              </p>
              <p class="pickup-location__text-xs">
                {{ 'content.pickup_ready_in' | t: pickup_time: pick_up_availabilities.first.pick_up_time }}
              </p>
            {% else %}
              <p class="pickup-location__text-sm">
                {{ 'content.pickup_not_available' | t }}
              </p>
            {% endif %}
            <button
              on:click="/showDialog"
              class="button-unstyled pickup-location__button"
            >
              {{ 'actions.view_store_information' | t }}
            </button>
          </div>
        </div>
        <dialog
          ref="dialog"
          class="dialog-modal dialog-drawer pickup-location__dialog color-{{ settings.drawer_color_scheme }}"
          scroll-lock
          aria-labelledby="pickup-dialog-heading"
          data-testid="pickup-location-dialog"
        >
          <h2
            id="pickup-dialog-heading"
            class="visually-hidden"
          >
            {{ 'actions.view_store_information' | t }}
          </h2>
          <div class="pickup-availability__dialog-row pickup-availability__header-container">
            <div class="pickup-availability__column">
              <h4 class="pickup-location__h4">{{ closest.product.title }}</h4>
              {% unless closest.product.has_only_default_variant %}
                <p class="pickup-location__text-sm">
                  {{ closest.product.selected_or_first_available_variant.title }}
                </p>
              {% endunless %}
            </div>
            <button
              ref="closeButton"
              on:click="/closeDialog"
              class="button button-unstyled close-button pickup-location__close-button"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>
          {% for pick_up_availability in pick_up_availabilities %}
            <div class="pickup-location__wrapper">
              <p class="pickup-location__text-bold">{{ pick_up_availability.location.name }}</p>
              <div class="pickup-location__address-wrapper">
                <span class="pickup-location__availability-wrapper">
                  {% if pick_up_availability.available %}
                    {{- 'icon-available.svg' | inline_asset_content -}}
                    {% assign pickup_time = pick_up_availability.pick_up_time | downcase %}
                    {{ 'content.pickup_available_in' | t: pickup_time: pickup_time }}
                  {% else %}
                    {{- 'icon-unavailable.svg' | inline_asset_content -}}
                    {{ 'content.pickup_not_available' | t }}
                  {% endif %}
                </span>
                <address class="pickup-location__address">
                  {{ pick_up_availability.location.address | format_address }}
                  {{ pick_up_availability.location.address.phone }}
                </address>
              </div>
            </div>
          {% endfor %}
        </dialog>
      </dialog-component>
    {% endif %}
  </local-pickup>
{% endif %}

{% if is_smart_card_product %}
  <script>
    (function () {
      const form = document.getElementById('BuyButtons-ProductForm-{{ section.id }}');
      if (!form || form.dataset.smartCardModuleBound === 'true') return;
      form.dataset.smartCardModuleBound = 'true';

      const billingToggle = form.querySelector('[data-sbc-billing-toggle]');
      const monthlyTargets = form.querySelectorAll('[data-billing-monthly]');
      const annualTargets = form.querySelectorAll('[data-billing-annual]');
      const basePlanCards = form.querySelectorAll('[data-billing-base-card]');
      const plusPlanCards = form.querySelectorAll('[data-billing-plus-card]');

      if (!billingToggle || !monthlyTargets.length || !annualTargets.length) {
        return;
      }

      const toggleButtons = billingToggle.querySelectorAll('button[data-billing]');

      const setElementHidden = (el, hidden) => {
        el.hidden = hidden;
        if (hidden) {
          el.style.setProperty('display', 'none', 'important');
          return;
        }
        el.style.removeProperty('display');
      };

      const setBilling = (interval) => {
        const isFree = interval === 'free';
        const isAnnual = interval === 'annual';

        toggleButtons.forEach((button) => {
          const active = button.getAttribute('data-billing') === interval;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-selected', active ? 'true' : 'false');
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        });

        monthlyTargets.forEach((el) => {
          setElementHidden(el, isAnnual);
        });

        annualTargets.forEach((el) => {
          setElementHidden(el, !isAnnual);
        });

        basePlanCards.forEach((el) => {
          setElementHidden(el, !isFree);
        });

        plusPlanCards.forEach((el) => {
          setElementHidden(el, isFree);
        });
      };

      setBilling('free');

      toggleButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const interval = button.getAttribute('data-billing');
          if (!interval) return;
          setBilling(interval);
        });
      });
    })();
  </script>
{% endif %}

{% stylesheet %}
    .smart-card-buy-buttons .smart-card-plus-cta {
      display: grid;
      margin: 0.25rem 0 0.6rem;
      place-items: center;
      width: 100%;
    }

    .smart-card-buy-buttons .smart-card-plus-label {
      color: #384862;
      font-size: 0.98rem;
      font-weight: 900;
      letter-spacing: 0.01em;
      margin: 0;
      text-align: center;
    }

    .smart-card-buy-buttons .sbc-btn {
      align-items: center;
      border-radius: 12px;
      display: inline-flex;
      font-weight: 900;
      justify-content: center;
      min-height: 46px;
      padding: 0.7rem 0.95rem;
      text-align: center;
      text-decoration: none;
      width: 100%;
    }

    .smart-card-buy-buttons .sbc-btn--primary {
      background: #ffa665;
      border: 1px solid #ffa665;
      box-shadow: 0 12px 24px rgba(255, 166, 101, 0.26);
      color: #384862;
    }

    .smart-card-buy-buttons .sbc-btn--muted {
      background: rgba(56, 72, 98, 0.08);
      border: 1px solid rgba(56, 72, 98, 0.16);
      color: #384862;
    }

    .smart-card-buy-buttons .sbc-plus-carousel {
      max-width: 100%;
      overflow: hidden;
      padding-bottom: 0.2rem;
      scrollbar-width: none;
      width: 100%;
      min-width: 0;
    }

    .smart-card-buy-buttons .sbc-plus-carousel::-webkit-scrollbar {
      display: none;
    }

    .smart-card-buy-buttons .sbc-plus-track {
      animation: sbc-plus-scroll 42s linear infinite;
      display: flex;
      gap: 0.8rem;
      width: max-content;
      will-change: transform;
      min-width: 0;
    }

    .smart-card-buy-buttons .sbc-plus-carousel:hover .sbc-plus-track {
      animation-play-state: paused;
    }

    .smart-card-buy-buttons .sbc-plus-card {
      background: #fff;
      border: 1px solid rgba(56, 72, 98, 0.14);
      border-radius: 16px;
      box-shadow: 0 12px 28px rgba(7, 29, 51, 0.06);
      display: grid;
      flex: 0 0 min(82vw, 280px);
      gap: 0.45rem;
      min-height: 220px;
      padding: 1rem;
      text-align: center;
      width: min(82vw, 280px);
    }

    .smart-card-buy-buttons .sbc-plus-card h3 {
      color: #384862;
      font-size: 1.08rem;
      margin: 0;
    }

    .smart-card-buy-buttons .sbc-plus-card p {
      color: rgba(56, 72, 98, 0.8);
      font-size: 0.9rem;
      line-height: 1.45;
      margin: 0;
    }

    @keyframes sbc-plus-scroll {
      from { transform: translate3d(0, 0, 0); }
      to { transform: translate3d(-50%, 0, 0); }
    }

    .smart-card-buy-buttons .product-form-buttons--smart-card .add-to-cart-button {
      background: #ffa665;
      border: 1px solid #ffa665;
      border-radius: 14px;
      box-shadow: 0 16px 28px rgba(255, 166, 101, 0.3);
      color: #384862;
      font-weight: 900;
      min-height: 58px;
      transition: transform 0.16s ease, box-shadow 0.2s ease, background-color 0.2s ease;
      width: 100%;
    }

    .smart-card-buy-buttons .product-form-buttons--smart-card .add-to-cart-button:hover {
      background: #ffb177;
      box-shadow: 0 18px 30px rgba(255, 166, 101, 0.38);
      transform: translateY(-1px);
    }

    .smart-card-buy-buttons .product-form-buttons--smart-card .add-to-cart-button:active {
      transform: translateY(0);
    }

    .smart-card-buy-buttons .product-form-buttons--smart-card .add-to-cart-button:disabled {
      background: #f0d9c8;
      border-color: #f0d9c8;
      box-shadow: none;
      color: rgba(56, 72, 98, 0.55);
    }

    .smart-card-buy-buttons .smart-card-secondary-links {
      display: grid;
      gap: 0.65rem;
      margin-top: 0.8rem;
    }

    .smart-card-buy-buttons .smart-card-secondary-links a {
      border: 1px solid rgba(56, 72, 98, 0.2);
      border-radius: 12px;
      color: #384862;
      font-weight: 700;
      padding: 0.72rem 0.9rem;
      text-align: center;
      text-decoration: none;
    }

    .smart-card-buy-buttons .smart-card-secondary-links a:hover {
      border-color: rgba(255, 166, 101, 0.72);
      color: #384862;
    }

    .smart-card-buy-buttons .smart-card-connect-wrap {
      background: #fff;
      border: 1px solid rgba(56, 72, 98, 0.14);
      border-radius: 22px;
      display: grid;
      gap: 0.9rem;
      margin-top: 1rem;
      padding: 1rem;
      text-align: center;
      min-width: 0;
      width: 100%;
    }

    .smart-card-buy-buttons .sbc-plans-title {
      color: #384862;
      font-size: 1.4rem;
      margin: 0;
    }

    .smart-card-buy-buttons .sbc-billing-toggle {
      align-items: center;
      background: #eef2f6;
      border: 1px solid rgba(56, 72, 98, 0.14);
      border-radius: 999px;
      display: inline-grid;
      gap: 0.35rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin: 0 auto;
      max-width: 640px;
      padding: 0.28rem;
      width: 100%;
    }

    .smart-card-buy-buttons .sbc-billing-toggle button {
      background: rgba(255, 255, 255, 0.95);
      border: 1px solid transparent;
      border-radius: 999px;
      color: rgba(56, 72, 98, 0.74);
      cursor: pointer;
      font-size: 0.86rem;
      font-weight: 800;
      min-height: 42px;
      padding: 0.55rem 0.8rem;
      transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .smart-card-buy-buttons .sbc-billing-toggle button:not(.is-active) {
      background: rgba(255, 255, 255, 0.9);
      border-color: rgba(56, 72, 98, 0.08);
      box-shadow: none;
      color: rgba(56, 72, 98, 0.74);
    }

    .smart-card-buy-buttons .sbc-billing-toggle button.is-active {
      background: #ffa665;
      border-color: rgba(255, 166, 101, 0.95);
      box-shadow: 0 10px 20px rgba(255, 166, 101, 0.3);
      color: #384862;
    }

    .smart-card-buy-buttons .sbc-pricing-grid {
      display: grid;
      gap: 0.7rem;
      margin: 1rem auto 0;
      max-width: 720px;
      width: 100%;
      min-width: 0;
    }

    .smart-card-buy-buttons .sbc-price-card {
      background: #fff;
      border: 1px solid rgba(56, 72, 98, 0.15);
      border-radius: 16px;
      display: grid;
      gap: 0.6rem;
      padding: 0.95rem;
      text-align: center;
      min-width: 0;
    }

    @media screen and (max-width: 749px) {
      .smart-card-buy-buttons {
        width: 100%;
      }

      .smart-card-buy-buttons .sbc-plus-card {
        flex-basis: min(76vw, 250px);
        min-height: 190px;
        width: min(76vw, 250px);
      }

      .smart-card-buy-buttons .sbc-billing-toggle button {
        font-size: 0.72rem;
        min-height: 38px;
        padding: 0.42rem 0.34rem;
      }
    }

    .smart-card-buy-buttons .sbc-price-card--featured {
      background: linear-gradient(180deg, #ffffff, #fffaf6);
      border-color: rgba(255, 166, 101, 0.52);
      box-shadow: 0 18px 34px rgba(255, 166, 101, 0.16);
    }

    .smart-card-buy-buttons .sbc-price-card h4,
    .smart-card-buy-buttons .sbc-price,
    .smart-card-buy-buttons .sbc-price-card__pill,
    .smart-card-buy-buttons .sbc-price-card ul {
      margin: 0;
    }

    .smart-card-buy-buttons .sbc-price {
      color: #384862;
      font-family: 'Exo 2', sans-serif;
      font-size: clamp(1.62rem, 2.7vw, 2rem);
      font-weight: 900;
      line-height: 1.05;
    }

    .smart-card-buy-buttons .sbc-price span {
      color: rgba(56, 72, 98, 0.78);
      font-size: 0.88rem;
      font-weight: 700;
      margin-left: 0.2rem;
    }

    .smart-card-buy-buttons .sbc-price-card__badge,
    .smart-card-buy-buttons .sbc-price-card__pill {
      background: rgba(255, 166, 101, 0.18);
      border: 1px solid rgba(255, 166, 101, 0.4);
      border-radius: 999px;
      color: #384862;
      display: inline-flex;
      font-size: 0.78rem;
      font-weight: 800;
      justify-self: center;
      padding: 0.32rem 0.68rem;
      width: fit-content;
    }

    .smart-card-buy-buttons .sbc-price-card ul {
      color: rgba(56, 72, 98, 0.88);
      list-style: none;
      line-height: 1.5;
      padding: 0;
      text-align: left;
    }

    .smart-card-buy-buttons .sbc-price-card li {
      align-items: start;
      display: grid;
      gap: 0.45rem;
      grid-template-columns: 14px 1fr;
    }

    .smart-card-buy-buttons .sbc-price-card li::before {
      color: #ffa665;
      content: '+';
      font-weight: 900;
    }

    @media screen and (min-width: 750px) {
      .smart-card-buy-buttons .sbc-plus-card {
        width: 250px;
      }

      .smart-card-buy-buttons .sbc-pricing-grid {
        justify-items: center;
      }

      .smart-card-buy-buttons .sbc-price-card {
        max-width: 620px;
        width: 100%;
      }

      .smart-card-buy-buttons .smart-card-secondary-links {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .smart-card-buy-buttons .sbc-plus-track {
        animation: none !important;
        transform: none !important;
        width: auto;
      }

      .smart-card-buy-buttons .sbc-plus-card.is-duplicate {
        display: none;
      }
    }
{% endstylesheet %}

