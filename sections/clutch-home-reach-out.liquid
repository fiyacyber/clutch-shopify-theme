<section class="clutch-home-reach-out color-{{ section.settings.color_scheme }}">
  <div class="clutch-home-reach-out__inner">
    <p class="clutch-home-reach-out__eyebrow">Need something custom?</p>
    <h2>Request Custom Quote</h2>
    <p>Tell us what you’re printing, when you need it, and whether you need help with artwork.</p>
    <div class="clutch-home-reach-out__details">
      <span>info@clutchprintshop.com</span>
      <span>(513) 951-8429</span>
    </div>
  </div>
</section>

{% stylesheet %}
  .clutch-home-reach-out {
    background: #fff;
    padding: clamp(3rem, 7vw, 5rem) var(--page-margin);
  }

  .clutch-home-reach-out__inner {
    background: linear-gradient(135deg, rgba(255, 166, 101, 0.16), rgba(56, 72, 98, 0.08));
    border: 1px solid rgba(56, 72, 98, 0.12);
    border-radius: 24px;
    margin-inline: auto;
    max-width: 980px;
    padding: clamp(1.5rem, 5vw, 3rem);
    text-align: center;
  }

  .clutch-home-reach-out__eyebrow {
    color: #ffa665;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  .clutch-home-reach-out h2 {
    color: #384862;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1;
    margin: 0.65rem 0 0.75rem;
  }

  .clutch-home-reach-out p:not(.clutch-home-reach-out__eyebrow) {
    color: rgba(34, 34, 34, 0.78);
    font-family: 'Montserrat', sans-serif;
    line-height: 1.6;
    margin: 0 auto;
    max-width: 620px;
  }

  .clutch-home-reach-out__details {
    display: grid;
    gap: 0.65rem;
    margin-top: 1.5rem;
  }

  .clutch-home-reach-out__details span {
    color: #384862;
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.15rem, 4vw, 1.65rem);
    font-weight: 900;
    overflow-wrap: anywhere;
  }

  @media screen and (min-width: 750px) {
    .clutch-home-reach-out__details {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Homepage reach out",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Homepage reach out"
    }
  ]
}
{% endschema %}
