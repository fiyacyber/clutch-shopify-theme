{% if collection.handle == 'business-kits' %}
  {% liquid
    assign starter_product = section.settings.starter_product
    if starter_product == blank
      assign starter_product = all_products['starter-business-kit']
    endif

    assign growth_product = section.settings.growth_product
    if growth_product == blank
      assign growth_product = all_products['growth-business-kit']
    endif

    assign starter_url = starter_product.url | default: '/products/starter-business-kit'
    assign growth_url = growth_product.url | default: '/products/growth-business-kit'
  %}

  <section class="clutch-kit-landing color-{{ section.settings.color_scheme }}" aria-labelledby="clutch-kit-compare-title">
    <div class="clutch-kit-landing__inner">
      <div class="clutch-kit-landing__benefits" aria-label="Included with every Business Kit">
        <article>
          <span aria-hidden="true">01</span>
          <div>
            <strong>Professional Design Included</strong>
            <em>$200 Value</em>
            <p>A coordinated print-ready design service is included with your kit.</p>
          </div>
        </article>
        <article>
          <span aria-hidden="true">02</span>
          <div>
            <strong>Free Shipping</strong>
            <p>Shipping is included with your Business Kit order.</p>
          </div>
        </article>
        <article>
          <span aria-hidden="true">03</span>
          <div>
            <strong>Artwork and Setup Support</strong>
            <p>We help prepare your files and guide the order through production.</p>
          </div>
        </article>
      </div>

      <div class="clutch-kit-landing__section-head" id="compare-kits">
        <p class="clutch-kit-landing__eyebrow">COMPARE KITS</p>
        <h2 id="clutch-kit-compare-title">Choose the Right Business Kit</h2>
        <p>Compare the essentials, then open the kit that fits your current campaign.</p>
      </div>

      <div class="clutch-kit-landing__compare" aria-label="Business Kit comparison">
        <article class="clutch-kit-card" data-product-source="{% if starter_product == blank %}fallback{% else %}shopify-product{% endif %}">
          <a class="clutch-kit-card__media" href="{{ starter_url }}" aria-label="View {{ starter_product.title | default: 'Starter Kit' | escape }}">
            {% if starter_product.featured_image != blank %}
              {{ starter_product.featured_image | image_url: width: 900 | image_tag: widths: '360, 540, 720, 900', sizes: '(min-width: 960px) 31vw, 100vw', loading: 'lazy', class: 'clutch-kit-card__image' }}
            {% else %}
              <span class="clutch-kit-card__fallback" aria-hidden="true"><b>CLUTCH</b><small>Starter Business Kit</small></span>
            {% endif %}
          </a>
          <div class="clutch-kit-card__body">
            <span class="clutch-kit-card__label">Starter</span>
            <h3><a class="clutch-kit-card__title-link" href="{{ starter_url }}">{{ starter_product.title | default: 'Starter Kit' }}</a></h3>
            <p class="clutch-kit-card__outcome">Build a polished foundation for launch-day outreach and everyday networking.</p>
            {% if starter_product != blank %}
              <p class="clutch-kit-card__price"><a class="clutch-kit-card__price-link" href="{{ starter_url }}" aria-label="View Starter Kit, current price {{ starter_product.price_min | money_without_trailing_zeros }}">{{ starter_product.price_min | money_without_trailing_zeros }}</a></p>
            {% endif %}
            <p class="clutch-kit-card__design"><strong>Professional Design Included</strong><span>$200 Value</span></p>
            {% if starter_product.metafields.custom.clutch_codes_90_day_access_enabled.value == true %}<p class="clutch-kit-card__access">90 Days Clutch Codes™ Access Included</p>{% endif %}
            <div class="clutch-kit-card__contains">
              <strong>What’s Included</strong>
              <ul>
                <li>{{ section.settings.starter_item_1 | default: '500 custom business cards' }}</li>
                <li>{{ section.settings.starter_item_2 | default: '100 custom door hangers' }}</li>
                <li>{{ section.settings.starter_item_3 | default: '250 premium custom flyers' }}</li>
              </ul>
            </div>
            <a class="clutch-kit-button clutch-kit-button--primary" href="{{ starter_url }}">View Starter Kit <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="clutch-kit-card clutch-kit-card--featured" data-product-source="{% if growth_product == blank %}fallback{% else %}shopify-product{% endif %}">
          <span class="clutch-kit-card__badge">Most Popular</span>
          <a class="clutch-kit-card__media" href="{{ growth_url }}" aria-label="View {{ growth_product.title | default: 'Growth Kit' | escape }}">
            {% if growth_product.featured_image != blank %}
              {{ growth_product.featured_image | image_url: width: 900 | image_tag: widths: '360, 540, 720, 900', sizes: '(min-width: 960px) 31vw, 100vw', loading: 'lazy', class: 'clutch-kit-card__image' }}
            {% else %}
              <span class="clutch-kit-card__fallback" aria-hidden="true"><b>CLUTCH</b><small>Growth Business Kit</small></span>
            {% endif %}
          </a>
          <div class="clutch-kit-card__body">
            <span class="clutch-kit-card__label">Growth</span>
            <h3><a class="clutch-kit-card__title-link" href="{{ growth_url }}">{{ growth_product.title | default: 'Growth Kit' }}</a></h3>
            <p class="clutch-kit-card__outcome">Scale local outreach with coordinated materials for larger campaigns.</p>
            {% if growth_product != blank %}
              <p class="clutch-kit-card__price"><a class="clutch-kit-card__price-link" href="{{ growth_url }}" aria-label="View Growth Kit, current price {{ growth_product.price_min | money_without_trailing_zeros }}">{{ growth_product.price_min | money_without_trailing_zeros }}</a></p>
            {% endif %}
            <p class="clutch-kit-card__design"><strong>Professional Design Included</strong><span>$200 Value</span></p>
            {% if growth_product.metafields.custom.clutch_codes_90_day_access_enabled.value == true %}<p class="clutch-kit-card__access">90 Days Clutch Codes™ Access Included</p>{% endif %}
            <div class="clutch-kit-card__contains">
              <strong>What’s Included</strong>
              <ul>
                <li>{{ section.settings.growth_item_1 | default: '1,000 custom business cards' }}</li>
                <li>{{ section.settings.growth_item_2 | default: '1,000 custom door hangers' }}</li>
                <li>{{ section.settings.growth_item_3 | default: '1,000 premium custom flyers' }}</li>
              </ul>
            </div>
            <a class="clutch-kit-button clutch-kit-button--primary" href="{{ growth_url }}">View Growth Kit <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="clutch-kit-card clutch-kit-card--custom">
          <div class="clutch-kit-card__custom-mark" aria-hidden="true"><span></span><span></span><span></span></div>
          <div class="clutch-kit-card__body">
            <span class="clutch-kit-card__label">Custom Kit</span>
            <h3>Build a Package Around Your Business</h3>
            <p class="clutch-kit-card__outcome">Choose custom products, quantities, sizes, or multi-location packages with help from Clutch.</p>
            <div class="clutch-kit-card__contains">
              <strong>Available Options</strong>
              <ul>
                <li>Custom quantities</li>
                <li>Additional print products</li>
                <li>Multi-location campaigns</li>
                <li>Included design support</li>
              </ul>
            </div>
            <a class="clutch-kit-button clutch-kit-button--light" href="/pages/contact">Request a Custom Kit <span aria-hidden="true">→</span></a>
          </div>
        </article>
      </div>

      <aside class="clutch-kit-landing__connected" aria-labelledby="clutch-kit-connected-title">
        <div>
          <p class="clutch-kit-landing__eyebrow">CONNECTED MARKETING OPTIONS</p>
          <h2 id="clutch-kit-connected-title">Connected Marketing Options</h2>
          <p>Eligible Business Kits can connect printed materials to editable online destinations using Clutch Codes™. Available tracking options are shown in the kit details.</p>
        </div>
        <a class="clutch-kit-text-link" href="/pages/qr-pro">Explore Clutch Codes™ <span aria-hidden="true">→</span></a>
      </aside>

      <div class="clutch-kit-landing__final" aria-labelledby="clutch-kit-final-title">
        <div>
          <h2 id="clutch-kit-final-title">Need a Different Combination?</h2>
          <p>Tell us which products and quantities you need and we’ll help create a custom Business Kit.</p>
        </div>
        <a class="clutch-kit-button clutch-kit-button--primary" href="/pages/contact">Request a Custom Kit <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .clutch-kit-landing {
    background: #f4f7fa;
    color: #384862;
    padding: clamp(2.25rem, 5vw, 4.5rem) var(--page-margin);
  }

  .clutch-kit-landing__inner {
    margin-inline: auto;
    max-width: 1180px;
  }

  .clutch-kit-landing h2,
  .clutch-kit-landing h3 {
    color: #384862;
    font-family: 'Exo 2', sans-serif;
    letter-spacing: -0.025em;
    line-height: 1.08;
    margin: 0;
    text-wrap: balance;
  }

  .clutch-kit-card__access { margin: .65rem 0 0; padding: .55rem .7rem; border-radius: .55rem; background: #fff1e7; color: #5c3a20; font-weight: 750; }

  .clutch-kit-landing h2 {
    font-size: clamp(1.85rem, 4vw, 3rem);
  }

  .clutch-kit-landing h3 {
    font-size: clamp(1.45rem, 2.5vw, 1.9rem);
  }

  .clutch-kit-landing p {
    line-height: 1.6;
  }

  .clutch-kit-landing__benefits {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .clutch-kit-landing__benefits article {
    align-items: start;
    background: #fff;
    border: 1px solid #dce4ec;
    border-radius: 16px;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: auto 1fr;
    padding: 1.1rem;
  }

  .clutch-kit-landing__benefits article > span,
  .clutch-kit-card__label,
  .clutch-kit-landing__eyebrow {
    color: #c66f32;
    font-size: 0.74rem;
    font-style: normal;
    font-weight: 900;
    letter-spacing: 0.1em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .clutch-kit-landing__benefits strong {
    color: #384862;
    display: block;
    font-size: 1rem;
    line-height: 1.25;
  }

  .clutch-kit-landing__benefits em {
    color: #8b4a20;
    display: block;
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 800;
    margin-top: 0.2rem;
  }

  .clutch-kit-landing__benefits p {
    color: #617087;
    font-size: 0.9rem;
    margin: 0.45rem 0 0;
  }

  .clutch-kit-landing__section-head {
    margin: clamp(2.75rem, 6vw, 4.75rem) auto 1.5rem;
    max-width: 720px;
    scroll-margin-top: 7rem;
    text-align: center;
  }

  .clutch-kit-landing__section-head > p:last-child {
    color: #617087;
    margin: 0.75rem 0 0;
  }

  .clutch-kit-landing__eyebrow {
    margin: 0 0 0.65rem;
  }

  .clutch-kit-landing__compare {
    align-items: stretch;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .clutch-kit-card {
    background: #fff;
    border: 1px solid #dce4ec;
    border-radius: 20px;
    box-shadow: 0 14px 34px rgba(56, 72, 98, 0.08);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }

  .clutch-kit-card:has(.clutch-kit-card__title-link:hover),
  .clutch-kit-card:has(.clutch-kit-card__title-link:focus-visible) {
    border-color: rgba(255, 166, 101, 0.85);
    box-shadow: 0 18px 40px rgba(56, 72, 98, 0.14);
    transform: translateY(-2px);
  }

  .clutch-kit-card--featured {
    border-color: rgba(255, 166, 101, 0.85);
    box-shadow: 0 18px 40px rgba(56, 72, 98, 0.12);
  }

  .clutch-kit-card__badge {
    background: #384862;
    border-radius: 8px;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    left: 1rem;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.65rem;
    position: absolute;
    text-transform: uppercase;
    top: 1rem;
    z-index: 1;
  }

  .clutch-kit-card__media {
    aspect-ratio: 16 / 10;
    background: #e8edf2;
    display: block;
    overflow: hidden;
    position: relative;
    z-index: 2;
  }

  .clutch-kit-card__image {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .clutch-kit-card__fallback {
    align-items: flex-start;
    background: linear-gradient(145deg, #edf1f5, #fff);
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: flex-end;
    padding: 1.25rem;
    position: relative;
  }

  .clutch-kit-card__fallback::before {
    background: #384862;
    border-bottom: 4px solid #ffa665;
    border-radius: 12px;
    content: '';
    height: 48%;
    position: absolute;
    right: 1.25rem;
    top: 1.25rem;
    transform: rotate(4deg);
    width: 58%;
  }

  .clutch-kit-card__fallback b,
  .clutch-kit-card__fallback small {
    color: #384862;
    position: relative;
    z-index: 1;
  }

  .clutch-kit-card__fallback b {
    color: #c66f32;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
  }

  .clutch-kit-card__fallback small {
    font-size: 0.92rem;
    font-weight: 800;
    margin-top: 0.2rem;
  }

  .clutch-kit-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.25rem;
  }

  .clutch-kit-card__title-link,
  .clutch-kit-card__price-link {
    color: inherit;
    text-decoration: none;
  }

  .clutch-kit-card__price-link {
    position: relative;
    z-index: 2;
  }

  .clutch-kit-card__title-link::after {
    content: '';
    inset: 0;
    position: absolute;
    z-index: 1;
  }

  .clutch-kit-card__title-link:hover,
  .clutch-kit-card__title-link:focus-visible,
  .clutch-kit-card__price-link:hover,
  .clutch-kit-card__price-link:focus-visible {
    text-decoration: underline;
    text-decoration-color: #c66f32;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.18em;
  }

  .clutch-kit-card__label {
    display: block;
    margin-bottom: 0.55rem;
  }

  .clutch-kit-card__outcome {
    color: #617087;
    font-size: 0.94rem;
    margin: 0.7rem 0 0;
  }

  .clutch-kit-card__price {
    color: #384862;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.35rem);
    font-weight: 900;
    line-height: 1;
    margin: 1rem 0 0;
  }

  .clutch-kit-card__design {
    background: #fff7f0;
    border-left: 3px solid #ffa665;
    color: #384862;
    margin: 1rem 0 0;
    padding: 0.75rem;
  }

  .clutch-kit-card__design strong,
  .clutch-kit-card__design span {
    display: block;
  }

  .clutch-kit-card__design strong {
    font-size: 0.87rem;
  }

  .clutch-kit-card__design span {
    color: #8b4a20;
    font-size: 0.78rem;
    font-weight: 800;
    margin-top: 0.1rem;
  }

  .clutch-kit-card__contains {
    margin-top: 1.15rem;
    position: relative;
    z-index: 2;
  }

  .clutch-kit-card__contains > strong {
    color: #384862;
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .clutch-kit-card__contains ul {
    display: grid;
    gap: 0.6rem;
    list-style: none;
    margin: 0.8rem 0 0;
    padding: 0;
  }

  .clutch-kit-card__contains li {
    color: #384862;
    display: grid;
    font-size: 0.92rem;
    font-weight: 650;
    gap: 0.55rem;
    grid-template-columns: 18px 1fr;
    line-height: 1.4;
  }

  .clutch-kit-card__contains li::before {
    color: #c66f32;
    content: '✓';
    font-weight: 900;
  }

  .clutch-kit-button {
    align-items: center;
    border-radius: 12px;
    display: inline-flex;
    font-size: 0.92rem;
    font-weight: 800;
    gap: 0.45rem;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1rem;
    text-decoration: none;
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }

  .clutch-kit-card .clutch-kit-button {
    margin-top: auto;
    position: relative;
    z-index: 2;
  }

  .clutch-kit-button--primary {
    background: #384862;
    box-shadow: inset 0 -3px 0 #ffa665, 0 10px 22px rgba(56, 72, 98, 0.16);
    color: #fff;
  }

  .clutch-kit-button--light {
    background: #fff;
    box-shadow: inset 0 -3px 0 #ffa665;
    color: #384862;
  }

  .clutch-kit-button:hover {
    box-shadow: inset 0 -3px 0 #ffa665, 0 14px 28px rgba(56, 72, 98, 0.2);
    transform: translateY(-2px);
  }

  .clutch-kit-button:active {
    box-shadow: inset 0 -2px 0 #ffa665;
    transform: translateY(0);
  }

  .clutch-kit-button:focus-visible,
  .clutch-kit-text-link:focus-visible,
  .clutch-kit-card__media:focus-visible,
  .clutch-kit-card__title-link:focus-visible,
  .clutch-kit-card__price-link:focus-visible {
    outline: 3px solid #ffa665;
    outline-offset: 3px;
  }

  .clutch-kit-card--custom {
    background: #384862;
    border-color: #384862;
    color: #fff;
  }

  .clutch-kit-card--custom h3,
  .clutch-kit-card--custom .clutch-kit-card__label,
  .clutch-kit-card--custom .clutch-kit-card__outcome,
  .clutch-kit-card--custom .clutch-kit-card__contains > strong,
  .clutch-kit-card--custom .clutch-kit-card__contains li {
    color: #fff;
  }

  .clutch-kit-card__custom-mark {
    align-items: end;
    display: flex;
    gap: 0.5rem;
    height: 10rem;
    padding: 1.5rem;
  }

  .clutch-kit-card__custom-mark span {
    background: #ffa665;
    border-radius: 4px 4px 0 0;
    display: block;
    width: 1.1rem;
  }

  .clutch-kit-card__custom-mark span:nth-child(1) { height: 34%; }
  .clutch-kit-card__custom-mark span:nth-child(2) { height: 58%; }
  .clutch-kit-card__custom-mark span:nth-child(3) { height: 82%; }

  .clutch-kit-landing__connected,
  .clutch-kit-landing__final {
    align-items: center;
    border-radius: 18px;
    display: flex;
    gap: 1.5rem;
    justify-content: space-between;
    margin-top: clamp(2rem, 4vw, 3.25rem);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .clutch-kit-landing__connected {
    background: #fff;
    border: 1px solid #dce4ec;
  }

  .clutch-kit-landing__connected p:last-child,
  .clutch-kit-landing__final p {
    color: #617087;
    margin: 0.6rem 0 0;
    max-width: 720px;
  }

  .clutch-kit-text-link {
    color: #384862;
    flex: 0 0 auto;
    font-weight: 850;
    min-height: 44px;
    padding: 0.7rem 0;
    text-decoration-color: #ffa665;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.3em;
  }

  .clutch-kit-landing__final {
    background: #fff7f0;
    border: 1px solid rgba(255, 166, 101, 0.5);
  }

  .clutch-kit-landing__final .clutch-kit-button {
    flex: 0 0 auto;
  }

  @media screen and (max-width: 959px) {
    .clutch-kit-landing__benefits,
    .clutch-kit-landing__compare {
      grid-template-columns: 1fr;
    }

    .clutch-kit-card {
      margin-inline: auto;
      max-width: 640px;
      width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .clutch-kit-landing {
      padding-inline: 0.9rem;
    }

    .clutch-kit-landing__benefits article,
    .clutch-kit-card__body {
      padding: 1rem;
    }

    .clutch-kit-landing__connected,
    .clutch-kit-landing__final {
      align-items: stretch;
      flex-direction: column;
    }

    .clutch-kit-button,
    .clutch-kit-landing__final .clutch-kit-button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .clutch-kit-button,
    .clutch-kit-card {
      transition: none;
    }

    .clutch-kit-button:hover,
    .clutch-kit-card:has(.clutch-kit-card__title-link:hover),
    .clutch-kit-card:has(.clutch-kit-card__title-link:focus-visible) {
      transform: none;
    }
  }
{% endstylesheet %}

