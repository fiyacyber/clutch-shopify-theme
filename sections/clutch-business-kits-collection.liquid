      "id": "starter_item_2",
      "label": "Included item 2",
      "default": "100 custom door hangers"
    },
    {
      "type": "text",
      "id": "starter_item_3",
      "label": "Included item 3",
      "default": "250 premium custom flyers"
    },
    {
      "type": "header",
      "content": "Growth Kit"
    },
    {
      "type": "product",
      "id": "growth_product",
      "label": "Growth product"
    },
    {
      "type": "text",
      "id": "growth_item_1",
      "label": "Included item 1",
      "default": "1,000 custom business cards"
    },
    {
      "type": "text",
      "id": "growth_item_2",
      "label": "Included item 2",
      "default": "1,000 custom door hangers"
    },
    {
      "type": "text",
      "id": "growth_item_3",
      "label": "Included item 3",
      "default": "1,000 premium custom flyers"
    }
  ],
  "presets": [
    {
      "name": "Business kits landing"
    }
  ]
}
{% endschema %}
