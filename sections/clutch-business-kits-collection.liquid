{% if collection.handle == 'business-kits' %}
  <section class="clutch-kit-landing color-{{ section.settings.color_scheme }}" aria-labelledby="clutch-kit-landing-title">
    <div class="clutch-kit-landing__inner">
      <div class="clutch-kit-landing__header">
        <p class="clutch-kit-landing__eyebrow">Business Kits</p>
        <h2 id="clutch-kit-landing-title">Launch-ready print campaigns, packaged by growth stage.</h2>
        <p>
          Each kit is built around a real campaign workflow: premium print, Clutch Connect Basic access,
          artwork review, and the materials your business needs to get in front of customers.
        </p>
        <p>
          Every Business Kit includes Clutch Connect Basic, so customers can scan, tap, or visit one clean digital profile
          with your contact info, links, and request form.
        </p>
        <p>
          Add QR Pro when you want to track multiple printed marketing pieces, campaigns, flyers, signs, cards, and door hangers.
          Upgrade to QR Pro for 100 dynamic QR codes and campaign tracking across your print materials.
        </p>
      </div>

      <div class="clutch-kit-landing__included" aria-label="Included with business kits">
        <article>
          <span>01</span>
          <strong>Premium print</strong>
          <p>Cards, flyers, door hangers, signs, and local outreach materials.</p>
        </article>
        <article>
          <span>02</span>
          <strong>Campaign tracking</strong>
          <p>QR destinations and campaign structure designed for measurable engagement.</p>
        </article>
        <article>
          <span>03</span>
          <strong>Artwork review</strong>
          <p>Upload artwork during product checkout or send files after ordering.</p>
        </article>
        <article>
          <span>04</span>
          <strong>Free shipping</strong>
          <p>Free shipping messaging is included across kit ordering flows.</p>
        </article>
      </div>

      <div class="clutch-kit-landing__compare" aria-label="Business kit comparison">
        {% assign starter_product = all_products['startup-kit'] %}
        {% if starter_product == blank %}{% assign starter_product = all_products['starter-kit'] %}{% endif %}
        {% assign growth_product = all_products['growth-kit'] %}

        <article>
          <span>Starter</span>
          <h3>Start getting found.</h3>
          <p class="clutch-kit-landing__price">
            {% if starter_product != blank %}{{ starter_product.price_min | money_without_trailing_zeros }}{% else %}Starter pricing{% endif %}
          </p>
          <p>For new brands that need essential print, clean design, and a campaign destination.</p>
          <div class="clutch-kit-landing__contains">
            <strong>Includes</strong>
            <ul>
              <li>250 business cards</li>
              <li>250 flyers</li>
              <li>QR campaign tracking</li>
              <li>Artwork review</li>
            </ul>
          </div>
          <a href="/products/startup-kit">View Starter Kit</a>
        </article>
        <article class="is-featured">
          <em>Most popular</em>
          <span>Growth</span>
          <h3>Launch a local campaign.</h3>
          <p class="clutch-kit-landing__price">
            {% if growth_product != blank %}{{ growth_product.price_min | money_without_trailing_zeros }}{% else %}Growth pricing{% endif %}
          </p>
          <p>For businesses ready to compare cards, flyers, and door hangers with tracking.</p>
          <div class="clutch-kit-landing__contains">
            <strong>Includes</strong>
            <ul>
              <li>500 business cards</li>
              <li>500 flyers</li>
              <li>500 door hangers</li>
              <li>Clutch Connect reporting</li>
            </ul>
            <p class="clutch-kit-landing__addon">Optional: Add 100 1-color, 2-sided yard signs for <strong>$399</strong>.</p>
          </div>
          <a href="/products/growth-kit">View Growth Kit</a>
        </article>
        <article class="clutch-kit-landing__agency-card">
          <span>Agency / Custom</span>
          <h3>Need a larger kit?</h3>
          <p class="clutch-kit-landing__price">Custom quote</p>
          <p>For agencies, franchises, teams, and custom local campaigns that need tailored quantities or multiple locations.</p>
          <div class="clutch-kit-landing__contains">
            <strong>Common requests</strong>
            <ul>
              <li>Multi-location print campaigns</li>
              <li>Custom quantities</li>
              <li>Yard signs and banners</li>
              <li>Campaign reporting setup</li>
            </ul>
          </div>
          <a href="/pages/contact">Request Custom Order</a>
        </article>
      </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .clutch-kit-landing {
    background: linear-gradient(180deg, #ffffff 0%, #F4F7FA 100%);
    padding: clamp(3rem, 6vw, 5rem) var(--page-margin);
  }

  .clutch-kit-landing__inner {
    margin-inline: auto;
    max-width: 1180px;
  }

  .clutch-kit-landing__header {
    margin: 0 auto clamp(1.75rem, 4vw, 2.75rem);
    max-width: 820px;
    text-align: center;
  }

  .clutch-kit-landing__eyebrow,
  .clutch-kit-landing__included span,
  .clutch-kit-landing__compare span {
    color: #FFA665;
    display: block;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    line-height: 1.2;
    margin: 0 0 0.8rem;
    text-transform: uppercase;
  }

  .clutch-kit-landing h2,
  .clutch-kit-landing h3 {
    color: #071D33;
    font-family: 'Exo 2', sans-serif;
    letter-spacing: -0.025em;
    line-height: 1;
    margin: 0;
    text-wrap: balance;
  }

  .clutch-kit-landing h2 {
    font-size: clamp(2rem, 5vw, 3.8rem);
  }

  .clutch-kit-landing h3 {
    font-size: clamp(1.35rem, 3vw, 1.85rem);
  }

  .clutch-kit-landing__header p,
  .clutch-kit-landing__included p,
  .clutch-kit-landing__compare p {
    color: #66758C;
    line-height: 1.65;
    margin: 0.9rem 0 0;
  }

  .clutch-kit-landing__included,
  .clutch-kit-landing__compare {
    display: grid;
    gap: 1rem;
  }

  .clutch-kit-landing__included {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .clutch-kit-landing__included article,
  .clutch-kit-landing__compare article {
    background: #fff;
    border: 1px solid #DDE6EF;
    border-radius: 20px;
    box-shadow: 0 16px 36px rgba(7, 29, 51, 0.07);
    padding: 1.15rem;
  }

  .clutch-kit-landing__included strong {
    color: #384862;
    display: block;
    font-size: 1rem;
    line-height: 1.2;
  }

  .clutch-kit-landing__compare {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .clutch-kit-landing__compare article {
    display: grid;
    align-content: start;
    position: relative;
  }

  .clutch-kit-landing__price {
    color: #071D33 !important;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1.45rem, 3vw, 2rem);
    font-weight: 900;
    line-height: 1;
    margin: 0.85rem 0 0 !important;
  }

  .clutch-kit-landing__contains {
    background: #F8FAFC;
    border: 1px solid #DDE6EF;
    border-radius: 16px;
    margin-top: 1.15rem;
    padding: 1rem;
  }

  .clutch-kit-landing__contains strong {
    color: #384862;
    display: block;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin-bottom: 0.7rem;
    text-transform: uppercase;
  }

  .clutch-kit-landing__contains ul {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .clutch-kit-landing__contains li {
    align-items: start;
    color: #384862;
    display: grid;
    font-size: 0.92rem;
    font-weight: 700;
    gap: 0.55rem;
    grid-template-columns: 18px 1fr;
    line-height: 1.35;
  }

  .clutch-kit-landing__contains li::before {
    color: #FFA665;
    content: '+';
    font-weight: 900;
  }

  .clutch-kit-landing__addon {
    background: #fff;
    border: 1px solid rgba(255, 166, 101, 0.32);
    border-radius: 12px;
    color: #384862 !important;
    font-size: 0.88rem;
    font-weight: 800;
    line-height: 1.4 !important;
    margin: 0.9rem 0 0 !important;
    padding: 0.7rem 0.8rem;
  }

  .clutch-kit-landing__addon strong {
    color: #071D33;
  }

  .clutch-kit-landing__compare article.is-featured {
    background: linear-gradient(180deg, #fffdfb, #fff7f0);
    border-color: rgba(255, 166, 101, 0.58);
    box-shadow: 0 24px 54px rgba(255, 166, 101, 0.18);
  }

  .clutch-kit-landing__compare article.is-featured .clutch-kit-landing__contains {
    background: rgba(255, 166, 101, 0.08);
    border-color: rgba(255, 166, 101, 0.24);
  }

  .clutch-kit-landing__agency-card {
    background: linear-gradient(145deg, #071D33, #384862) !important;
    border-color: rgba(255, 166, 101, 0.28) !important;
    color: #fff;
  }

  .clutch-kit-landing__agency-card h3,
  .clutch-kit-landing__agency-card .clutch-kit-landing__price {
    color: #fff !important;
  }

  .clutch-kit-landing__agency-card p:not(.clutch-kit-landing__price) {
    color: rgba(255, 255, 255, 0.76);
  }

  .clutch-kit-landing__agency-card .clutch-kit-landing__contains {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.14);
  }

  .clutch-kit-landing__agency-card .clutch-kit-landing__contains strong,
  .clutch-kit-landing__agency-card .clutch-kit-landing__contains li {
    color: rgba(255, 255, 255, 0.9);
  }

  .clutch-kit-landing__compare em {
    background: #071D33;
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-size: 0.68rem;
    font-style: normal;
    font-weight: 900;
    margin: 0 0 0.8rem;
    padding: 0.38rem 0.6rem;
    width: fit-content;
  }

  .clutch-kit-landing__compare a {
    align-items: center;
    background: #FFA665;
    border-radius: 10px;
    color: #071D33;
    display: inline-flex;
    font-weight: 900;
    justify-content: center;
    margin-top: 1.15rem;
    min-height: 46px;
    padding: 0.8rem 1rem;
    text-decoration: none;
    width: 100%;
  }

  @media screen and (max-width: 900px) {
    .clutch-kit-landing__included,
    .clutch-kit-landing__compare {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Business kits landing",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Business kits landing"
    }
  ]
}
{% endschema %}
