<section class="clutch-custom-order color-{{ section.settings.color_scheme }}" aria-labelledby="clutch-custom-order-title">
  <div class="clutch-custom-order__inner">
    <div class="clutch-custom-order__hero">
      <div>
        <p class="clutch-custom-order__eyebrow">Request Custom Quote</p>
        <h1 id="clutch-custom-order-title">Tell us what you need printed and tracked.</h1>
        <p>
          Send the details for custom print, business kits, smart cards, artwork help, or a trackable QR campaign.
          Clutch will review your request and follow up with next steps.
        </p>
      </div>
      <div class="clutch-custom-order__hero-card" aria-label="Custom order benefits">
        <span>Included</span>
        <strong>Artwork review + free shipping</strong>
        <p>Upload or describe your artwork, timeline, print pieces, QR destination, and campaign goals.</p>
      </div>
    </div>

    <div class="clutch-custom-order__grid-layout">
      <aside class="clutch-custom-order__process" aria-label="Custom order process">
        <article><span>01</span><strong>Share project details</strong><p>Tell us what you need, your deadline, quantity, and whether artwork is ready.</p></article>
        <article><span>02</span><strong>We review the setup</strong><p>Clutch checks print specs, artwork readiness, and QR or Clutch Connect needs.</p></article>
        <article><span>03</span><strong>Approve and launch</strong><p>You receive next steps for checkout, proofing, production, and campaign setup.</p></article>
      </aside>

      {%- form 'contact', id: 'ClutchContactForm', class: 'clutch-custom-order__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="clutch-custom-order__alert clutch-custom-order__alert--success" tabindex="-1" autofocus>
            Thanks for reaching out. We received your custom order request and will reply shortly.
          </div>
        {%- elsif form.errors -%}
          <div class="clutch-custom-order__alert clutch-custom-order__alert--error" tabindex="-1" autofocus>
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="clutch-custom-order__section-heading">
          <span>Project details</span>
          <strong>Request custom quote</strong>
        </div>

        <div class="clutch-custom-order__grid">
          <label class="clutch-custom-order__field">
            <span>Name</span>
            <input id="ClutchContactName" type="text" name="contact[name]" value="{% if form.name %}{{ form.name | escape }}{% endif %}" autocomplete="name" required>
          </label>

          <label class="clutch-custom-order__field">
            <span>Email</span>
            <input id="ClutchContactEmail" type="email" name="contact[email]" value="{% if form.email %}{{ form.email | escape }}{% endif %}" autocomplete="email" autocorrect="off" autocapitalize="off" required>
          </label>

          <label class="clutch-custom-order__field">
            <span>Phone</span>
            <input id="ClutchContactPhone" type="tel" name="contact[phone]" value="{% if form.phone %}{{ form.phone | escape }}{% endif %}" autocomplete="tel">
          </label>

          <label class="clutch-custom-order__field">
            <span>Company</span>
            <input id="ClutchContactCompany" type="text" name="contact[Company Name]" value="{% if form.company %}{{ form.company | escape }}{% endif %}" autocomplete="organization">
          </label>

          <label class="clutch-custom-order__field">
            <span>Project type</span>
            <select name="contact[Project Type]">
              <option>Business Kit</option>
              <option>Business Cards</option>
              <option>Smart Clutch Card</option>
              <option>Flyers / Handouts</option>
              <option>Door Hangers</option>
              <option>Yard Signs / Banners</option>
              <option>Custom Print Campaign</option>
              <option>Artwork / Design Help</option>
            </select>
          </label>

          <label class="clutch-custom-order__field">
            <span>Artwork status</span>
            <select name="contact[Artwork Status]">
              <option>I have print-ready artwork</option>
              <option>I have artwork but need review</option>
              <option>I need design help</option>
              <option>Not sure yet</option>
            </select>
          </label>

          <label class="clutch-custom-order__field">
            <span>Timeline</span>
            <input type="text" name="contact[Timeline]" placeholder="Example: Needed in 2 weeks">
          </label>

          <label class="clutch-custom-order__field">
            <span>Estimated quantity</span>
            <input type="text" name="contact[Estimated Quantity]" placeholder="Example: 500 flyers, 100 cards">
          </label>

          <label class="clutch-custom-order__field clutch-custom-order__field--full">
            <span>Campaign / QR destination</span>
            <input type="text" name="contact[Campaign Destination]" placeholder="Website, Google review link, booking page, Clutch Connect profile, or not sure">
          </label>

          <label class="clutch-custom-order__field clutch-custom-order__field--full">
            <span>Project notes</span>
            <textarea id="ClutchContactMessage" name="contact[body]" rows="7" required placeholder="Tell us what you need printed, your goals, brand details, QR tracking needs, and any artwork notes.">{% if form.body %}{{ form.body | escape }}{% endif %}</textarea>
          </label>
        </div>

        <input type="hidden" name="contact[Source]" value="Request Custom Quote Page">
        <button type="submit" class="button clutch-custom-order__submit">Send Request</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .clutch-custom-order {
    background:
      radial-gradient(circle at 12% 4%, rgba(255, 166, 101, 0.16), transparent 30%),
      linear-gradient(180deg, #F4F7FA 0%, #ffffff 100%);
    color: #384862;
    font-family: 'Montserrat', sans-serif;
    padding: clamp(4rem, 7vw, 6rem) var(--page-margin) clamp(3.5rem, 7vw, 5.5rem);
  }

  .clutch-custom-order__inner {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    margin-inline: auto;
    max-width: 1180px;
  }

  .clutch-custom-order__hero {
    align-items: stretch;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
  }

  .clutch-custom-order__eyebrow,
  .clutch-custom-order__hero-card span,
  .clutch-custom-order__process span,
  .clutch-custom-order__section-heading span,
  .clutch-custom-order__field span {
    color: #FFA665;
    display: block;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    line-height: 1.2;
    margin: 0 0 0.65rem;
    text-transform: uppercase;
  }

  .clutch-custom-order h1 {
    color: #071D33;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(2.5rem, 6vw, 5.15rem);
    letter-spacing: -0.03em;
    line-height: 0.96;
    margin: 0;
    max-width: 850px;
    text-wrap: balance;
  }

  .clutch-custom-order__hero p,
  .clutch-custom-order__process p {
    color: #66758C;
    line-height: 1.7;
    margin: 1rem 0 0;
    max-width: 740px;
  }

  .clutch-custom-order__hero-card,
  .clutch-custom-order__process article,
  .clutch-custom-order__form {
    background: #fff;
    border: 1px solid #DDE6EF;
    border-radius: 22px;
    box-shadow: 0 18px 44px rgba(7, 29, 51, 0.08);
  }

  .clutch-custom-order__hero-card {
    padding: 1.25rem;
  }

  .clutch-custom-order__hero-card strong,
  .clutch-custom-order__process strong,
  .clutch-custom-order__section-heading strong {
    color: #071D33;
    display: block;
    font-family: 'Exo 2', sans-serif;
    font-size: 1.2rem;
    line-height: 1.08;
  }

  .clutch-custom-order__grid-layout {
    align-items: start;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(240px, 0.36fr) minmax(0, 1fr);
  }

  .clutch-custom-order__process {
    display: grid;
    gap: 0.9rem;
    position: sticky;
    top: 1rem;
  }

  .clutch-custom-order__process article {
    padding: 1rem;
  }

  .clutch-custom-order__form {
    display: grid;
    gap: 1rem;
    padding: clamp(1rem, 2.4vw, 1.5rem);
  }

  .clutch-custom-order__section-heading {
    border-bottom: 1px solid #DDE6EF;
    padding-bottom: 1rem;
  }

  .clutch-custom-order__grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .clutch-custom-order__field {
    display: grid;
    gap: 0.35rem;
  }

  .clutch-custom-order__field--full {
    grid-column: 1 / -1;
  }

  .clutch-custom-order__field input,
  .clutch-custom-order__field textarea,
  .clutch-custom-order__field select {
    background: #F8FAFC;
    border: 1px solid #DDE6EF;
    border-radius: 14px;
    color: #384862;
    font: inherit;
    padding: 0.82rem 0.9rem;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    width: 100%;
  }

  .clutch-custom-order__field input:focus,
  .clutch-custom-order__field textarea:focus,
  .clutch-custom-order__field select:focus {
    background: #fff;
    border-color: #FFA665;
    box-shadow: 0 0 0 4px rgba(255, 166, 101, 0.18);
    outline: 0;
  }

  .clutch-custom-order__submit {
    background: #FFA665 !important;
    border-color: #FFA665 !important;
    border-radius: 12px !important;
    box-shadow: 0 16px 34px rgba(255, 166, 101, 0.3);
    color: #071D33 !important;
    font-weight: 900;
    justify-self: start;
    min-height: 52px;
    padding-inline: 1.35rem;
  }

  .clutch-custom-order__alert {
    border-radius: 14px;
    padding: 0.8rem 1rem;
  }

  .clutch-custom-order__alert--success {
    background: rgba(31, 157, 85, 0.12);
    border: 1px solid rgba(31, 157, 85, 0.32);
    color: #166534;
  }

  .clutch-custom-order__alert--error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(220, 38, 38, 0.35);
    color: #991b1b;
  }

  @media screen and (max-width: 900px) {
    .clutch-custom-order__hero,
    .clutch-custom-order__grid-layout,
    .clutch-custom-order__grid {
      grid-template-columns: 1fr;
    }

    .clutch-custom-order__process {
      position: static;
    }

    .clutch-custom-order__submit {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Clutch contact page",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Clutch contact page"
    }
  ]
}
{% endschema %}
