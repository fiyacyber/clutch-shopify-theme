<section class="clutch-reach-out section color-{{ section.settings.color_scheme }}">
  <div class="clutch-reach-out__card">
    <p class="clutch-reach-out__eyebrow">Custom orders</p>
    <h1>Request Custom Quote</h1>
    <p class="clutch-reach-out__subheading">
      Need a custom print order or help with artwork? Send us a message and we’ll get back to you.
    </p>

    <div class="clutch-reach-out__details" aria-label="Contact information">
      <div class="clutch-reach-out__item">
        <p class="clutch-reach-out__label">Email</p>
        <p class="clutch-reach-out__value">info@clutchprintshop.com</p>
      </div>

      <div class="clutch-reach-out__item">
        <p class="clutch-reach-out__label">Phone/Text</p>
        <p class="clutch-reach-out__value">(513) 951-8429</p>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .clutch-reach-out {
    display: grid;
    min-height: 55vh;
    padding: clamp(3rem, 8vw, 6rem) var(--page-margin);
    place-items: center;
  }

  .clutch-reach-out__card {
    background: #fff;
    border: 1px solid rgba(56, 72, 98, 0.14);
    border-radius: 24px;
    box-shadow: 0 18px 50px rgba(56, 72, 98, 0.08);
    margin-inline: auto;
    max-width: 760px;
    padding: clamp(1.5rem, 5vw, 3rem);
    text-align: center;
    width: min(100%, 760px);
  }

  .clutch-reach-out__eyebrow,
  .clutch-reach-out__label {
    color: #ffa665;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    margin: 0;
    text-transform: uppercase;
  }

  .clutch-reach-out h1 {
    color: #384862;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(2.4rem, 8vw, 4.5rem);
    line-height: 0.95;
    margin: 0.65rem 0 1rem;
  }

  .clutch-reach-out__subheading {
    color: rgba(34, 34, 34, 0.82);
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1rem, 2.6vw, 1.2rem);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 560px;
  }

  .clutch-reach-out__details {
    display: grid;
    gap: 1.25rem;
    margin-top: clamp(2rem, 5vw, 3rem);
  }

  .clutch-reach-out__item {
    border-top: 1px solid rgba(56, 72, 98, 0.14);
    padding-top: 1.25rem;
  }

  .clutch-reach-out__value {
    color: #384862;
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.25rem, 5vw, 2rem);
    font-weight: 800;
    line-height: 1.25;
    margin: 0.45rem 0 0;
    overflow-wrap: anywhere;
  }

  @media screen and (min-width: 750px) {
    .clutch-reach-out__details {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Request Custom Quote",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Request Custom Quote"
    }
  ]
}
{% endschema %}
