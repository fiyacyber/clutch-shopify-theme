<footer class="clutch-footer color-{{ section.settings.color_scheme }}">
  <div class="clutch-footer__inner">
    <div class="clutch-footer__brand">
      <a href="/" class="clutch-footer__brand-logo-link" aria-label="{{ shop.name }}">
        <img
          class="clutch-footer__brand-logo"
          src="{{ 'clutch-hero-logo-1920x700.png' | asset_url }}"
          alt="Clutch Print Shop"
          width="1920"
          height="700"
          loading="lazy"
        >
      </a>
      <p>Premium print products powered by Clutch Connect campaign analytics.</p>

      <div class="clutch-footer__resources">
        <h3>Resources</h3>
        <ul>
          <li><a href="/pages/smart-business-card">Smart Clutch Card</a></li>
          <li><a href="/pages/clutch-profile">Clutch Profile</a></li>
          <li><a href="/pages/qr-pro">Clutch Codes</a></li>
          <li><a href="/collections/business-kits">Business Kits</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/pages/file-upload-requirements">File Upload Requirements</a></li>
          <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
          <li><a href="/pages/qr-pro-terms">Clutch Codes Terms</a></li>
        </ul>
      </div>
    </div>

    <nav class="clutch-footer__nav" aria-label="Shop">
      <h3>Shop</h3>
      <ul>
        <li><a href="/products/standard-business-cards">Business Cards</a></li>
        <li><a href="/products/clutch-connect-card">Smart Clutch Card</a></li>
        <li><a href="/products/premium-flyers">Flyers</a></li>
        <li><a href="/products/door-hangers">Door Hangers</a></li>
        <li><a href="/products/yard-signs">Yard Signs</a></li>
        <li><a href="/products/premium-postcards">Postcards</a></li>
        <li><a href="/products/tri-fold-brochures">Brochures</a></li>
        <li><a href="/products/vinyl-banners">Banners</a></li>
        <li><a href="/products/startup-kit">Starter Kit</a></li>
        <li><a href="/products/growth-kit">Growth Kit</a></li>
        <li><a href="/pages/contact">Custom Orders</a></li>
      </ul>
    </nav>

    <div class="clutch-footer__contact">
      <h3>Reach Out</h3>
      <p><a href="mailto:info@clutchprintshop.com">info@clutchprintshop.com</a></p>
      <p><a href="tel:+15139518429">(513) 951-8429</a></p>
      <p>Text Only</p>
    </div>

    <div class="clutch-footer__bottom">
      <p>© 2026 Clutch Print Shop</p>
      <p>Smart Clutch Cards • Trackable Print Marketing • Clutch Connect Analytics</p>
    </div>
  </div>
</footer>

{% stylesheet %}
  .clutch-footer {
    background: #384862;
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    padding: clamp(2.75rem, 7vw, 4.5rem) var(--page-margin) 1.5rem;
  }

  .clutch-footer__inner {
    display: grid;
    gap: 1.25rem;
    margin-inline: auto;
    max-width: 1180px;
    text-align: center;
  }

  .clutch-footer h2,
  .clutch-footer h3 {
    font-family: 'Exo 2', sans-serif;
    margin: 0;
  }

  .clutch-footer h2 {
    color: #ffa665;
    font-size: clamp(2rem, 6vw, 3rem);
    line-height: 1;
  }

  .clutch-footer h3 {
    color: #ffa665;
    font-size: 1.2rem;
    margin-bottom: 0.9rem;
  }

  .clutch-footer p {
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.55;
    margin: 0;
  }

  .clutch-footer__brand p {
    margin-top: 0.75rem;
  }

  .clutch-footer__brand-logo-link {
    display: inline-flex;
    min-height: 0;
    max-width: 420px;
  }

  .clutch-footer__brand-logo {
    display: block;
    width: 100%;
    height: auto;
  }

  .clutch-footer__resources {
    display: grid;
    gap: 0.8rem;
    margin-top: 1.4rem;
    padding-top: 1.15rem;
    border-top: 1px solid rgb(255 255 255 / 0.12);
  }

  .clutch-footer__resources h3 {
    margin-bottom: 0;
  }

  .clutch-footer__brand,
  .clutch-footer__nav,
  .clutch-footer__contact {
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 24px;
    padding: clamp(1.1rem, 3vw, 1.5rem);
    box-shadow: 0 18px 36px rgb(26 34 49 / 0.14);
  }

  .clutch-footer ul {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .clutch-footer a {
    color: #fff;
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    text-decoration: none;
  }

  .clutch-footer a:hover {
    color: #ffa665;
  }

  .clutch-footer__nav ul a,
  .clutch-footer__contact a {
    padding: 0.15rem 0;
  }

  .clutch-footer__contact {
    display: grid;
    gap: 0.45rem;
    align-content: start;
    grid-auto-rows: min-content;
  }

  .clutch-footer__contact a {
    min-height: auto;
  }

  .clutch-footer__contact p:last-child {
    color: #ffa665;
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .clutch-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    display: grid;
    gap: 0.4rem;
    padding-top: 1.25rem;
  }

  .clutch-footer__bottom p {
    font-size: 0.86rem;
  }

  @media screen and (min-width: 750px) {
    .clutch-footer__inner {
      grid-template-columns: 1.15fr 1fr 0.85fr;
      text-align: left;
    }

    .clutch-footer__nav ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 1rem;
    }

    .clutch-footer__bottom {
      grid-column: 1 / -1;
      text-align: center;
    }
  }

  @media screen and (max-width: 749px) {
    .clutch-footer {
      padding-top: 2.5rem;
    }

    .clutch-footer__brand,
    .clutch-footer__nav,
    .clutch-footer__contact {
      text-align: left;
    }

    .clutch-footer__nav ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 0.85rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Clutch footer",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Clutch footer"
    }
  ]
}
{% endschema %}
