<section class="clutch-pricing-page" aria-labelledby="clutch-pricing-title">
  <div class="clutch-pricing-page__inner">
    <header class="clutch-pricing-page__header">
      <p class="clutch-pricing-page__eyebrow">Pricing</p>
      <h1 id="clutch-pricing-title">Plans for digital profiles, QR tracking, and print marketing.</h1>
      <p>
        Start with a free Clutch Connect profile, then upgrade when you need advanced lead capture,
        QR campaign tracking, or agency reporting.
      </p>
    </header>

    <section class="clutch-pricing-page__cards" aria-label="Plan cards">
      <article class="clutch-plan-card">
        <p class="clutch-plan-card__badge">Free profile</p>
        <h2>Clutch Connect Basic</h2>
        <p class="clutch-plan-card__price">Free</p>
        <p class="clutch-plan-card__desc">A simple digital profile for NFC cards, QR codes, and social media bios.</p>
        <ul>
          <li>Public digital profile</li>
          <li>Contact buttons</li>
          <li>Social links</li>
          <li>Save contact button</li>
          <li>Basic request form</li>
          <li>Basic Lead Inbox</li>
          <li>Basic view/click tracking</li>
          <li>Clutch Connect branding</li>
        </ul>
        <a class="clutch-plan-card__cta clutch-plan-card__cta--primary" href="/login">Create free profile</a>
      </article>

      <article class="clutch-plan-card clutch-plan-card--featured">
        <p class="clutch-plan-card__badge">Best for profiles</p>
        <h2>Clutch Connect+</h2>
        <p class="clutch-plan-card__price">$9.99/mo</p>
        <p class="clutch-plan-card__desc">Turn your profile into a branded lead capture and analytics tool.</p>
        <ul>
          <li>Everything in Basic</li>
          <li>Advanced profile builder</li>
          <li>Premium banner themes</li>
          <li>Custom quote/request forms</li>
          <li>Advanced Lead Inbox</li>
          <li>Heatmap/profile analytics</li>
          <li>Source tracking</li>
          <li>Remove Clutch branding</li>
        </ul>
        <a class="clutch-plan-card__cta clutch-plan-card__cta--primary" href="/products/clutch-connect-plus">Upgrade to Connect+</a>
      </article>

      <article class="clutch-plan-card">
        <p class="clutch-plan-card__badge">Best for print tracking</p>
        <h2>QR Pro</h2>
        <p class="clutch-plan-card__price">$14.99/mo</p>
        <p class="clutch-plan-card__desc">Create, customize, and track dynamic QR campaigns for print and marketing.</p>
        <ul>
          <li>100 dynamic QR codes</li>
          <li>Editable destinations</li>
          <li>QR color customization</li>
          <li>Logo upload</li>
          <li>PNG/SVG/JPEG/PDF exports</li>
          <li>Scan analytics</li>
          <li>Device/location analytics</li>
          <li>Campaign performance</li>
        </ul>
        <a class="clutch-plan-card__cta clutch-plan-card__cta--primary" href="/products/qr-pro">Upgrade to QR Pro</a>
      </article>

      <article class="clutch-plan-card">
        <p class="clutch-plan-card__badge">For teams and agencies</p>
        <h2>Agency</h2>
        <p class="clutch-plan-card__price">Custom</p>
        <p class="clutch-plan-card__desc">For agencies, multi-location businesses, and high-volume QR campaign reporting.</p>
        <ul>
          <li>250+ QR codes</li>
          <li>Higher scan volume</li>
          <li>Multi-client reporting</li>
          <li>Campaign comparison</li>
          <li>Advanced filters</li>
          <li>CSV/PDF reporting</li>
          <li>Priority setup</li>
          <li>Custom onboarding</li>
        </ul>
        <a class="clutch-plan-card__cta clutch-plan-card__cta--secondary" href="/pages/contact">Request Agency Quote</a>
      </article>
    </section>

    <section class="clutch-pricing-page__compare" aria-labelledby="clutch-compare-title">
      <div class="clutch-pricing-page__compare-head">
        <p class="clutch-pricing-page__eyebrow">Compare Plans</p>
        <h2 id="clutch-compare-title">Feature comparison</h2>
      </div>

      <div class="clutch-pricing-table-wrap" role="region" aria-label="Pricing comparison table" tabindex="0">
        <table class="clutch-pricing-table">
          <thead>
            <tr>
              <th>Feature</th>
              <th>Basic</th>
              <th>Connect+</th>
              <th>QR Pro</th>
