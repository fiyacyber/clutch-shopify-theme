{% stylesheet %}
  .clutch-pricing-page {
    background: #f6f8fb;
    color: #0b1f35;
    padding: clamp(3rem, 6vw, 5.5rem) 0;
  }

  .clutch-pricing-page__inner {
    margin-inline: auto;
    max-width: 1220px;
    padding-inline: clamp(1rem, 3vw, 2rem);
  }

  .clutch-pricing-page__header,
  .clutch-pricing-page__compare-head {
    margin: 0 auto clamp(1.5rem, 4vw, 2.5rem);
    max-width: 860px;
    text-align: center;
  }

  .clutch-pricing-page__eyebrow {
    color: #ffa665;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  .clutch-pricing-page h1,
  .clutch-pricing-page h2 {
    color: #0b1f35;
    font-family: 'Exo 2', sans-serif;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0;
    text-wrap: balance;
  }

  .clutch-pricing-page h1 {
    font-size: clamp(2.05rem, 5vw, 4.1rem);
  }

  .clutch-pricing-page h2 {
    font-size: clamp(1.25rem, 2.4vw, 1.8rem);
  }

  .clutch-pricing-page__header p:last-child,
  .clutch-plan-card__desc {
    color: #69758a;
    line-height: 1.62;
    margin-top: 0.9rem;
  }

  .clutch-pricing-page__cards {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .clutch-plan-card {
    background: #fff;
    border: 1px solid #dde5ef;
    border-radius: 18px;
    box-shadow: 0 14px 30px rgba(11, 31, 53, 0.08);
    display: grid;
    grid-template-rows: auto auto auto auto 1fr auto;
    gap: 0.7rem;
    min-width: 0;
    padding: 1.05rem;
  }

  .clutch-plan-card--featured {
    border-color: rgba(255, 166, 101, 0.7);
    box-shadow: 0 20px 40px rgba(255, 166, 101, 0.18);
  }

  .clutch-plan-card__badge {
    background: #fff7f0;
    border: 1px solid rgba(255, 166, 101, 0.45);
    border-radius: 999px;
    color: #384862;
    display: inline-flex;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0;
    padding: 0.35rem 0.6rem;
    text-transform: uppercase;
    width: fit-content;
  }

  .clutch-plan-card__price {
    color: #384862;
    font-family: 'Exo 2', sans-serif;
    font-size: 1.65rem;
    font-weight: 900;
    line-height: 1;
    margin: 0;
  }

  .clutch-plan-card ul {
    display: grid;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .clutch-plan-card li {
    align-items: start;
    color: #384862;
    display: grid;
    font-size: 0.86rem;
    font-weight: 700;
    gap: 0.45rem;
    grid-template-columns: 14px 1fr;
    line-height: 1.35;
  }

  .clutch-plan-card li::before {
    color: #ffa665;
    content: '+';
    font-weight: 900;
  }

  .clutch-plan-card__cta {
    align-items: center;
    border-radius: 10px;
    display: inline-flex;
    font-weight: 900;
    justify-content: center;
    min-height: 44px;
    padding: 0.7rem 0.95rem;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
  }

  .clutch-plan-card__cta--primary {
    background: #384862;
    color: #fff;
  }

  .clutch-plan-card__cta--secondary {
    background: #ffa665;
    color: #0b1f35;
  }

  .clutch-pricing-page__compare {
    background: #fff;
    border: 1px solid #dde5ef;
    border-radius: 20px;
    box-shadow: 0 16px 34px rgba(11, 31, 53, 0.07);
    padding: clamp(1rem, 3vw, 1.7rem);
  }

  .clutch-pricing-table-wrap {
    overflow-x: auto;
    border: 1px solid #dde5ef;
    border-radius: 14px;
  }

  .clutch-pricing-table {
    border-collapse: collapse;
    min-width: 760px;
    width: 100%;
  }

  .clutch-pricing-table th,
  .clutch-pricing-table td {
    border-bottom: 1px solid #dde5ef;
    font-size: 0.88rem;
    line-height: 1.35;
    padding: 0.68rem 0.7rem;
    text-align: left;
    white-space: nowrap;
  }

  .clutch-pricing-table th {
    background: #f6f8fb;
    color: #384862;
    font-size: 0.76rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .clutch-pricing-table td:first-child,
  .clutch-pricing-table th:first-child {
    white-space: normal;
    width: 28%;
  }

  .clutch-pricing-mobile-compare {
    display: none;
    gap: 0.65rem;
  }

  .clutch-pricing-mobile-compare details {
    background: #f6f8fb;
    border: 1px solid #dde5ef;
    border-radius: 12px;
    padding: 0.7rem;
  }

  .clutch-pricing-mobile-compare summary {
    color: #384862;
    cursor: pointer;
    font-weight: 900;
  }

  .clutch-pricing-mobile-compare ul {
    display: grid;
    gap: 0.45rem;
    list-style: none;
    margin: 0.7rem 0 0;
    padding: 0;
  }

  .clutch-pricing-mobile-compare li {
    color: #384862;
    font-size: 0.86rem;
    line-height: 1.35;
  }

  @media screen and (max-width: 1180px) {
    .clutch-pricing-page__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .clutch-pricing-page__cards {
      grid-template-columns: 1fr;
    }

    .clutch-pricing-table-wrap {
      display: none;
    }

    .clutch-pricing-mobile-compare {
      display: grid;
    }
  }
{% endstylesheet %}

