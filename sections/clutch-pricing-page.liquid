            </tr>
          </thead>
          <tbody>
            <tr><td>Public digital profile</td><td>Yes</td><td>Yes</td><td>Yes</td><td>Yes</td></tr>
            <tr><td>Contact buttons</td><td>Yes</td><td>Yes</td><td>Yes</td><td>Yes</td></tr>
            <tr><td>Social links</td><td>Yes</td><td>Yes</td><td>Yes</td><td>Yes</td></tr>
