<section class="sbc-page color-{{ section.settings.color_scheme }}" aria-labelledby="sbc-hero-title">
  <div class="sbc-shell">
    <div class="sbc-hero">
      <div class="sbc-hero__copy sbc-reveal">
        <h1 id="sbc-hero-title">
          <span class="sbc-hero-title-main">Metal Business Card</span>
          <span class="sbc-hero-title-secondary">w/ NFC Technology</span>
        </h1>
        <div class="sbc-hero-tagline-cta-wrap">
          <a class="sbc-hero-tagline-cta" href="/products/clutch-connect-card">Tap. Share. Connect.</a>
        </div>
        <ul class="sbc-hero-checklist" aria-label="Included benefits">
          <li>
            <span class="sbc-hero-checklist__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M20 12a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z" stroke="currentColor" stroke-width="1.8"/><path d="m8.6 12.2 2.2 2.2 4.5-4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Free Digital Profile</span>
          </li>
          <li>
            <span class="sbc-hero-checklist__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M20 12a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z" stroke="currentColor" stroke-width="1.8"/><path d="m8.6 12.2 2.2 2.2 4.5-4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Guided Setup Included</span>
          </li>
        </ul>

        <div class="sbc-actions">
          <a class="sbc-btn sbc-btn--primary" href="/products/clutch-connect-card">Order Smart Card</a>
          <a class="sbc-btn sbc-btn--secondary" href="#connect-plans">Compare Connect Plans</a>
        </div>
      </div>
    </div>

    <section class="sbc-section sbc-section--soft" aria-labelledby="sbc-plus-title">
      <div class="sbc-section__head sbc-reveal">
        <h2 id="sbc-plus-title">Unlock more with Clutch <span class="sbc-plus-title-accent">Connect+</span></h2>
        <p>
          Upgrade your smart card profile with better customization, stronger lead tools, and analytics
          that show what people actually do after they tap or scan.
        </p>
        <div class="sbc-section__cta">
          <a class="sbc-btn sbc-btn--primary" href="/products/clutch-connect-card">Start 14-Day Free Trial</a>
        </div>
      </div>

      <div class="sbc-plus-carousel sbc-reveal sbc-reveal-delay-1" data-sbc-carousel>
        <div class="sbc-plus-track" data-sbc-track>
          <article class="sbc-plus-card">
            <span class="sbc-icon-badge"> 
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16M7 4v6M17 4v6M5 11h14v9H5z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <h3>Better Profile Builder</h3>
            <p>Create a cleaner digital profile with stronger layout, sections, buttons, and brand control.</p>
          </article>
          <article class="sbc-plus-card">
            <span class="sbc-icon-badge">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 18h16M7 15l3-3 3 2 4-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <h3>Advanced Analytics</h3>
            <p>See more than basic views. Track taps, scans, clicks, and engagement patterns.</p>
          </article>
          <article class="sbc-plus-card">
            <span class="sbc-icon-badge">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><rect x="4" y="4" width="16" height="16" rx="4" stroke="currentColor" stroke-width="1.7"/></svg>
            </span>
            <h3>Lead Capture</h3>
            <p>Let visitors request quotes, ask questions, or send their contact info from your profile.</p>
          </article>
          <article class="sbc-plus-card">
            <span class="sbc-icon-badge">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 15v4H4V5h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M20 4l-9 9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M14 4h6v6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <h3>Follow Ups</h3>
            <p>Keep track of new leads so you know who to contact after they interact with your card.</p>
          </article>
          <article class="sbc-plus-card">
            <span class="sbc-icon-badge">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3" stroke="currentColor" stroke-width="1.7"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
            </span>
            <h3>Contact Saves</h3>
            <p>Make it easier for customers to save your business details directly from your profile.</p>
          </article>
          <article class="sbc-plus-card">
            <span class="sbc-icon-badge">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-4.8 7-11a7 7 0 1 0-14 0c0 6.2 7 11 7 11z" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="10" r="2.2" stroke="currentColor" stroke-width="1.7"/></svg>
            </span>
            <h3>Heatmap</h3>
            <p>See where engagement is coming from and understand which areas are interacting with your card.</p>
          </article>

          <article class="sbc-plus-card is-duplicate" aria-hidden="true">
            <span class="sbc-icon-badge"><svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16M7 4v6M17 4v6M5 11h14v9H5z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <h3>Better Profile Builder</h3>
            <p>Create a cleaner digital profile with stronger layout, sections, buttons, and brand control.</p>
          </article>
          <article class="sbc-plus-card is-duplicate" aria-hidden="true">
            <span class="sbc-icon-badge"><svg viewBox="0 0 24 24" fill="none"><path d="M4 18h16M7 15l3-3 3 2 4-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <h3>Advanced Analytics</h3>
            <p>See more than basic views. Track taps, scans, clicks, and engagement patterns.</p>
          </article>
          <article class="sbc-plus-card is-duplicate" aria-hidden="true">
            <span class="sbc-icon-badge"><svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><rect x="4" y="4" width="16" height="16" rx="4" stroke="currentColor" stroke-width="1.7"/></svg></span>
            <h3>Lead Capture</h3>
            <p>Let visitors request quotes, ask questions, or send their contact info from your profile.</p>
          </article>
          <article class="sbc-plus-card is-duplicate" aria-hidden="true">
            <span class="sbc-icon-badge"><svg viewBox="0 0 24 24" fill="none"><path d="M20 15v4H4V5h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M20 4l-9 9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M14 4h6v6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <h3>Follow Ups</h3>
            <p>Keep track of new leads so you know who to contact after they interact with your card.</p>
          </article>
          <article class="sbc-plus-card is-duplicate" aria-hidden="true">
            <span class="sbc-icon-badge"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="3" stroke="currentColor" stroke-width="1.7"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>
            <h3>Contact Saves</h3>
            <p>Make it easier for customers to save your business details directly from your profile.</p>
          </article>
          <article class="sbc-plus-card is-duplicate" aria-hidden="true">
            <span class="sbc-icon-badge"><svg viewBox="0 0 24 24" fill="none"><path d="M12 21s7-4.8 7-11a7 7 0 1 0-14 0c0 6.2 7 11 7 11z" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="10" r="2.2" stroke="currentColor" stroke-width="1.7"/></svg></span>
            <h3>Heatmap</h3>
            <p>See where engagement is coming from and understand which areas are interacting with your card.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="sbc-section sbc-section--soft" aria-labelledby="sbc-steps-title">
      <div class="sbc-section__head sbc-reveal">
        <h2 id="sbc-steps-title">3 Easy Steps</h2>
      </div>
      <div class="sbc-grid sbc-grid--3">
        <article class="sbc-card sbc-reveal sbc-reveal-delay-1"><h3>Order your card</h3><p>Choose your Smart Business Card and complete checkout.</p></article>
        <article class="sbc-card sbc-reveal sbc-reveal-delay-2"><h3>Build Your Profile</h3><p>Set up your business details, brand identity, and links in Clutch Connect.</p></article>
        <article class="sbc-card sbc-card--orange sbc-reveal sbc-reveal-delay-3"><h3>Start Sharing</h3><p>Tap, scan, and share your profile anywhere with one clean destination.</p></article>
      </div>
    </section>

    <section class="sbc-section" aria-labelledby="sbc-socials-title">
      <div class="sbc-section__head sbc-reveal">
        <h2 id="sbc-socials-title">Add Your Socials</h2>
        <p>Connect the platforms your audience already uses so your profile works like your social hub and include it in your bio.</p>
      </div>
      <div class="sbc-grid sbc-grid--3 sbc-social-grid">
        <article class="sbc-card sbc-social-card sbc-reveal sbc-reveal-delay-1">
          <span class="sbc-social-icon sbc-social-icon--instagram" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3.8" stroke="currentColor" stroke-width="1.8"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor"/></svg></span>
          <h3>Instagram</h3>
        </article>
        <article class="sbc-card sbc-social-card sbc-reveal sbc-reveal-delay-2">
          <span class="sbc-social-icon sbc-social-icon--facebook" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M14.8 6.6h2.2V4h-2.2c-2.6 0-4.2 1.6-4.2 4.2v2H8v2.8h2.6V20h3.1v-7h2.8l.4-2.8h-3.2v-2c0-1 .4-1.6 1.1-1.6z" fill="currentColor"/></svg></span>
          <h3>Facebook</h3>
        </article>
        <article class="sbc-card sbc-social-card sbc-reveal sbc-reveal-delay-3">
          <span class="sbc-social-icon sbc-social-icon--linkedin" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="M8.2 10.2V16M8.2 8.1v.1M11.2 16v-5.8h2.5v.8c.4-.5 1-.8 1.8-.8 1.5 0 2.3 1 2.3 2.7V16h-2.4v-2.8c0-.8-.3-1.3-1-1.3-.7 0-1.1.5-1.1 1.3V16h-2.1z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h3>LinkedIn</h3>
        </article>
        <article class="sbc-card sbc-social-card sbc-reveal">
          <span class="sbc-social-icon sbc-social-icon--tiktok" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M14.4 5v8.1a3.4 3.4 0 1 1-2.6-3.3" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/><path d="M14.4 5c.7 1.2 1.8 2 3.2 2.2" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg></span>
          <h3>TikTok</h3>
        </article>
        <article class="sbc-card sbc-social-card sbc-reveal sbc-reveal-delay-1">
          <span class="sbc-social-icon sbc-social-icon--youtube" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="3.5" y="6.5" width="17" height="11" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="M10.2 9.4 15 12l-4.8 2.6V9.4z" fill="currentColor"/></svg></span>
          <h3>YouTube</h3>
        </article>
        <article class="sbc-card sbc-social-card sbc-reveal sbc-reveal-delay-2">
          <span class="sbc-social-icon sbc-social-icon--x" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 5h3.4l3.6 5.3L16 5h3l-5.3 6.2L19.2 19h-3.4l-3.9-5.8L7 19H4l5.5-6.6L5 5z" fill="currentColor"/></svg></span>
          <h3>X</h3>
        </article>
      </div>
    </section>

    <section class="sbc-section" id="connect-plans" aria-labelledby="sbc-plans-title">
      <section class="sbc-section sbc-section--soft" aria-labelledby="sbc-audience-title">
        <div class="sbc-section__head sbc-reveal">
          <h2 id="sbc-audience-title">Built for everyone</h2>
        </div>
        <div class="sbc-highlights sbc-reveal sbc-reveal-delay-1" role="list" aria-label="Who uses Clutch Smart Business Card">
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M3.5 20h17M6 18V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v9M9 7V5h6v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span>Contractors</span>
          </article>
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 21s7-4.8 7-11a7 7 0 1 0-14 0c0 6.2 7 11 7 11z" stroke="currentColor" stroke-width="1.8"/><path d="M9.5 10.5h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
            <span>Realtors</span>
          </article>
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="14" rx="2.5" stroke="currentColor" stroke-width="1.8"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
            <span>Sales Reps</span>
          </article>
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 19h14M7 19V9h10v10M10 9V6h4v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span>Barbers / Cosmetologists</span>
          </article>
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3" stroke="currentColor" stroke-width="1.8"/><path d="M5 20a7 7 0 0 1 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
            <span>Coaches</span>
          </article>
        </div>
      </section>

      <div class="sbc-section__head sbc-reveal">
      </section>

      <section class="sbc-section" id="connect-plans" aria-labelledby="sbc-plans-title">
      <section class="sbc-section sbc-section--soft" aria-labelledby="sbc-audience-title">
        <div class="sbc-section__head sbc-reveal">
          <h2 id="sbc-audience-title">Built for everyone</h2>
        </div>
        <div class="sbc-highlights sbc-reveal sbc-reveal-delay-1" role="list" aria-label="Who uses Clutch Smart Business Card">
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M3.5 20h17M6 18V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v9M9 7V5h6v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span>Contractors</span>
          </article>
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 21s7-4.8 7-11a7 7 0 1 0-14 0c0 6.2 7 11 7 11z" stroke="currentColor" stroke-width="1.8"/><path d="M9.5 10.5h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
            <span>Realtors</span>
          </article>
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="14" rx="2.5" stroke="currentColor" stroke-width="1.8"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
            <span>Sales Reps</span>
          </article>
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 19h14M7 19V9h10v10M10 9V6h4v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span>Barbers / Cosmetologists</span>
          </article>
          <article class="sbc-highlight" role="listitem">
            <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3" stroke="currentColor" stroke-width="1.8"/><path d="M5 20a7 7 0 0 1 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
            <span>Coaches</span>
          </article>
        </div>
      </section>

      <section class="sbc-section" id="connect-plans" aria-labelledby="sbc-plans-title">
        <div class="sbc-section__head sbc-reveal">
        <div class="sbc-section__head sbc-reveal">
        <h2 id="sbc-plans-title" class="sbc-plans-title">Clutch Connect</h2>
      </div>

      <div class="sbc-billing-toggle sbc-reveal sbc-reveal-delay-1" role="tablist" aria-label="Billing interval" data-sbc-billing-toggle>
        <button type="button" role="tab" aria-selected="false" aria-pressed="false" data-billing="free">Free</button>
        <button type="button" role="tab" aria-selected="true" aria-pressed="true" class="is-active" data-billing="monthly">Monthly</button>
        <button type="button" role="tab" aria-selected="false" aria-pressed="false" data-billing="annual">Annual - Save 50%</button>
      </div>

      <div class="sbc-grid sbc-grid--2 sbc-pricing-grid">
        <article class="sbc-price-card sbc-price-card--base sbc-reveal sbc-reveal-delay-1" data-billing-base-card hidden>
          <p class="sbc-price-card__badge">Included with Smart Card</p>
          <h3>Clutch Connect</h3>
          <p class="sbc-price">Free</p>
          <p>A simple digital profile for sharing your business details from your NFC card or QR code.</p>
          <p class="sbc-feature-heading">Included features:</p>
          <div class="sbc-feature-tiles sbc-feature-tiles--base" role="list" aria-label="Clutch Connect features">
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="14" rx="3" stroke="currentColor" stroke-width="1.7"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Free Digital Profile</h4>
                <p>A simple public profile connected to your card.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M4 20h7M13 4l7 7M11 6l7 7M10 13l-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="7" r="3" stroke="currentColor" stroke-width="1.7"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Guided Setup</h4>
                <p>Send your details and we help get you started.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M4 18h16M7 14l3-3 3 2 4-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="14" r="1.2" fill="currentColor"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Basic Tap &amp; Scan Analytics</h4>
                <p>See simple activity from your NFC card and QR code.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="14" rx="3" stroke="currentColor" stroke-width="1.7"/><path d="M7.5 9h9M7.5 12h6M7.5 15h4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Basic Lead Form</h4>
                <p>Let visitors send a simple message or request.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="6" width="18" height="13" rx="2.5" stroke="currentColor" stroke-width="1.7"/><path d="M7 10h10M7 14h6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M18 6V4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Contact Saves</h4>
                <p>Make it easy for customers to save your info.</p>
              </div>
            </article>
          </div>
          <p class="sbc-branding-helper">Free profiles include Clutch branding.</p>
          <span class="sbc-btn sbc-btn--muted">Included with Smart Card</span>
        </article>

        <article class="sbc-price-card sbc-price-card--featured sbc-reveal sbc-reveal-delay-2" data-billing-plus-card>
          <div class="sbc-price-card__badges">
            <p class="sbc-price-card__badge sbc-price-card__badge--warm">14-day free trial</p>
            <p class="sbc-price-card__badge sbc-price-card__badge--outline">Best Value</p>
          </div>
          <h3>Clutch <span class="sbc-plus-title-accent">Connect+</span></h3>
          <p class="sbc-price" data-billing-monthly>$9.99<span>/month</span></p>
          <p class="sbc-price" data-billing-annual hidden>$60<span>/year</span></p>
          <p class="sbc-price-helper" data-billing-annual hidden>Equivalent to $5/month</p>
          <p class="sbc-price-savings" data-billing-annual hidden>Save 50% with annual billing</p>
          <p>For businesses that want a more polished profile, better lead capture, and stronger analytics.</p>
          <p class="sbc-feature-heading">Everything in Connect, plus:</p>
          <div class="sbc-feature-tiles sbc-feature-tiles--plus" role="list" aria-label="Clutch Connect Plus features">
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="7" height="6" rx="1.2" stroke="currentColor" stroke-width="1.7"/><rect x="13" y="5" width="7" height="6" rx="1.2" stroke="currentColor" stroke-width="1.7"/><rect x="4" y="13" width="16" height="6" rx="1.2" stroke="currentColor" stroke-width="1.7"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Advanced Profile Builder</h4>
                <p>Create a more polished, flexible digital profile.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M4 18h16M7 14l3-3 3 2 4-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 20s5-3.2 5-7a5 5 0 1 0-10 0c0 3.8 5 7 5 7z" stroke="currentColor" stroke-width="1.5"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Analytics + Heatmap</h4>
                <p>Track taps, scans, clicks, and location activity.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="12" height="14" rx="2.5" stroke="currentColor" stroke-width="1.7"/><path d="M7.5 10h5M7.5 13h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M18 8v4M16 10h4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Lead Capture + Follow-Up</h4>
                <p>Collect quote requests and manage next steps.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="1.7"/><path d="M3 10h18" stroke="currentColor" stroke-width="1.7"/><path d="M7 8h3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Banner Themes</h4>
                <p>Add branded profile visuals and seasonal banners.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="4" rx="1.2" stroke="currentColor" stroke-width="1.7"/><rect x="4" y="10" width="16" height="4" rx="1.2" stroke="currentColor" stroke-width="1.7"/><rect x="4" y="15" width="16" height="4" rx="1.2" stroke="currentColor" stroke-width="1.7"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Custom Sections</h4>
                <p>Add flexible sections for services, offers, or details.</p>
              </div>
            </article>
            <article class="sbc-feature-tile" role="listitem">
              <span class="sbc-feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M3 12s3.2-5 9-5 9 5 9 5-3.2 5-9 5-9-5-9-5z" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="12" r="2.1" stroke="currentColor" stroke-width="1.7"/><path d="M5 19L19 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
              </span>
              <div class="sbc-feature-content">
                <h4>Remove Clutch Branding</h4>
                <p>Keep the profile focused on your business.</p>
              </div>
            </article>
          </div>
          <a class="sbc-btn sbc-btn--primary" href="/products/clutch-connect-card">Try Connect+</a>
          <p class="sbc-cta-helper">14 Day Free Trial - Cancel Anytime</p>
        </article>
      </div>
    </section>

    <section class="sbc-section sbc-section--soft" aria-labelledby="sbc-audience-title">
      <div class="sbc-section__head sbc-reveal">
        <h2 id="sbc-audience-title">Built for everyone</h2>
      </div>
      <div class="sbc-highlights sbc-reveal sbc-reveal-delay-1" role="list" aria-label="Who uses Clutch Smart Business Card">
        <article class="sbc-highlight" role="listitem">
          <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M3.5 20h17M6 18V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v9M9 7V5h6v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <span>Contractors</span>
        </article>
        <article class="sbc-highlight" role="listitem">
          <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 21s7-4.8 7-11a7 7 0 1 0-14 0c0 6.2 7 11 7 11z" stroke="currentColor" stroke-width="1.8"/><path d="M9.5 10.5h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
          <span>Realtors</span>
        </article>
        <article class="sbc-highlight" role="listitem">
          <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="14" rx="2.5" stroke="currentColor" stroke-width="1.8"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
          <span>Sales Reps</span>
        </article>
        <article class="sbc-highlight" role="listitem">
          <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 19h14M7 19V9h10v10M10 9V6h4v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <span>Barbers / Cosmetologists</span>
        </article>
        <article class="sbc-highlight" role="listitem">
          <span class="sbc-highlight__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3" stroke="currentColor" stroke-width="1.8"/><path d="M5 20a7 7 0 0 1 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>
          <span>Coaches</span>
        </article>
      </div>
    </section>

      <section class="sbc-section sbc-section--soft" aria-labelledby="sbc-faq-title">

      <section class="sbc-section sbc-section--soft" aria-labelledby="sbc-faq-title">
      <div class="sbc-section__head sbc-reveal">
        <h2 id="sbc-faq-title">Frequently asked questions</h2>
      </div>
        <div class="sbc-faq sbc-reveal sbc-reveal-delay-1">
          <details><summary>Do I need Connect+ to use the card?</summary><p>No. Every Smart Business Card includes Clutch Connect Free. Connect+ is optional if you want advanced profile features, themes, lead capture, follow ups, heatmap, and advanced analytics.</p></details>
        <details><summary>Can I update my links after the card is made?</summary><p>Yes. Your card points to your Clutch Connect profile, so you can update your profile and links without replacing the physical card.</p></details>
        <details><summary>What if someone cannot use NFC?</summary><p>The card can also use a QR backup, so people can scan instead of tapping.</p></details>
        <details><summary>Is the card only available in black?</summary><p>Yes. This offer is for a black metal NFC card connected to a Clutch Connect profile.</p></details>
        <details><summary>Can I add my logo?</summary><p>Yes. Customers can submit business details and logo information after checkout.</p></details>
        <details><summary>What does the free Clutch Connect plan include?</summary><p>Clutch Connect Free includes a public digital profile, NFC tap destination, QR backup destination, Basic Analytics, Basic Lead Form, Contact Saves, Guided Setup, and profile updates.</p></details>
        <details><summary>What does Connect+ add?</summary><p>Connect+ adds Better Profile Builder, Advanced Analytics, Lead Capture, Follow Ups, Contact Saves, Heatmap, banner themes, custom sections, and stronger customization tools.</p></details>
        <details><summary>Can I cancel Connect+?</summary><p>Yes. Connect+ can be canceled anytime. The free Clutch Connect profile remains available unless the business changes its plan terms later.</p></details>
      </div>
    </section>

    <section class="sbc-final sbc-reveal" aria-labelledby="sbc-final-title">
      <h2 id="sbc-final-title">Ready to replace your basic business card?</h2>
      <p>Order a black metal NFC card with a live Clutch Connect profile and give customers a faster way to save, contact, and remember your business.</p>
      <div class="sbc-actions">
        <a class="sbc-btn sbc-btn--primary" href="/products/clutch-connect-card">Order Smart Card</a>
        <a class="sbc-btn sbc-btn--secondary" href="#connect-plans">Compare Connect Plans</a>
      </div>
    </section>
  </div>
</section>

{% stylesheet %}
  .sbc-page {
    --sbc-navy: #384862;
    --sbc-orange: #ffa665;
    --sbc-white: #ffffff;
    --sbc-soft: #f7f8fa;
    --sbc-border: rgba(255, 166, 101, 0.22);
    background:
      radial-gradient(1200px 600px at 50% -20%, rgba(255, 166, 101, 0.2), transparent 60%),
      linear-gradient(180deg, #f3f6fb 0%, #f7f8fa 38%, #f7f8fa 100%);
    color: var(--sbc-navy);
    overflow-x: hidden;
    padding: clamp(2.2rem, 4vw, 4rem) 0 4rem;
    width: 100%;
  }

  @supports (overflow: clip) {
    .sbc-page {
      overflow-x: clip;
    }
  }

  .sbc-page [hidden] {
    display: none !important;
  }

  .sbc-shell {
    margin: 0 auto;
    max-width: 1180px;
    overflow-x: hidden;
    padding: 0 clamp(1rem, 3vw, 2rem);
    width: 100%;
  }

  .sbc-hero,
  .sbc-section,
  .sbc-final {
    margin-top: 1.25rem;
  }

  .sbc-hero {
    align-items: center;
    display: grid;
    gap: 1.15rem;
    grid-template-columns: 1fr;
    justify-items: center;
    min-width: 0;
  }

  .sbc-hero__copy {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.88));
    border: 1px solid rgba(255, 166, 101, 0.26);
    border-radius: 28px;
    box-shadow: 0 22px 50px rgba(24, 44, 73, 0.11);
    display: grid;
    gap: 0.48rem;
    justify-items: center;
    max-width: 760px;
    padding: clamp(1.55rem, 3.4vw, 2.4rem) clamp(1rem, 3.2vw, 2.4rem) clamp(1.2rem, 2.8vw, 2rem);
    text-align: center;
  }

  .sbc-eyebrow {
    background: rgba(255, 166, 101, 0.18);
    border: 1px solid rgba(255, 166, 101, 0.44);
    border-radius: 999px;
    color: #8a4f2b;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0;
    padding: 0.35rem 0.75rem;
    text-transform: uppercase;
  }

  .sbc-hero h1,
  .sbc-section h2,
  .sbc-card h3,
  .sbc-price-card h3,
  .sbc-compare h3,
  .sbc-plus-card h3,
  .sbc-final h2 {
    color: var(--sbc-navy);
    font-family: 'Exo 2', sans-serif;
    line-height: 1.05;
    margin: 0;
  }

  .sbc-hero h1 {
    color: #000000;
    display: grid;
    gap: 0.36rem;
    font-size: clamp(1.9rem, 6vw, 4.15rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    max-width: 100%;
  }

  .sbc-hero-title-main,
  .sbc-hero-title-secondary {
    display: block;
    font-weight: 900;
  }

  .sbc-hero-title-main {
    white-space: nowrap;
  }

  .sbc-hero-title-secondary {
    font-size: 0.68em;
  }

  .sbc-hero-tagline-cta-wrap {
    display: grid;
    margin-top: 0.38rem;
    place-items: center;
    width: 100%;
  }

  .sbc-hero-tagline-cta {
    background: linear-gradient(135deg, #1b2230, #384862 48%, #ffa665);
    border: 1px solid rgba(255, 166, 101, 0.44);
    border-radius: 999px;
    box-shadow: 0 14px 28px rgba(27, 34, 48, 0.2);
    color: #ffffff;
    display: inline-flex;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(0.98rem, 2.7vw, 1.25rem);
    font-weight: 900;
    letter-spacing: 0.06em;
    line-height: 1;
    padding: 0.62rem 1.1rem;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .sbc-hero-tagline-cta:hover {
    box-shadow: 0 18px 30px rgba(27, 34, 48, 0.24);
    transform: translateY(-1px);
  }

  .sbc-hero-checklist {
    display: grid;
    gap: 0.34rem;
    list-style: none;
    margin: 0.52rem 0 0;
    max-width: 460px;
    padding: 0;
    width: min(100%, 460px);
  }

  .sbc-hero-checklist li {
    align-items: center;
    color: rgba(56, 72, 98, 0.92);
    display: flex;
    font-size: clamp(0.9rem, 1.08vw, 1rem);
    font-weight: 800;
    gap: 0.4rem;
    justify-content: center;
    line-height: 1.25;
    margin: 0;
    text-align: center;
  }

  .sbc-hero-checklist__icon {
    color: #384862;
    display: inline-flex;
    flex: 0 0 auto;
    height: 18px;
    width: 18px;
  }

  .sbc-hero-checklist__icon svg {
    height: 100%;
    width: 100%;
  }

  .sbc-card p,
  .sbc-price-card p,
  .sbc-plus-card p,
  .sbc-billing-note,
  .sbc-note,
  .sbc-final p {
    color: rgba(56, 72, 98, 0.84);
    line-height: 1.42;
    margin: 0;
  }

  .sbc-card--orange {
    background: var(--sbc-orange) !important;
    border-color: rgba(255, 166, 101, 0.95);
  }

  .sbc-card--orange h3 {
    color: #000000;
  }

  .sbc-card--orange p {
    color: #000000 !important;
  }

  .sbc-inclusion-line {
    background: rgba(255, 166, 101, 0.1);
    border: 1px solid rgba(255, 166, 101, 0.24);
    border-radius: 999px;
    color: rgba(56, 72, 98, 0.76);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.2;
    margin: 0.05rem 0 0;
    padding: 0.42rem 0.72rem;
  }

  .sbc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    justify-content: center;
    margin-top: 0.15rem;
  }

  .sbc-btn {
    align-items: center;
    border-radius: 11px;
    display: inline-flex;
    font-size: 0.96rem;
    font-weight: 900;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1.15rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .sbc-btn:hover {
    transform: translateY(-1px);
  }

  .sbc-btn--primary {
    background: linear-gradient(135deg, #ffb173, #ffa665 52%, #ff9a52);
    border: 1px solid rgba(255, 154, 82, 0.92);
    box-shadow: 0 16px 30px rgba(255, 166, 101, 0.3);
    color: var(--sbc-navy);
  }

  .sbc-btn--secondary {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(56, 72, 98, 0.22);
    color: var(--sbc-navy);
  }

  .sbc-btn--muted {
    background: #eef2f6;
    border: 1px solid #dbe3ec;
    color: var(--sbc-navy);
    cursor: default;
  }

  .sbc-note {
    background: rgba(56, 72, 98, 0.06);
    border: 1px solid rgba(56, 72, 98, 0.1);
    border-radius: 12px;
    font-size: 0.88rem;
    margin-top: 0.25rem;
    padding: 0.55rem 0.75rem;
  }

  .sbc-section {
    background: var(--sbc-white);
    border: 1px solid rgba(56, 72, 98, 0.09);
    border-radius: 20px;
    box-shadow: 0 14px 34px rgba(7, 29, 51, 0.06);
    min-width: 0;
    padding: clamp(1rem, 2.2vw, 1.7rem);
  }

  .sbc-section--soft {
    background: #f7f8fa;
  }

  .sbc-section__head {
    display: grid;
    gap: 0.6rem;
    justify-items: center;
    margin-bottom: 1rem;
    text-align: center;
  }

  .sbc-plans-title {
    font-size: clamp(2rem, 5vw, 3rem) !important;
    letter-spacing: -0.02em;
  }

  .sbc-section h2 {
    font-size: clamp(1.5rem, 4.8vw, 2.4rem);
    letter-spacing: -0.01em;
  }

  .sbc-section__cta {
    display: grid;
    gap: 0.45rem;
    justify-items: center;
    margin-top: 0.4rem;
  }

  .sbc-section__cta small {
    color: rgba(56, 72, 98, 0.74);
    font-size: 0.85rem;
  }

  .sbc-grid {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
  }

  .sbc-grid--4,
  .sbc-grid--3,
  .sbc-grid--2 {
    grid-template-columns: 1fr;
  }

  .sbc-card,
  .sbc-price-card,
  .sbc-plus-card,
  .sbc-compare__col {
    background: var(--sbc-white);
    border: 1px solid var(--sbc-border);
    border-radius: 16px;
    box-shadow: 0 12px 28px rgba(7, 29, 51, 0.06);
    min-width: 0;
    padding: 1rem;
    text-align: center;
  }

  .sbc-card h3,
  .sbc-plus-card h3 {
    font-size: 1.12rem;
    margin-bottom: 0.35rem;
  }

  .sbc-plus-carousel {
    max-width: 100%;
    overflow: hidden;
    padding-bottom: 0.2rem;
    scrollbar-width: none;
    touch-action: pan-y;
  }

  .sbc-plus-carousel::-webkit-scrollbar {
    display: none;
  }

  .sbc-plus-track {
    animation: sbcPlusScroll 42s linear infinite;
    display: flex;
    gap: 0.8rem;
    touch-action: pan-y;
    width: max-content;
    will-change: transform;
  }

  .sbc-plus-carousel:hover .sbc-plus-track {
    animation-play-state: paused;
  }

  .sbc-plus-card {
    aspect-ratio: 1 / 1;
    display: grid;
    flex: 0 0 min(82vw, 280px);
    gap: 0.55rem;
    min-height: 240px;
    width: min(82vw, 280px);
  }

  .sbc-icon-badge {
    align-items: center;
    background: rgba(255, 166, 101, 0.2);
    border-radius: 10px;
    color: var(--sbc-navy);
    display: inline-flex;
    height: 34px;
    justify-content: center;
    width: 34px;
  }

  .sbc-icon-badge svg {
    height: 18px;
    width: 18px;
  }

  .sbc-billing-toggle {
    align-items: center;
    background: #eef2f6;
    border: 1px solid rgba(56, 72, 98, 0.14);
    border-radius: 999px;
    display: inline-grid;
    gap: 0.35rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 640px;
    padding: 0.28rem;
    width: 100%;
  }

  .sbc-billing-toggle button {
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid transparent;
    border: 0;
    border-radius: 999px;
    color: rgba(56, 72, 98, 0.74);
    cursor: pointer;
    font-size: 0.86rem;
    font-weight: 800;
    min-height: 42px;
    padding: 0.55rem 0.8rem;
    transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .sbc-billing-toggle button:not(.is-active) {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(56, 72, 98, 0.08);
    box-shadow: none;
    color: rgba(56, 72, 98, 0.74);
  }

  .sbc-billing-toggle button.is-active {
    background: var(--sbc-orange);
    border-color: rgba(255, 166, 101, 0.95);
    box-shadow: 0 10px 20px rgba(255, 166, 101, 0.3);
    color: var(--sbc-navy);
  }

  .sbc-pricing-grid {
    margin-top: 1rem;
  }

  .sbc-price-card {
    display: grid;
    gap: 0.5rem;
    padding: clamp(0.9rem, 1.8vw, 1.2rem);
  }

  .sbc-price-card--base {
    border-color: rgba(56, 72, 98, 0.14);
    box-shadow: 0 14px 28px rgba(20, 35, 58, 0.05);
  }

  .sbc-price-card--featured {
    background: linear-gradient(180deg, #ffffff, #fffaf6);
    border-color: rgba(255, 166, 101, 0.52);
    box-shadow: 0 18px 34px rgba(255, 166, 101, 0.16);
    position: relative;
    padding-bottom: clamp(1rem, 2vw, 1.3rem);
  }

  .sbc-price-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
    margin-bottom: 0;
  }

  .sbc-price-card__badge {
    align-items: center;
    border-radius: 999px;
    color: var(--sbc-navy);
    display: inline-flex;
    font-size: 0.73rem;
    font-weight: 800;
    line-height: 1;
    margin: 0;
    justify-self: center;
    padding: 0.34rem 0.58rem;
    width: fit-content;
  }

  .sbc-price-card__badge--warm,
  .sbc-price-card__badge {
    background: rgba(255, 166, 101, 0.2);
    border: 1px solid rgba(255, 166, 101, 0.4);
  }

  .sbc-price-card__badge--outline {
    background: rgba(56, 72, 98, 0.08);
    border: 1px solid rgba(56, 72, 98, 0.2);
  }

  .sbc-price {
    color: var(--sbc-navy);
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1.62rem, 2.7vw, 2rem);
    font-weight: 900;
    letter-spacing: -0.01em;
    line-height: 1.05;
    margin: 0;
  }

  .sbc-price span {
    color: rgba(56, 72, 98, 0.78);
    font-size: 0.88rem;
    font-weight: 700;
    margin-left: 0.2rem;
  }

  .sbc-price-helper,
  .sbc-price-savings,
  .sbc-cta-helper {
    font-size: 0.8rem;
    line-height: 1.35;
    margin: 0;
  }

  .sbc-price-helper {
    color: rgba(56, 72, 98, 0.8);
  }

  .sbc-price-savings {
    color: #a55b29;
    font-weight: 800;
  }

  .sbc-feature-heading {
    color: var(--sbc-navy);
    font-size: 0.87rem;
    font-weight: 900;
    margin: 0.2rem 0 0;
    text-align: center;
  }

  .sbc-feature-tiles {
    display: grid;
    gap: 0.48rem;
    grid-template-columns: 1fr;
    margin: 0;
    padding: 0.05rem 0 0;
  }

  .sbc-feature-tile {
    align-items: flex-start;
    background: #f7f9fc;
    border: 1px solid rgba(56, 72, 98, 0.12);
    border-radius: 12px;
    box-shadow: 0 8px 18px rgba(7, 29, 51, 0.05);
    display: grid;
    gap: 0.5rem;
    grid-template-columns: 30px 1fr;
    line-height: 1.3;
    margin: 0;
    padding: 0.62rem 0.66rem;
    text-align: left;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .sbc-feature-tile:hover {
    box-shadow: 0 12px 22px rgba(7, 29, 51, 0.08);
    transform: translateY(-1px);
  }

  .sbc-feature-icon {
    align-items: center;
    background: rgba(255, 166, 101, 0.14);
    border-radius: 8px;
    color: var(--sbc-orange);
    display: inline-flex;
    height: 30px;
    justify-content: center;
    width: 30px;
  }

  .sbc-feature-icon svg {
    height: 17px;
    width: 17px;
  }

  .sbc-feature-content {
    display: grid;
    gap: 0.18rem;
  }

  .sbc-feature-content h4 {
    color: var(--sbc-navy);
    font-family: 'Exo 2', sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    line-height: 1.2;
    margin: 0;
  }

  .sbc-feature-content p {
    color: rgba(56, 72, 98, 0.74);
    font-size: 0.74rem;
    line-height: 1.35;
    margin: 0;
  }

  .sbc-feature-tiles--base .sbc-feature-tile {
    background: #f8fafd;
    border-color: rgba(56, 72, 98, 0.11);
    box-shadow: 0 8px 16px rgba(7, 29, 51, 0.04);
  }

  .sbc-feature-tiles--plus .sbc-feature-tile {
    background: linear-gradient(180deg, #fffdfb, #fff8f2);
    border-color: rgba(255, 166, 101, 0.42);
    box-shadow: 0 10px 20px rgba(255, 166, 101, 0.12);
  }

  .sbc-feature-tiles--plus .sbc-feature-icon {
    background: rgba(255, 166, 101, 0.2);
  }

  .sbc-branding-helper {
    background: rgba(56, 72, 98, 0.06);
    border: 1px solid rgba(56, 72, 98, 0.11);
    border-radius: 10px;
    color: rgba(56, 72, 98, 0.8);
    font-size: 0.76rem;
    line-height: 1.35;
    margin: 0;
    padding: 0.46rem 0.58rem;
    text-align: center;
  }

  .sbc-price-card .sbc-btn {
    margin-top: 0.2rem;
    width: 100%;
  }

  .sbc-cta-helper {
    color: rgba(56, 72, 98, 0.75);
    margin-top: 0.2rem;
    padding-bottom: 0.5rem;
    text-align: center;
  }

  .sbc-plus-title-accent {
    color: var(--sbc-orange);
    font-weight: 900;
  }

  .sbc-social-grid {
    margin-top: 0.25rem;
  }

  .sbc-social-card {
    background: linear-gradient(180deg, #ffffff, #fcfdff);
    border-color: rgba(56, 72, 98, 0.14);
    display: grid;
    gap: 0.3rem;
    justify-items: center;
    min-height: 0;
    padding: 0.62rem 0.45rem;
  }

  .sbc-social-card h3 {
    font-size: 0.9rem;
    line-height: 1.1;
    margin: 0;
  }

  .sbc-social-icon {
    align-items: center;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow: 0 10px 20px rgba(7, 29, 51, 0.14);
    display: inline-flex;
    height: 48px;
    justify-content: center;
    width: 48px;
  }

  .sbc-social-icon svg {
    height: 28px;
    width: 28px;
  }

  .sbc-social-icon--instagram {
    background: linear-gradient(135deg, rgba(131, 58, 180, 0.16), rgba(253, 29, 29, 0.18), rgba(252, 176, 69, 0.22));
    color: #c13584;
  }

  .sbc-social-icon--facebook {
    background: rgba(24, 119, 242, 0.14);
    color: #1877f2;
  }

  .sbc-social-icon--linkedin {
    background: rgba(10, 102, 194, 0.14);
    color: #0a66c2;
  }

  .sbc-social-icon--tiktok {
    background: rgba(0, 0, 0, 0.08);
    color: #111111;
  }

  .sbc-social-icon--youtube {
    background: rgba(255, 0, 0, 0.12);
    color: #ff0000;
  }

  .sbc-social-icon--x {
    background: rgba(17, 17, 17, 0.1);
    color: #111111;
  }

  .sbc-compare__label {
    background: rgba(56, 72, 98, 0.1);
    border: 1px solid rgba(56, 72, 98, 0.2);
    border-radius: 999px;
    color: rgba(56, 72, 98, 0.82);
    display: inline-flex;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0;
    padding: 0.32rem 0.62rem;
    text-transform: uppercase;
  }

  .sbc-compare__label--featured {
    background: rgba(255, 166, 101, 0.2);
    border-color: rgba(255, 166, 101, 0.5);
    color: #8d4f26;
  }

  .sbc-compare__col {
    display: grid;
    gap: 0.62rem;
    justify-items: center;
    padding: 1.1rem;
  }

  .sbc-compare__col h3 {
    font-size: clamp(2rem, 4.2vw, 2.75rem);
    line-height: 0.98;
    margin: 0;
  }

  .sbc-compare ul {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    margin: 0.35rem 0 0;
    padding: 0;
    width: 100%;
  }

  .sbc-compare li {
    align-items: center;
    background: #f8fafc;
    border: 1px solid rgba(56, 72, 98, 0.12);
    border-radius: 12px;
    display: flex;
    gap: 0.62rem;
    justify-content: flex-start;
    line-height: 1.3;
    min-height: 48px;
    padding: 0.48rem 0.62rem;
    text-align: left;
  }

  .sbc-compare li::before {
    align-items: center;
    background: rgba(56, 72, 98, 0.1);
    border-radius: 999px;
    color: var(--sbc-orange);
    content: '+';
    display: inline-flex;
    font-weight: 900;
    height: 24px;
    justify-content: center;
    width: 24px;
  }

  .sbc-compare li span {
    color: rgba(56, 72, 98, 0.9);
    font-size: 1.03rem;
    font-weight: 700;
  }

  .sbc-billing-note {
    color: rgba(56, 72, 98, 0.82);
    font-size: 0.88rem;
    margin-top: 0.9rem;
    text-align: center;
  }

  .sbc-compare {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 1fr;
  }

  .sbc-highlights {
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 255, 0.94));
    border: 1px solid rgba(255, 166, 101, 0.3);
    border-radius: 20px;
    box-shadow: 0 18px 38px rgba(7, 29, 51, 0.1);
    display: grid;
    gap: 0.7rem;
    justify-items: center;
    margin: 0 auto;
    max-width: 860px;
    padding: clamp(1rem, 2.4vw, 1.45rem);
  }

  .sbc-highlight {
    align-items: center;
    background: linear-gradient(180deg, #ffffff, #fffaf5);
    border: 1px solid rgba(255, 166, 101, 0.34);
    border-radius: 14px;
    box-shadow: 0 10px 24px rgba(255, 166, 101, 0.14);
    display: grid;
    gap: 0.52rem;
    grid-template-columns: 1fr;
    justify-items: center;
    margin: 0;
    min-height: 88px;
    padding: 0.72rem 0.85rem;
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }

  .sbc-highlight:hover {
    box-shadow: 0 14px 28px rgba(255, 166, 101, 0.2);
    transform: translateY(-1px);
  }

  .sbc-highlight span:last-child {
    color: rgba(56, 72, 98, 0.92);
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.25;
    text-align: center;
  }

  .sbc-highlight__icon {
    align-items: center;
    background: radial-gradient(circle at 30% 25%, rgba(255, 199, 150, 0.82), rgba(255, 166, 101, 0.4));
    border: 1px solid rgba(255, 166, 101, 0.52);
    border-radius: 10px;
    color: var(--sbc-navy);
    display: inline-flex;
    height: 38px;
    justify-content: center;
    width: 38px;
  }

  .sbc-highlight__icon svg {
    height: 21px;
    width: 21px;
  }

  .sbc-compare__col--featured {
    background: linear-gradient(160deg, #fff8f1, #ffffff 45%, #fffdfb);
    border-color: rgba(255, 166, 101, 0.46);
    box-shadow: 0 16px 32px rgba(255, 166, 101, 0.16);
  }

  .sbc-compare__col--featured li {
    background: linear-gradient(180deg, #fffdfb, #fff8f2);
    border-color: rgba(255, 166, 101, 0.36);
  }

  .sbc-compare__col--featured li::before {
    background: rgba(255, 166, 101, 0.19);
    color: #e98231;
  }

  .sbc-checklist {
    background: var(--sbc-white);
    border: 1px solid var(--sbc-border);
    border-radius: 16px;
    box-shadow: 0 12px 28px rgba(7, 29, 51, 0.06);
    display: grid;
    gap: 0.55rem;
    padding: 1rem;
  }

  .sbc-checklist p {
    align-items: start;
    color: rgba(56, 72, 98, 0.9);
    display: grid;
    gap: 0.5rem;
    grid-template-columns: 16px 1fr;
    margin: 0;
    text-align: center;
    justify-content: center;
  }

  .sbc-checklist p::before {
    color: var(--sbc-orange);
    content: '✓';
    font-weight: 900;
  }

  .sbc-faq {
    display: grid;
    gap: 0.6rem;
  }

  .sbc-faq details {
    background: var(--sbc-white);
    border: 1px solid var(--sbc-border);
    border-radius: 12px;
    box-shadow: 0 10px 22px rgba(7, 29, 51, 0.05);
    padding: 0.85rem;
    text-align: center;
  }

  .sbc-faq summary {
    cursor: pointer;
    font-weight: 800;
    list-style: none;
  }

  .sbc-faq summary::-webkit-details-marker {
    display: none;
  }

  .sbc-faq p {
    margin-top: 0.55rem;
    text-align: center;
  }

  .sbc-final {
    background: var(--sbc-white);
    border: 1px solid var(--sbc-border);
    border-radius: 20px;
    box-shadow: 0 14px 32px rgba(7, 29, 51, 0.06);
    display: grid;
    gap: 0.7rem;
    justify-items: start;
    min-width: 0;
    padding: clamp(1rem, 2.2vw, 1.6rem);
  }

  .sbc-final h2 {
    font-size: clamp(1.5rem, 4.6vw, 2.25rem);
  }

  .sbc-reveal {
    opacity: 0;
    transform: translate3d(0, 20px, 0);
    transition: opacity 0.62s ease-out, transform 0.62s ease-out;
    will-change: opacity, transform;
  }

  .sbc-reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .sbc-reveal-delay-1 { transition-delay: 0.08s; }
  .sbc-reveal-delay-2 { transition-delay: 0.16s; }
  .sbc-reveal-delay-3 { transition-delay: 0.24s; }

  @media screen and (min-width: 750px) {
    .sbc-grid--3 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sbc-grid--2,
    .sbc-compare {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sbc-feature-tiles {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sbc-highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .sbc-hero {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }

    .sbc-grid--4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .sbc-grid--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .sbc-plus-card {
      width: 250px;
    }
  }

  @keyframes sbcPlusScroll {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(-50%, 0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .sbc-reveal,
    .sbc-reveal.is-visible {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }

    .sbc-plus-track {
      animation: none !important;
      transform: none !important;
      width: auto;
    }

    .sbc-plus-card.is-duplicate {
      display: none;
    }
  }

  @media screen and (max-width: 989px) {
    .sbc-actions {
      width: 100%;
    }

    .sbc-actions .sbc-btn {
      flex: 1 1 auto;
      min-width: 0;
    }

    .sbc-billing-toggle {
      margin-left: auto;
      margin-right: auto;
      max-width: 100%;
    }

    .sbc-billing-toggle button {
      font-size: 0.7rem;
      line-height: 1.1;
      min-height: 40px;
      padding: 0.5rem 0.38rem;
    }

    .sbc-pricing-grid {
      gap: 0.65rem;
    }

    .sbc-price-card {
      gap: 0.44rem;
    }

    .sbc-hero__copy {
      border-radius: 22px;
      padding: 1.45rem 0.95rem 1.1rem;
    }

    .sbc-hero-checklist {
      gap: 0.3rem;
      width: 95%;
    }

    .sbc-hero-checklist li {
      font-size: 0.82rem;
      line-height: 1.25;
    }

    .sbc-inclusion-line {
      font-size: 0.72rem;
      max-width: 92%;
    }

    .sbc-note {
      width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .sbc-social-grid {
      gap: 0.5rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealItems = document.querySelectorAll('.sbc-reveal');

    if (reducedMotion) {
      revealItems.forEach((el) => el.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2, rootMargin: '0px 0px -8% 0px' }
      );

      revealItems.forEach((el) => observer.observe(el));
    }

    const billingToggle = document.querySelector('[data-sbc-billing-toggle]');
    const monthlyTargets = document.querySelectorAll('[data-billing-monthly]');
    const annualTargets = document.querySelectorAll('[data-billing-annual]');
    const basePlanCards = document.querySelectorAll('[data-billing-base-card]');
    const plusPlanCards = document.querySelectorAll('[data-billing-plus-card]');

    if (!billingToggle || !monthlyTargets.length || !annualTargets.length) {
      return;
    }

    const toggleButtons = billingToggle.querySelectorAll('button[data-billing]');

    const setElementHidden = (el, hidden) => {
      el.hidden = hidden;

      if (hidden) {
        el.style.setProperty('display', 'none', 'important');
        return;
      }

      el.style.removeProperty('display');
    };

    const setBilling = (interval) => {
      const isFree = interval === 'free';
      const isAnnual = interval === 'annual';

      toggleButtons.forEach((button) => {
        const active = button.getAttribute('data-billing') === interval;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-selected', active ? 'true' : 'false');
        button.setAttribute('aria-pressed', active ? 'true' : 'false');

        // Explicit inline state styling keeps only one toggle visually active across theme style overrides.
        button.style.setProperty('background', active ? '#ffa665' : 'rgba(255, 255, 255, 0.9)', 'important');
        button.style.setProperty('color', active ? '#384862' : 'rgba(56, 72, 98, 0.74)', 'important');
        button.style.setProperty('box-shadow', active ? '0 10px 20px rgba(255, 166, 101, 0.3)' : 'none', 'important');
        button.style.setProperty('border-color', active ? 'rgba(255, 166, 101, 0.95)' : 'rgba(56, 72, 98, 0.08)', 'important');
      });

      monthlyTargets.forEach((el) => {
        setElementHidden(el, isAnnual);
      });

      annualTargets.forEach((el) => {
        setElementHidden(el, !isAnnual);
      });

      basePlanCards.forEach((el) => {
        setElementHidden(el, !isFree);
      });

      plusPlanCards.forEach((el) => {
        setElementHidden(el, isFree);
      });
    };

    setBilling('monthly');

    toggleButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const interval = button.getAttribute('data-billing');
        if (!interval) {
          return;
        }
        setBilling(interval);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Clutch Smart Card Page",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Clutch Smart Card Page"
    }
  ]
}
{% endschema %}
