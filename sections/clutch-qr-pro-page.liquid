{% liquid
  assign starter_url = section.settings.starter_url | default: 'https://qr.clutchprintshop.com/login?plan=clutch_codes_starter'
  assign growth_url = section.settings.growth_url | default: 'https://qr.clutchprintshop.com/login?plan=clutch_codes_growth'
  assign pro_url = section.settings.pro_url | default: 'https://qr.clutchprintshop.com/login?plan=clutch_codes_pro'
  assign portal_url = section.settings.portal_url | default: 'https://qr.clutchprintshop.com/login'
  assign shop_url = section.settings.shop_url | default: '/collections/all'
%}

<main class="clutch-codes color-{{ section.settings.color_scheme }}" data-clutch-codes>
  <section class="clutch-codes__hero">
    <div class="clutch-codes__shell clutch-codes__hero-grid">
      <div class="clutch-codes__hero-copy" data-reveal>
        <p class="clutch-codes__eyebrow">CLUTCH CODES™</p>
        <h1>Make Every Print Piece Trackable.</h1>
        <p class="clutch-codes__lead">Clutch Codes are dynamic QR codes built for physical marketing. Update destinations after printing, track scan activity, and compare which campaigns generate engagement.</p>
        <div class="clutch-codes__actions">
          <a class="button clutch-codes__button" href="#plans">Explore Plans</a>
          <a class="button-secondary clutch-codes__button" href="{{ shop_url }}">Shop Trackable Print</a>
        </div>
        <p class="clutch-codes__micro">Every eligible Clutch print campaign includes one Clutch Code.</p>
      </div>

      <div class="clutch-codes__dashboard" aria-label="Example Clutch Code analytics dashboard" data-reveal>
        <div class="clutch-codes__dashboard-top">
          <div><span class="clutch-codes__dashboard-label">Example campaign data</span><strong>Summer Flyer Campaign</strong></div>
          <span class="clutch-codes__status"><i aria-hidden="true"></i> Campaign active</span>
        </div>
        <div class="clutch-codes__metrics">
          <div><span>Total scans</span><strong>1,284</strong><small>+18% this month</small></div>
          <div><span>Unique scan estimate</span><strong>917</strong><small>71% of total</small></div>
          <div><span>Top scan time</span><strong>6–8 PM</strong><small>Weekday evenings</small></div>
        </div>
        <div class="clutch-codes__chart-card">
          <div class="clutch-codes__chart-head"><span>Scan activity</span><small>Last 7 days</small></div>
          <div class="clutch-codes__bars" aria-label="Example seven-day scan activity chart">
            <span style="--bar:44%"><i>Mon</i></span><span style="--bar:58%"><i>Tue</i></span><span style="--bar:50%"><i>Wed</i></span><span style="--bar:76%"><i>Thu</i></span><span style="--bar:92%"><i>Fri</i></span><span style="--bar:67%"><i>Sat</i></span><span style="--bar:54%"><i>Sun</i></span>
          </div>
        </div>
        <div class="clutch-codes__dashboard-bottom">
          <div><span>Top campaign</span><strong>Summer Flyers</strong></div>
          <div><span>Top device</span><strong>Mobile</strong></div>
          <div><span>Top area</span><strong>Cincinnati</strong></div>
        </div>
      </div>
    </div>
  </section>

  <section class="clutch-codes__value-strip" aria-label="Clutch Codes benefits">
    <div class="clutch-codes__shell clutch-codes__value-grid">
      <div data-reveal><span aria-hidden="true">↗</span><strong>Editable After Printing</strong></div>
      <div data-reveal><span aria-hidden="true">◎</span><strong>Track Every Campaign</strong></div>
      <div data-reveal><span aria-hidden="true">⇄</span><strong>Compare What Performs</strong></div>
      <div data-reveal><span aria-hidden="true">↓</span><strong>Print-Ready QR Files</strong></div>
    </div>
  </section>

  <section class="clutch-codes__section">
    <div class="clutch-codes__shell">
      <div class="clutch-codes__section-heading" data-reveal>
        <p class="clutch-codes__eyebrow">INCLUDED WITH CLUTCH PRINT</p>
        <h2>Your Print Order Comes With a Tracking Layer.</h2>
        <p>Every eligible marketing-material order includes one Clutch Code for that print campaign. The same code appears across the full quantity, giving the campaign one measurable destination.</p>
      </div>
      <div class="clutch-codes__included-grid">
        <article class="clutch-codes__card clutch-codes__card--navy" data-reveal><span class="clutch-codes__badge">Included</span><h3>One Campaign. One Clutch Code.</h3><p>Order flyers, business cards, signs, brochures, door hangers, postcards, or other eligible marketing materials and receive a dynamic code connected to that campaign.</p></article>
        <article class="clutch-codes__card" data-reveal><h3>Change the Destination</h3><p>Update where the code sends customers without replacing the printed code.</p></article>
        <article class="clutch-codes__card" data-reveal><h3>See Scan Activity</h3><p>View campaign engagement instead of relying only on how many pieces were printed.</p></article>
        <article class="clutch-codes__card" data-reveal><h3>Upgrade When Needed</h3><p>Add more active Clutch Codes and expanded campaign management starting at $3.99 per month.</p></article>
      </div>
    </div>
  </section>

  <section class="clutch-codes__section clutch-codes__section--soft">
    <div class="clutch-codes__shell clutch-codes__split">
      <div data-reveal>
        <p class="clutch-codes__eyebrow">WHAT “DYNAMIC” MEANS</p>
        <h2>Change the Link. Keep the Code.</h2>
        <p>A static QR code permanently contains its destination. A Clutch Code uses a managed redirect, so the destination can change while the code printed on your materials stays the same.</p>
        <div class="clutch-codes__callout">No reprint required when the destination changes.</div>
      </div>
      <div class="clutch-codes__comparison" data-reveal>
        <article><span>Static QR code</span><ul><li>Destination is fixed</li><li>Changes may require reprinting</li><li>Limited campaign visibility</li><li>Harder to compare print pieces</li></ul></article>
        <article class="clutch-codes__comparison-featured"><span>Clutch Code</span><ul><li>Update the destination anytime</li><li>Keep using the printed code</li><li>Track scan engagement</li><li>Compare campaign performance</li></ul></article>
      </div>
    </div>
  </section>

  <section class="clutch-codes__section">
    <div class="clutch-codes__shell">
      <div class="clutch-codes__section-heading" data-reveal>
        <p class="clutch-codes__eyebrow">BUILT FOR PHYSICAL MARKETING</p>
        <h2>Know Which Marketing Piece Gets Attention.</h2>
        <p>Give each campaign its own Clutch Code so you can compare how customers engage with different printed materials.</p>
      </div>
      <div class="clutch-codes__use-grid">
        <article data-reveal><span>BC</span><h3>Business Cards</h3><p>Track networking and contact engagement.</p></article>
        <article data-reveal><span>FL</span><h3>Flyers</h3><p>Compare promotions, locations, or distribution areas.</p></article>
        <article data-reveal><span>YS</span><h3>Yard Signs</h3><p>Measure interest by campaign or placement.</p></article>
        <article data-reveal><span>DH</span><h3>Door Hangers</h3><p>Track neighborhoods and service promotions.</p></article>
        <article data-reveal><span>BR</span><h3>Brochures</h3><p>Connect detailed print pieces to digital next steps.</p></article>
        <article data-reveal><span>DM</span><h3>Direct Mail</h3><p>Measure response from specific mail campaigns.</p></article>
        <article data-reveal><span>BN</span><h3>Banners</h3><p>Track event, storefront, or promotional visibility.</p></article>
        <article data-reveal><span>PC</span><h3>Postcards</h3><p>Compare offers, routes, or campaign drops.</p></article>
      </div>
    </div>
  </section>

  <section class="clutch-codes__section clutch-codes__section--navy">
    <div class="clutch-codes__shell">
      <div class="clutch-codes__section-heading" data-reveal>
        <p class="clutch-codes__eyebrow">CLUTCH CODE ANALYTICS</p>
        <h2>See When, Where, and How Customers Engage.</h2>
        <p>Turn scan activity into understandable campaign signals without claiming that every scan became a sale.</p>
      </div>
      <div class="clutch-codes__feature-grid">
        <article data-reveal><span>01</span><h3>Total & Unique Scan Estimates</h3><p>Measure overall activity and estimate separate visitor engagement.</p></article>
        <article data-reveal><span>02</span><h3>Campaign Comparison</h3><p>Compare cards, flyers, signs, mailers, and other campaigns from one dashboard.</p></article>
        <article data-reveal><span>03</span><h3>Scan Trends</h3><p>View activity by day, hour, and weekday to understand engagement timing.</p></article>
        <article data-reveal><span>04</span><h3>Approximate Locations</h3><p>See activity by city, region, and country where network-derived data is available.</p></article>
        <article data-reveal><span>05</span><h3>Device Insights</h3><p>See mobile, tablet, desktop, browser, and operating-system breakdowns.</p></article>
        <article data-reveal><span>06</span><h3>Campaign Filters</h3><p>Filter by code, date range, device, location, referrer, and print-piece type.</p></article>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="clutch-codes__section">
    <div class="clutch-codes__shell">
      <div class="clutch-codes__section-heading" data-reveal><p class="clutch-codes__eyebrow">HOW IT WORKS</p><h2>From Print Order to Measurable Campaign.</h2></div>
      <div class="clutch-codes__steps">
        <article data-reveal><span>1</span><h3>Create the Campaign</h3><p>Choose the destination, print type, campaign name, and code appearance.</p></article>
        <article data-reveal><span>2</span><h3>Add It to the Print</h3><p>Place the Clutch Code on your business card, flyer, sign, brochure, mailer, or other material.</p></article>
        <article data-reveal><span>3</span><h3>Track Engagement</h3><p>View scan activity, compare campaigns, and update the destination without replacing the code.</p></article>
      </div>
    </div>
  </section>

  <section class="clutch-codes__section clutch-codes__section--soft">
    <div class="clutch-codes__shell">
      <div class="clutch-codes__section-heading" data-reveal><p class="clutch-codes__eyebrow">CAMPAIGN COMPARISON</p><h2>Stop Guessing Which Print Piece Worked.</h2><p>Use separate Clutch Codes to compare campaign engagement side by side.</p></div>
      <div class="clutch-codes__table-wrap" data-reveal>
        <div class="clutch-codes__table-label">Example campaign comparison</div>
        <div class="clutch-codes__campaign-table" role="table" aria-label="Example campaign comparison">
          <div class="clutch-codes__campaign-row clutch-codes__campaign-row--head" role="row"><span>Campaign</span><span>Total scans</span><span>Unique estimate</span><span>Top device</span><span>Top area</span></div>
          <div class="clutch-codes__campaign-row" role="row"><strong>Summer Flyers</strong><span data-label="Total scans">184</span><span data-label="Unique estimate">141</span><span data-label="Top device">Mobile</span><span data-label="Top area">Cincinnati</span></div>
          <div class="clutch-codes__campaign-row" role="row"><strong>Yard Signs</strong><span data-label="Total scans">96</span><span data-label="Unique estimate">72</span><span data-label="Top device">Mobile</span><span data-label="Top area">Milford</span></div>
          <div class="clutch-codes__campaign-row" role="row"><strong>Business Cards</strong><span data-label="Total scans">58</span><span data-label="Unique estimate">44</span><span data-label="Top device">Mobile</span><span data-label="Top area">Loveland</span></div>
        </div>
        <p class="clutch-codes__table-note">In this example, flyers generated the most scan engagement. Scan activity does not automatically equal sales or conversions.</p>
      </div>
    </div>
  </section>

  <section id="plans" class="clutch-codes__section">
    <div class="clutch-codes__shell">
      <div class="clutch-codes__section-heading" data-reveal>
        <p class="clutch-codes__eyebrow">SIMPLE MONTHLY PLANS</p>
        <h2>Start Included. Upgrade as Your Campaigns Grow.</h2>
        <p>Paid plans increase the number of active dynamic Clutch Codes you can manage. Cancel anytime.</p>
      </div>
      <div class="clutch-codes__pricing">
        <article class="clutch-codes__price-card" data-reveal>
          <div><span class="clutch-codes__plan-label">WITH ELIGIBLE PRINT</span><h3>Included</h3><p class="clutch-codes__price">$0 <small>with order</small></p><p>For tracking the campaign you purchase from Clutch.</p></div>
          <ul><li>1 Clutch Code per eligible print campaign</li><li>Dynamic destination</li><li>Basic scan activity</li><li>Code remains usable on the printed material</li></ul>
          <a class="button-secondary clutch-codes__button" href="{{ shop_url }}">Shop Print Products</a>
        </article>
        <article class="clutch-codes__price-card" data-reveal>
          <div><span class="clutch-codes__plan-label">STARTER</span><h3>10 Clutch Codes</h3><p class="clutch-codes__price">$3.99 <small>/month</small></p><p>For individuals and small businesses running a few campaigns.</p></div>
          <ul><li>10 active dynamic Clutch Codes</li><li>Editable destinations</li><li>Scan analytics</li><li>QR styling and print-ready exports</li></ul>
          <a class="button-secondary clutch-codes__button" href="{{ starter_url }}">Choose Starter</a>
        </article>
        <article class="clutch-codes__price-card clutch-codes__price-card--featured" data-reveal>
          <span class="clutch-codes__popular">MOST POPULAR</span>
          <div><span class="clutch-codes__plan-label">GROWTH</span><h3>30 Clutch Codes</h3><p class="clutch-codes__price">$6.99 <small>/month</small></p><p>For businesses managing multiple print campaigns.</p></div>
          <ul><li>30 active dynamic Clutch Codes</li><li>Editable destinations</li><li>Campaign comparison</li><li>Device and approximate location insights</li><li>QR styling, exports, and CSV reporting</li></ul>
          <a class="button clutch-codes__button" href="{{ growth_url }}">Choose Growth</a>
        </article>
        <article class="clutch-codes__price-card" data-reveal>
          <div><span class="clutch-codes__plan-label">PRO</span><h3>100 Clutch Codes</h3><p class="clutch-codes__price">$11.99 <small>/month</small></p><p>For frequent campaigns, teams, and larger print programs.</p></div>
          <ul><li>100 active dynamic Clutch Codes</li><li>Everything in Growth</li><li>Advanced time and geographic analytics</li><li>Best-performing campaign insights</li><li>Expanded campaign management</li></ul>
          <a class="button-secondary clutch-codes__button" href="{{ pro_url }}">Choose Pro</a>
        </article>
      </div>
      <p class="clutch-codes__pricing-note" data-reveal>Plan checkout and account access are handled through the Clutch portal. Location data is approximate, and unique scans are estimates.</p>
    </div>
  </section>

  <section class="clutch-codes__section clutch-codes__section--soft">
    <div class="clutch-codes__shell clutch-codes__faq-shell">
      <div class="clutch-codes__section-heading" data-reveal><p class="clutch-codes__eyebrow">QUESTIONS</p><h2>Clutch Codes FAQ</h2></div>
      <div class="clutch-codes__faq">
        <details data-reveal><summary>What is a Clutch Code?</summary><p>A Clutch Code is a dynamic QR code connected to an editable destination and campaign analytics.</p></details>
        <details data-reveal><summary>Does every printed piece receive a different code?</summary><p>No. One campaign code normally appears across the full quantity of that printed campaign. For example, 500 flyers can share one Clutch Code.</p></details>
        <details data-reveal><summary>Can I change the destination after printing?</summary><p>Yes. Update the campaign destination without replacing the code already printed on your materials.</p></details>
        <details data-reveal><summary>What can Clutch Codes track?</summary><p>Available data can include total scans, estimated unique activity, scan times, devices, browsers, referrers, approximate locations, and campaign comparisons.</p></details>
        <details data-reveal><summary>Does Clutch track exact customer locations?</summary><p>No. Geographic information is approximate and based on network-derived data. Clutch Codes do not provide exact GPS tracking.</p></details>
        <details data-reveal><summary>Do customers need an app?</summary><p>No. Most modern smartphones can scan the code using the standard camera application.</p></details>
        <details data-reveal><summary>Are scans the same as sales?</summary><p>No. A scan measures engagement with the campaign. It does not automatically prove a purchase or conversion.</p></details>
        <details data-reveal><summary>Can I use Clutch Codes on materials printed elsewhere?</summary><p>Paid-plan customers can download supported QR files for their own designs and eligible external marketing use.</p></details>
      </div>
    </div>
  </section>

  <section class="clutch-codes__final">
    <div class="clutch-codes__shell clutch-codes__final-inner" data-reveal>
      <p class="clutch-codes__eyebrow">PRINT SMARTER. TRACK MORE.</p>
      <h2>Make Your Next Print Campaign Measurable.</h2>
      <p>Create dynamic Clutch Codes, update destinations, and see which printed materials generate engagement.</p>
      <div class="clutch-codes__actions"><a class="button clutch-codes__button" href="#plans">Explore Plans</a><a class="button-secondary clutch-codes__button" href="{{ portal_url }}">Open Clutch Portal</a></div>
    </div>
  </section>
</main>

{% stylesheet %}
  .clutch-codes{--navy:#384862;--orange:#ffa665;--ink:#202833;--soft:#f7f5f1;--line:rgba(56,72,98,.14);--shadow:0 18px 50px rgba(56,72,98,.09);background:#fff;color:var(--navy);font-family:'Montserrat',sans-serif;overflow-x:clip}
  .clutch-codes *,.clutch-codes *:before,.clutch-codes *:after{box-sizing:border-box}.clutch-codes__shell{margin-inline:auto;max-width:1180px;width:min(100% - 2rem,1180px)}
  .clutch-codes h1,.clutch-codes h2,.clutch-codes h3{color:var(--navy);font-family:'Exo 2',sans-serif;letter-spacing:-.025em;margin-top:0;text-wrap:balance}.clutch-codes p{line-height:1.65}
  .clutch-codes__hero{background:radial-gradient(circle at 85% 20%,rgba(255,166,101,.22),transparent 32%),linear-gradient(135deg,#2e3d55 0%,var(--navy) 55%,#465a78 100%);color:#fff;padding:clamp(4rem,8vw,7rem) 0}.clutch-codes__hero-grid{align-items:center;display:grid;gap:clamp(2.25rem,6vw,5rem);min-width:0}.clutch-codes__hero-copy,.clutch-codes__dashboard{min-width:0}
  .clutch-codes__eyebrow,.clutch-codes__plan-label,.clutch-codes__dashboard-label{color:var(--orange);font-size:.76rem;font-weight:900;letter-spacing:.11em;margin:0;text-transform:uppercase}.clutch-codes__hero h1{color:#fff;font-size:clamp(2.65rem,8vw,5.7rem);line-height:.95;margin:.8rem 0 1.25rem}.clutch-codes__lead{color:rgba(255,255,255,.86);font-size:clamp(1.03rem,2vw,1.22rem);margin:0;max-width:680px}
  .clutch-codes__actions{display:grid;gap:.8rem;margin-top:1.8rem;max-width:520px}.clutch-codes__button{align-items:center;border-radius:999px;display:inline-flex;justify-content:center;min-height:50px;padding-inline:1.4rem;text-align:center;text-decoration:none;width:100%}.clutch-codes .button{background:var(--orange)!important;color:var(--navy)!important}.clutch-codes .button-secondary{background:transparent!important;border:1px solid currentColor!important;color:inherit!important}.clutch-codes__micro{color:rgba(255,255,255,.72);font-size:.88rem;margin:1rem 0 0}
  .clutch-codes__dashboard{background:#fff;border:1px solid rgba(255,255,255,.55);border-radius:26px;box-shadow:0 30px 80px rgba(9,18,32,.28);color:var(--navy);padding:clamp(1rem,3vw,1.4rem)}.clutch-codes__dashboard-top,.clutch-codes__chart-head{align-items:center;display:flex;gap:1rem;justify-content:space-between}.clutch-codes__dashboard-top strong{display:block;font-family:'Exo 2',sans-serif;font-size:1.12rem;margin-top:.25rem}.clutch-codes__status{align-items:center;background:#edf8f0;border-radius:999px;color:#29623a;display:inline-flex;font-size:.72rem;font-weight:800;gap:.4rem;padding:.45rem .65rem;white-space:nowrap}.clutch-codes__status i{background:#46a363;border-radius:50%;height:.5rem;width:.5rem}
  .clutch-codes__metrics,.clutch-codes__dashboard-bottom{display:grid;gap:.65rem;grid-template-columns:repeat(3,minmax(0,1fr));margin:1rem 0}.clutch-codes__metrics div,.clutch-codes__dashboard-bottom div{background:var(--soft);border:1px solid var(--line);border-radius:15px;min-width:0;padding:.8rem}.clutch-codes__metrics span,.clutch-codes__dashboard-bottom span{color:rgba(56,72,98,.68);display:block;font-size:.68rem;line-height:1.3}.clutch-codes__metrics strong{display:block;font-family:'Exo 2',sans-serif;font-size:clamp(1rem,3vw,1.45rem);margin:.25rem 0}.clutch-codes__metrics small{color:rgba(56,72,98,.7);font-size:.62rem}.clutch-codes__dashboard-bottom{margin:1.85rem 0 0}.clutch-codes__dashboard-bottom strong{display:block;font-size:.78rem;margin-top:.25rem}
  .clutch-codes__chart-card{border:1px solid var(--line);border-radius:17px;padding:.9rem}.clutch-codes__chart-head{font-size:.8rem;font-weight:800}.clutch-codes__chart-head small{color:rgba(56,72,98,.62)}.clutch-codes__bars{align-items:end;display:grid;gap:.45rem;grid-template-columns:repeat(7,minmax(0,1fr));height:125px;margin-top:.75rem}.clutch-codes__bars span{background:linear-gradient(180deg,var(--orange),rgba(255,166,101,.38));border-radius:6px 6px 2px 2px;height:var(--bar);min-height:18px;position:relative}.clutch-codes__bars i{bottom:-1.25rem;color:rgba(56,72,98,.6);font-size:.58rem;font-style:normal;left:50%;position:absolute;transform:translateX(-50%)}
  .clutch-codes__value-strip{background:#fff;border-bottom:1px solid var(--line);padding:1.35rem 0}.clutch-codes__value-grid{display:grid;gap:.7rem}.clutch-codes__value-grid div{align-items:center;background:var(--soft);border:1px solid var(--line);border-radius:999px;display:flex;gap:.65rem;justify-content:center;min-height:48px;padding:.65rem .9rem;text-align:center}.clutch-codes__value-grid span{color:var(--orange);font-size:1.1rem;font-weight:900}.clutch-codes__value-grid strong{font-size:.82rem}
  .clutch-codes__section,.clutch-codes__final{padding:clamp(3.5rem,8vw,6.5rem) 0}.clutch-codes__section--soft{background:var(--soft)}.clutch-codes__section--navy,.clutch-codes__final{background:var(--navy);color:#fff}.clutch-codes__section-heading{margin:0 auto clamp(2rem,5vw,3.25rem);max-width:820px;text-align:center}.clutch-codes__section-heading h2,.clutch-codes__split h2,.clutch-codes__final h2{font-size:clamp(2rem,5vw,3.7rem);line-height:1.02;margin:.65rem 0 1rem}.clutch-codes__section-heading p:last-child,.clutch-codes__split>div>p,.clutch-codes__final p{color:rgba(32,40,51,.72);font-size:clamp(1rem,2vw,1.12rem);margin:0}.clutch-codes__section--navy h2,.clutch-codes__section--navy h3,.clutch-codes__final h2{color:#fff}.clutch-codes__section--navy .clutch-codes__section-heading p:last-child,.clutch-codes__final p{color:rgba(255,255,255,.76)}
  .clutch-codes__included-grid,.clutch-codes__use-grid,.clutch-codes__feature-grid,.clutch-codes__steps,.clutch-codes__pricing{display:grid;gap:1rem}.clutch-codes__card,.clutch-codes__use-grid article,.clutch-codes__feature-grid article,.clutch-codes__steps article,.clutch-codes__price-card,.clutch-codes__faq details{background:#fff;border:1px solid var(--line);border-radius:22px;box-shadow:var(--shadow)}.clutch-codes__card,.clutch-codes__use-grid article,.clutch-codes__feature-grid article,.clutch-codes__steps article,.clutch-codes__price-card{padding:clamp(1.25rem,3vw,1.75rem)}.clutch-codes__card--navy{background:var(--navy);color:#fff}.clutch-codes__card--navy h3{color:#fff}.clutch-codes__badge,.clutch-codes__popular{background:var(--orange);border-radius:999px;color:var(--navy);display:inline-block;font-size:.7rem;font-weight:900;letter-spacing:.08em;padding:.45rem .7rem;text-transform:uppercase}.clutch-codes__card h3,.clutch-codes__use-grid h3,.clutch-codes__feature-grid h3,.clutch-codes__steps h3,.clutch-codes__price-card h3{font-size:1.35rem;line-height:1.1;margin:.8rem 0 .55rem}.clutch-codes__card p,.clutch-codes__use-grid p,.clutch-codes__feature-grid p,.clutch-codes__steps p,.clutch-codes__price-card p{color:rgba(32,40,51,.72);margin:0}.clutch-codes__card--navy p{color:rgba(255,255,255,.76)}
