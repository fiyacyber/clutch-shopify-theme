{% liquid
  assign starter_url = section.settings.starter_checkout_url | strip
  assign growth_url = section.settings.growth_checkout_url | strip
  assign pro_url = section.settings.pro_checkout_url | strip
  assign app_login_url = section.settings.app_login_url | strip
  assign shop_print_url = section.settings.shop_print_url | strip
  assign clutch_connect_url = section.settings.clutch_connect_url | strip

  if starter_url == blank
    assign starter_url = 'https://clutchprintshop.com/products/clutch-codes-starter'
  endif

  if growth_url == blank
    assign growth_url = 'https://clutchprintshop.com/products/clutch-codes-growth'
  endif

  if pro_url == blank
    assign pro_url = 'https://clutchprintshop.com/products/clutch-codes-pro'
  endif

  if app_login_url == blank
    assign app_login_url = 'https://qr.clutchprintshop.com/login'
  endif

  if shop_print_url == blank
    assign shop_print_url = 'https://clutchprintshop.com/collections/all'
  endif

  if clutch_connect_url == blank
    assign clutch_connect_url = section.settings.connect_url | strip
  endif

  if clutch_connect_url == blank
    assign clutch_connect_url = 'https://clutchprintshop.com/pages/connect'
  endif
%}

<main class="cc-page color-{{ section.settings.color_scheme }}" aria-labelledby="cc-page-title">
  <section class="cc-hero">
    <div class="cc-wrap cc-hero__grid">
      <div class="cc-hero__copy cc-reveal">
        <p class="cc-eyebrow">CLUTCH CODES™</p>
        <h1 id="cc-page-title">Clutch Codes™ Dynamic QR Tracking</h1>
        <h2>Make Every Print Piece Trackable.</h2>
        <p>
          Clutch Codes are dynamic QR codes built for physical marketing. Change where your code sends customers,
          track scan activity, and compare which printed campaigns generate engagement.
        </p>
        <div class="cc-actions">
          <a class="cc-btn cc-btn--primary" href="#clutch-codes-pricing">Explore Plans</a>
          <a class="cc-btn cc-btn--ghost" href="{{ shop_print_url }}">Shop Trackable Print</a>
        </div>
        <p class="cc-supporting">A Clutch Code is included with every eligible printed marketing product.</p>
      </div>

      <aside class="cc-dashboard cc-reveal cc-reveal--scale" aria-label="Example campaign data">
        <div class="cc-dashboard__top">
          <span>Example campaign data</span>
          <span class="cc-live-dot" aria-hidden="true"></span>
        </div>
        <div class="cc-dashboard__metrics">
          <article><span>Total scans</span><strong>1,284</strong></article>
          <article><span>Estimated unique activity</span><strong>917</strong></article>
          <article><span>Top campaign</span><strong>Summer Flyers</strong></article>
          <article><span>Top scan period</span><strong>6-8 PM</strong></article>
        </div>
        <div class="cc-chart" aria-hidden="true">
          <span style="--bar: 72%"></span>
          <span style="--bar: 44%"></span>
          <span style="--bar: 58%"></span>
          <span style="--bar: 88%"></span>
          <span style="--bar: 64%"></span>
          <span style="--bar: 39%"></span>
        </div>
        <p>This mockup shows example campaign information, not real customer data.</p>
      </aside>
    </div>
  </section>

  <section class="cc-section cc-section--soft">
    <div class="cc-wrap">
      <div class="cc-section__head cc-reveal">
        <h2>Trackable Marketing Is Already Included.</h2>
        <p>
          Every eligible printed marketing product ordered through Clutch includes a Clutch Code for that campaign.
          Your code can connect customers to a website, offer, booking page, review page, form, or digital profile.
        </p>
      </div>
      <div class="cc-product-grid">
        {% assign print_products = 'Business Cards|Flyers|Door Hangers|Yard Signs|Postcards|Brochures|Banners|Smart Business Cards' | split: '|' %}
        {% for item in print_products %}
          <article class="cc-mini-card cc-reveal" style="--stagger: {{ forloop.index0 | times: 55 }}ms">
            <span aria-hidden="true">{{ forloop.index }}</span>
            <h3>{{ item }}</h3>
          </article>
        {% endfor %}
      </div>
      <aside class="cc-callout cc-reveal">
        <strong>One print campaign. One included Clutch Code.</strong>
        <p>An order of 500 flyers uses one campaign code printed across all 500 flyers - not 500 separate codes.</p>
      </aside>
    </div>
  </section>

  <section class="cc-section">
    <div class="cc-wrap">
      <div class="cc-section__head cc-reveal">
        <h2>Change the Link. Keep the Printed Code.</h2>
        <p>
          A static QR code permanently contains its destination. A Clutch Code uses a managed redirect, allowing the
          customer to update the final destination without changing the QR code already printed on their marketing.
        </p>
      </div>
      <div class="cc-compare">
        <article class="cc-compare__card cc-reveal">
          <h3>Static QR Code</h3>
          <ul>
            <li>Destination is fixed</li>
            <li>Reprinting may be required</li>
            <li>Little or no campaign visibility</li>
            <li>Difficult to compare print materials</li>
          </ul>
        </article>
        <article class="cc-compare__card cc-compare__card--featured cc-reveal">
          <h3>Clutch Code</h3>
          <ul>
            <li>Update the destination</li>
            <li>Keep using the printed code</li>
            <li>Track scan activity</li>
            <li>Organize by campaign</li>
            <li>Compare printed materials</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="cc-section cc-section--soft">
    <div class="cc-wrap">
      <div class="cc-section__head cc-reveal">
        <h2>How Clutch Codes Work</h2>
      </div>
      <div class="cc-steps">
        {% assign steps = 'Choose Your Marketing|Order printed materials from Clutch or create a code through a paid Clutch Codes plan.||Connect Your Destination|Send customers to a website, promotion, booking page, review page, form, or Clutch Connect profile.||Track Engagement|View scan activity and compare which print campaigns receive attention.||Update Anytime|Change the final destination without replacing the printed QR code.' | split: '||' %}
        {% for step in steps %}
          {% assign step_parts = step | split: '|' %}
          <article class="cc-card cc-reveal" style="--stagger: {{ forloop.index0 | times: 70 }}ms">
            <span class="cc-step-number">{{ forloop.index }}</span>
            <h3>{{ step_parts[0] }}</h3>
            <p>{{ step_parts[1] }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="cc-section">
    <div class="cc-wrap">
      <div class="cc-section__head cc-reveal">
        <h2>See What Happens After Printing.</h2>
        <p>Clutch Code Analytics turns scan activity into understandable campaign information.</p>
      </div>
      <div class="cc-feature-grid">
        {% assign features = 'Total Scan Activity|See how many scans a Clutch Code receives.||Estimated Unique Activity|Estimate separate visitor activity without claiming guaranteed unique individuals.||Campaign Comparison|Compare flyers, signs, business cards, mailers, and other marketing pieces.||Time-Based Insights|View activity by date, day, and hour.||Device Insights|See mobile, tablet, desktop, browser, and operating-system information where available.||Approximate Locations|View approximate city, region, and country information where available.' | split: '||' %}
        {% for feature in features %}
          {% assign feature_parts = feature | split: '|' %}
          <article class="cc-card cc-reveal" style="--stagger: {{ forloop.index0 | times: 50 }}ms">
            <h3>{{ feature_parts[0] }}</h3>
            <p>{{ feature_parts[1] }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="cc-section cc-section--soft">
    <div class="cc-wrap">
      <div class="cc-section__head cc-reveal">
        <h2>One Code. More Ways to Connect.</h2>
      </div>
      <div class="cc-use-grid">
        {% assign uses = 'Restaurant|Menu, ordering, or reservations||Contractor|Quote request or booking form||Realtor|Property listing or walkthrough||Retail|Promotion or product collection||Local Service|Reviews or appointment scheduling||Event|Registration or event details||Professional|Contact information or Clutch Connect profile||Campaign|Offer-specific landing page' | split: '||' %}
        {% for use in uses %}
          {% assign use_parts = use | split: '|' %}
          <article class="cc-use-card cc-reveal" style="--stagger: {{ forloop.index0 | times: 45 }}ms">
            <h3>{{ use_parts[0] }}</h3>
            <p>{{ use_parts[1] }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section id="clutch-codes-pricing" class="cc-section">
    <div class="cc-wrap">
      <div class="cc-section__head cc-reveal">
        <h2>Choose Your Clutch Codes Plan.</h2>
        <p>
          Every paid plan includes dynamic destinations, Clutch Code management, customization, exports, and scan
          analytics. Choose the capacity that matches your number of active campaigns.
        </p>
      </div>
      <div class="cc-pricing">
        <article class="cc-price-card cc-reveal">
          <h3>Included With Print</h3>
          <p class="cc-price">Included</p>
          <p class="cc-capacity">One Clutch Code per eligible print campaign</p>
          <ul>
            <li>Dynamic destination</li>
            <li>Basic scan tracking</li>
            <li>Campaign association</li>
            <li>Standard QR download</li>
            <li>Included with qualifying Clutch print products</li>
          </ul>
          <a class="cc-btn cc-btn--secondary" href="{{ shop_print_url }}">Shop Trackable Print</a>
        </article>

        <article class="cc-price-card cc-reveal" style="--stagger: 80ms">
          <h3>Starter</h3>
          <p class="cc-price">$3.99<span>/month</span></p>
          <p class="cc-capacity">10 Clutch Codes</p>
          <ul>
            <li>Up to 10 active Clutch Codes</li>
            <li>Editable destinations</li>
            <li>Scan analytics</li>
            <li>Campaign organization</li>
            <li>QR customization</li>
            <li>Print-ready exports</li>
          </ul>
          <a class="cc-btn cc-btn--primary" href="{{ starter_url }}">Choose Starter</a>
        </article>

        <article class="cc-price-card cc-price-card--popular cc-reveal" style="--stagger: 160ms">
          <p class="cc-badge">Most Popular</p>
          <h3>Growth</h3>
          <p class="cc-price">$6.99<span>/month</span></p>
          <p class="cc-capacity">30 Clutch Codes</p>
          <ul>
            <li>Up to 30 active Clutch Codes</li>
            <li>Editable destinations</li>
            <li>Scan analytics</li>
            <li>Campaign comparison</li>
            <li>QR customization</li>
            <li>Print-ready exports</li>
          </ul>
          <a class="cc-btn cc-btn--primary" href="{{ growth_url }}">Choose Growth</a>
        </article>

        <article class="cc-price-card cc-reveal" style="--stagger: 240ms">
          <h3>Pro</h3>
          <p class="cc-price">$11.99<span>/month</span></p>
          <p class="cc-capacity">100 Clutch Codes</p>
          <ul>
            <li>Up to 100 active Clutch Codes</li>
            <li>Editable destinations</li>
            <li>Scan analytics</li>
            <li>Larger campaign library</li>
            <li>QR customization</li>
            <li>Print-ready exports</li>
          </ul>
          <a class="cc-btn cc-btn--primary" href="{{ pro_url }}">Choose Pro</a>
        </article>
      </div>
      <p class="cc-pricing-note cc-reveal">
        All prices are monthly. Cancel anytime. Previously printed Clutch Code redirects remain active subject to
        account and fair-use policies.
      </p>
    </div>
  </section>

  <section class="cc-section cc-section--soft">
    <div class="cc-wrap cc-split">
      <div class="cc-section__head cc-section__head--left cc-reveal">
        <h2>Stop Guessing Which Print Piece Worked.</h2>
        <p>
          In this example, flyers generated the most scan activity, giving the business a clearer signal about where
          customers engaged.
        </p>
        <p class="cc-small-note">Scans measure engagement. They do not automatically equal sales.</p>
      </div>
      <aside class="cc-comparison-mock cc-reveal" aria-label="Example campaign comparison">
        <p>Example campaign comparison</p>
        <div><span>Summer Flyers</span><strong>184 total scans</strong><i style="--bar: 100%"></i></div>
        <div><span>Yard Signs</span><strong>96 total scans</strong><i style="--bar: 52%"></i></div>
        <div><span>Business Cards</span><strong>58 total scans</strong><i style="--bar: 32%"></i></div>
      </aside>
    </div>
  </section>

  <section class="cc-section">
    <div class="cc-wrap cc-connect cc-reveal">
      <p class="cc-eyebrow">CLUTCH CONNECT</p>
      <h2>Send Scans to Your Clutch Connect Profile.</h2>
      <p>A Clutch Code can link to your website, promotion, booking page, form, or Clutch Connect digital profile.</p>
      <p>
        Clutch Codes plans and Clutch Connect+ are separate subscriptions. Customers can use them together, but
        purchasing a Clutch Codes plan does not automatically include all Connect+ profile features.
      </p>
      <div class="cc-actions cc-actions--center">
        <a class="cc-btn cc-btn--secondary" href="{{ clutch_connect_url }}">Explore Clutch Connect</a>
        {% if app_login_url != blank %}
          <a class="cc-btn cc-btn--ghost-dark" href="{{ app_login_url }}">App Login</a>
        {% endif %}
      </div>
    </div>
  </section>

  <section class="cc-section cc-section--soft">
    <div class="cc-wrap cc-faq-wrap">
      <div class="cc-section__head cc-reveal">
        <h2>Clutch Codes FAQ</h2>
      </div>
      <div class="cc-faq-list">
        <details class="cc-faq cc-reveal"><summary>What is a Clutch Code?</summary><p>A Clutch Code is a dynamic QR code connected to an editable destination and scan analytics.</p></details>
        <details class="cc-faq cc-reveal"><summary>Is a Clutch Code included with my print order?</summary><p>Every eligible printed marketing product includes one Clutch Code for that distinct campaign.</p></details>
        <details class="cc-faq cc-reveal"><summary>Does an order of 500 flyers include 500 codes?</summary><p>No. It includes one campaign code that can be printed on all 500 flyers.</p></details>
        <details class="cc-faq cc-reveal"><summary>Can I change the destination after printing?</summary><p>Yes. The final destination can be updated while the printed QR code remains the same.</p></details>
        <details class="cc-faq cc-reveal"><summary>What can I track?</summary><p>Depending on available scan data and account access, Clutch Codes can show total activity, estimated unique activity, scan times, devices, browsers, operating systems, referrers, approximate locations, and campaign comparisons.</p></details>
        <details class="cc-faq cc-reveal"><summary>Does Clutch track exact locations?</summary><p>No. Geographic information is approximate and does not provide exact GPS location.</p></details>
        <details class="cc-faq cc-reveal"><summary>Do customers need an application to scan?</summary><p>No. Most modern phones can scan the code using their normal camera.</p></details>
        <details class="cc-faq cc-reveal"><summary>Are scans the same as sales?</summary><p>No. Scan data measures QR engagement and does not automatically prove a purchase or conversion.</p></details>
        <details class="cc-faq cc-reveal"><summary>What happens if I cancel a paid plan?</summary><p>Existing redirects should remain operational. Creation, editing, capacity, and advanced analytics access may be limited based on the remaining account allowance.</p></details>
      </div>
    </div>
  </section>

  <section class="cc-final">
    <div class="cc-wrap cc-final__inner cc-reveal">
      <h2>Make Your Next Print Campaign Measurable.</h2>
      <p>Order trackable marketing from Clutch or choose a Clutch Codes plan for additional dynamic QR campaigns.</p>
      <div class="cc-actions cc-actions--center">
        <a class="cc-btn cc-btn--primary" href="#clutch-codes-pricing">Explore Plans</a>
        <a class="cc-btn cc-btn--ghost" href="{{ shop_print_url }}">Shop Print Products</a>
      </div>
    </div>
  </section>
</main>

{% stylesheet %}
  .cc-page {
    --cc-navy: #384862;
    --cc-orange: #ffa665;
    --cc-soft: #f6f7f9;
    --cc-border: rgba(56, 72, 98, 0.14);
    background: #ffffff;
    color: var(--cc-navy);
    font-family: 'Montserrat', sans-serif;
    overflow-x: clip;
    overflow-y: visible;
  }

  .cc-page * {
    box-sizing: border-box;
    min-width: 0;
  }

  .cc-wrap {
    margin-inline: auto;
    max-width: 1180px;
    width: min(100% - 2rem, 1180px);
  }

  .cc-page h1,
  .cc-page h2,
  .cc-page h3,
  .cc-page summary,
  .cc-price,
  .cc-btn {
    font-family: 'Exo 2', sans-serif;
  }

  .cc-hero {
    background:
      radial-gradient(circle at 85% 10%, rgba(255, 166, 101, 0.22), transparent 30rem),
      linear-gradient(135deg, #263349 0%, var(--cc-navy) 62%, #2f3f58 100%);
    color: #ffffff;
    padding: clamp(3.2rem, 7vw, 6.2rem) 0;
  }

  .cc-hero__grid,
  .cc-split {
    display: grid;
    gap: clamp(1.2rem, 4vw, 2.2rem);
  }

  .cc-hero__copy {
    display: grid;
    gap: 0.9rem;
    justify-items: start;
  }

  .cc-eyebrow {
    color: var(--cc-orange);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.13em;
    line-height: 1.2;
    margin: 0;
  }

  .cc-page h1 {
    color: rgba(255, 255, 255, 0.76);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1.15;
    margin: 0;
    text-transform: uppercase;
  }

  .cc-hero h2,
  .cc-final h2 {
    color: #ffffff;
    font-size: clamp(2.55rem, 9vw, 5.4rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.95;
    margin: 0;
    max-width: 760px;
  }

  .cc-page p {
    line-height: 1.55;
    margin: 0;
  }

  .cc-hero__copy > p:not(.cc-eyebrow):not(.cc-supporting),
  .cc-final p {
    color: rgba(255, 255, 255, 0.86);
    font-size: clamp(1rem, 2vw, 1.17rem);
    max-width: 700px;
  }

  .cc-supporting {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.92rem;
    font-weight: 800;
  }

  .cc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.25rem;
    width: 100%;
  }

  .cc-actions--center {
    justify-content: center;
  }

  .cc-btn {
    align-items: center;
    border: 1px solid transparent;
    border-radius: 12px;
    display: inline-flex;
    font-size: 0.96rem;
    font-weight: 900;
    justify-content: center;
    min-height: 48px;
    padding: 0.78rem 1.08rem;
    text-align: center;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .cc-btn:hover {
    transform: translateY(-1px);
  }

  .cc-btn--primary {
    background: var(--cc-orange);
    box-shadow: 0 16px 32px rgba(255, 166, 101, 0.25);
    color: var(--cc-navy);
  }

  .cc-btn--secondary,
  .cc-btn--ghost-dark {
    background: #ffffff;
    border-color: var(--cc-border);
    color: var(--cc-navy);
  }

  .cc-btn--ghost {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.46);
    color: #ffffff;
  }

  .cc-dashboard,
  .cc-card,
  .cc-mini-card,
  .cc-compare__card,
  .cc-use-card,
  .cc-price-card,
  .cc-comparison-mock,
  .cc-connect,
  .cc-faq,
  .cc-callout {
    background: #ffffff;
    border: 1px solid var(--cc-border);
    border-radius: 18px;
    box-shadow: 0 16px 36px rgba(25, 38, 58, 0.08);
  }

  .cc-dashboard {
    align-self: center;
    color: var(--cc-navy);
    display: grid;
    gap: 1rem;
    padding: clamp(1rem, 3vw, 1.35rem);
  }

  .cc-dashboard__top {
    align-items: center;
    display: flex;
    font-weight: 900;
    justify-content: space-between;
  }

  .cc-live-dot {
    background: var(--cc-orange);
    border-radius: 999px;
    box-shadow: 0 0 0 7px rgba(255, 166, 101, 0.18);
    height: 0.6rem;
    width: 0.6rem;
  }

  .cc-dashboard__metrics {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cc-dashboard__metrics article {
    background: var(--cc-soft);
    border: 1px solid rgba(56, 72, 98, 0.08);
    border-radius: 12px;
    display: grid;
    gap: 0.2rem;
    padding: 0.75rem;
  }

  .cc-dashboard__metrics span,
  .cc-dashboard > p,
  .cc-small-note,
  .cc-capacity,
  .cc-pricing-note {
    color: rgba(56, 72, 98, 0.72);
    font-size: 0.86rem;
  }

  .cc-dashboard__metrics strong {
    color: var(--cc-navy);
    font-size: clamp(1.05rem, 3.5vw, 1.42rem);
    line-height: 1.05;
  }

  .cc-chart {
    align-items: end;
    background: linear-gradient(180deg, #f9fafc, #eef3f8);
    border: 1px solid rgba(56, 72, 98, 0.08);
    border-radius: 14px;
    display: grid;
    gap: 0.45rem;
    grid-template-columns: repeat(6, 1fr);
    height: clamp(120px, 24vw, 170px);
    padding: 0.85rem;
  }

  .cc-chart span {
    background: linear-gradient(180deg, var(--cc-orange), #ffbf8a);
    border-radius: 999px 999px 6px 6px;
    height: var(--bar);
  }

  .cc-section,
  .cc-final {
    padding: clamp(2.8rem, 6vw, 5.4rem) 0;
  }

  .cc-section--soft {
    background: var(--cc-soft);
  }

  .cc-section__head {
    display: grid;
    gap: 0.75rem;
    margin: 0 auto clamp(1.4rem, 4vw, 2.35rem);
    max-width: 820px;
    text-align: center;
  }

  .cc-section__head--left {
    margin: 0;
    text-align: left;
  }

  .cc-section h2,
  .cc-connect h2 {
    color: var(--cc-navy);
    font-size: clamp(1.9rem, 5.8vw, 3.35rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.03;
    margin: 0;
  }

  .cc-section__head p,
  .cc-card p,
  .cc-use-card p,
  .cc-compare__card li,
  .cc-price-card li,
  .cc-faq p,
  .cc-connect p {
    color: rgba(56, 72, 98, 0.78);
  }

  .cc-product-grid,
  .cc-feature-grid,
  .cc-use-grid,
  .cc-pricing,
  .cc-steps,
  .cc-compare {
    display: grid;
    gap: 0.9rem;
  }

  .cc-mini-card,
  .cc-card,
  .cc-use-card,
  .cc-compare__card,
  .cc-price-card,
  .cc-callout,
  .cc-connect,
  .cc-comparison-mock {
    padding: clamp(1rem, 3vw, 1.35rem);
  }

  .cc-mini-card {
    align-items: center;
    display: flex;
    gap: 0.75rem;
  }

  .cc-mini-card span,
  .cc-step-number {
    align-items: center;
    background: rgba(255, 166, 101, 0.2);
    border-radius: 999px;
    color: var(--cc-navy);
    display: inline-flex;
    flex: 0 0 auto;
    font-weight: 900;
    height: 2.15rem;
    justify-content: center;
    width: 2.15rem;
  }

  .cc-mini-card h3,
  .cc-card h3,
  .cc-use-card h3,
  .cc-compare__card h3,
  .cc-price-card h3 {
    color: var(--cc-navy);
    font-size: clamp(1.12rem, 3vw, 1.42rem);
    font-weight: 900;
    line-height: 1.12;
    margin: 0;
  }

  .cc-card,
  .cc-use-card,
  .cc-price-card {
    display: grid;
    gap: 0.65rem;
  }

  .cc-callout {
    display: grid;
    gap: 0.35rem;
    margin-top: 1rem;
    text-align: center;
  }

  .cc-callout strong {
    color: var(--cc-navy);
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1.2rem, 4vw, 1.75rem);
  }

  .cc-compare__card ul,
  .cc-price-card ul {
    display: grid;
    gap: 0.48rem;
    margin: 0.25rem 0 0;
    padding-left: 1.15rem;
  }

  .cc-compare__card li::marker,
  .cc-price-card li::marker {
    color: var(--cc-orange);
  }

  .cc-compare__card--featured,
  .cc-price-card--popular {
    border-color: rgba(255, 166, 101, 0.62);
    box-shadow: 0 20px 44px rgba(255, 166, 101, 0.14);
  }

  .cc-price-card {
    position: relative;
  }

  .cc-price-card .cc-btn {
    margin-top: auto;
    width: 100%;
  }

  .cc-badge {
    align-self: start;
    background: rgba(255, 166, 101, 0.2);
    border: 1px solid rgba(255, 166, 101, 0.45);
    border-radius: 999px;
    color: #8e512a;
    font-size: 0.78rem;
    font-weight: 900;
    justify-self: start;
    padding: 0.28rem 0.58rem;
  }

  .cc-price {
    color: var(--cc-navy);
    font-size: clamp(1.65rem, 5vw, 2.45rem);
    font-weight: 900;
    line-height: 1;
  }

  .cc-price span {
    color: rgba(56, 72, 98, 0.64);
    font-size: 0.95rem;
  }

  .cc-pricing-note {
    margin: 1.2rem auto 0;
    max-width: 860px;
    text-align: center;
  }

  .cc-comparison-mock {
    display: grid;
    gap: 0.9rem;
  }

  .cc-comparison-mock > p {
    color: var(--cc-navy);
    font-weight: 900;
  }

  .cc-comparison-mock div {
    display: grid;
    gap: 0.35rem;
  }

  .cc-comparison-mock strong,
  .cc-comparison-mock span {
    color: var(--cc-navy);
  }

  .cc-comparison-mock i {
    background: linear-gradient(90deg, var(--cc-orange), #ffc08f);
    border-radius: 999px;
    display: block;
    height: 0.6rem;
    width: var(--bar);
  }

  .cc-connect {
    display: grid;
    gap: 0.85rem;
    justify-items: center;
    margin-inline: auto;
    max-width: 900px;
    text-align: center;
  }

  .cc-faq-wrap {
    max-width: 920px;
  }

  .cc-faq-list {
    display: grid;
    gap: 0.75rem;
  }

  .cc-faq {
    padding: 1rem 1.1rem;
  }

  .cc-faq summary {
    color: var(--cc-navy);
    cursor: pointer;
    font-size: 1.05rem;
    font-weight: 900;
    line-height: 1.25;
  }

  .cc-faq p {
    margin-top: 0.65rem;
  }

  .cc-final {
    background: var(--cc-navy);
    color: #ffffff;
  }

  .cc-final__inner {
    display: grid;
    gap: 0.9rem;
    justify-items: center;
    text-align: center;
  }

  .cc-reveal {
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: var(--stagger, 0ms);
  }

  .cc-reveal--scale {
    transform: translate3d(0, 24px, 0) scale(0.97);
  }

  .cc-reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media screen and (min-width: 640px) {
    .cc-product-grid,
    .cc-feature-grid,
    .cc-use-grid,
    .cc-steps,
    .cc-compare {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .cc-actions {
      width: auto;
    }
  }

  @media screen and (min-width: 900px) {
    .cc-hero__grid,
    .cc-split {
      align-items: center;
      grid-template-columns: minmax(0, 1fr) minmax(340px, 0.82fr);
    }

    .cc-feature-grid,
    .cc-use-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .cc-pricing {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 520px) {
    .cc-wrap {
      width: min(100% - 1.25rem, 1180px);
    }

    .cc-btn {
      width: 100%;
    }

    .cc-dashboard__metrics {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cc-reveal,
    .cc-reveal--scale,
    .cc-reveal.is-visible {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  const revealItems = document.querySelectorAll('.cc-reveal');
  const staleQrProSuggestion = document.querySelector('a[href="/products/qr-pro"]')?.closest('.predictive-search-results__card');

  staleQrProSuggestion?.remove();

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  } else if ('IntersectionObserver' in window) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        });
      },
      { threshold: 0.16, rootMargin: '0px 0px -8% 0px' }
    );

    revealItems.forEach((item) => revealObserver.observe(item));
  } else {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  }
{% endjavascript %}

