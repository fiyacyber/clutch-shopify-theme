{% comment %}
  Clutch Print Shop custom homepage
{% endcomment %}

<section class="clutch-home">
  <div class="clutch-hero page-width">
    <div class="clutch-hero__copy">
      <p class="clutch-eyebrow">PRINT + QR TRACKING</p>
      <h1>Print Smarter. Track Everything.</h1>
      <p class="clutch-lead">Every Clutch print order includes a dynamic Clutch QR Code powered by Clutch QR™, giving you access to scan analytics, engagement data, and measurable marketing insights.</p>
      <div class="clutch-actions">
        <a class="clutch-btn clutch-btn--primary" href="/collections/all">Shop Products</a>
          <a class="clutch-btn clutch-btn--secondary" href="/pages/contact">Request Custom Quote</a>
      </div>
    </div>
    <div class="clutch-hero__card" aria-label="Clutch QR tracking preview">
      <div class="clutch-card__top">CLUTCH QR™</div>
      <div class="clutch-qr-box">
        <span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span>
      </div>
      <p><strong>Included with qualifying print orders</strong></p>
      <p>Editable destination URLs, scan counts, and customer dashboard access.</p>
    </div>
  </div>

  <div class="clutch-strip page-width">
    <div><strong>Dynamic QR included</strong><span>Free with qualifying orders over $45</span></div>
    <div><strong>Design help available</strong><span>Artwork setup, cleanup, and file review</span></div>
    <div><strong>Built for businesses</strong><span>Cards, flyers, signs, banners, kits, and more</span></div>
  </div>

  <div class="clutch-section page-width">
    <div class="clutch-section__heading">
      <p class="clutch-eyebrow">BUSINESS ESSENTIALS</p>
      <h2>Print products built for growing businesses.</h2>
      <p>Core marketing materials with clean ordering, practical options, and QR tracking built into the Clutch workflow.</p>
    </div>
    <div class="clutch-grid clutch-grid--products">
      <a class="clutch-product" href="/products/business-cards"><span>Business Cards</span><small>Professional cards for everyday networking.</small></a>
      <a class="clutch-product" href="/products/full-color-flyers"><span>Flyers</span><small>Promote offers, events, and services fast.</small></a>
      <a class="clutch-product" href="/products/door-hangers"><span>Door Hangers</span><small>Neighborhood-ready print for local outreach.</small></a>
      <a class="clutch-product" href="/products/yard-signs"><span>Yard Signs</span><small>Durable outdoor signs for local visibility.</small></a>
      <a class="clutch-product" href="/products/postcards"><span>Postcards</span><small>Compact promos for offers and follow-ups.</small></a>
      <a class="clutch-product" href="/products/brochures"><span>Brochures</span><small>Folded print pieces for polished presentations.</small></a>
      <a class="clutch-product" href="/products/banners"><span>Banners</span><small>Large-format banners for bold displays.</small></a>
    </div>
  </div>

  <div class="clutch-section clutch-section--navy">
    <div class="page-width clutch-qr-section">
      <div>
        <p class="clutch-eyebrow clutch-eyebrow--light">MORE THAN JUST PRINTING</p>
        <h2>Turn printed marketing into trackable marketing.</h2>
        <p>Most print companies stop at printing. Clutch helps you understand what happens after your materials are delivered.</p>
      </div>
      <div class="clutch-grid clutch-grid--features">
        <div><strong>Dynamic QR Codes</strong><span>Update destinations after printing without reordering materials.</span></div>
        <div><strong>Scan Tracking</strong><span>See how many people scan your printed campaigns.</span></div>
        <div><strong>Editable URLs</strong><span>Send customers to websites, booking pages, reviews, forms, and offers.</span></div>
        <div><strong>Customer Portal</strong><span>Manage links, download QR files, and view scan activity.</span></div>
      </div>
    </div>
  </div>

  <div class="clutch-section page-width">
    <div class="clutch-section__heading clutch-section__heading--center">
      <p class="clutch-eyebrow">BUSINESS KITS</p>
      <h2>Prebuilt bundles for faster launches.</h2>
    </div>
    <div class="clutch-grid clutch-grid--kits">
      <a class="clutch-kit" href="/products/startup-kit"><small>Starter</small><strong>Startup Kit</strong><span>Business cards, flyers, and file review.</span></a>
      <a class="clutch-kit clutch-kit--featured" href="/products/growth-kit"><small>Best Value</small><strong>Growth Kit</strong><span>Cards, flyers, door hangers, and QR tracking.</span></a>
      <a class="clutch-kit" href="/pages/contact"><small>Agency / Custom</small><strong>Custom Kit</strong><span>Custom quantities, yard signs, banners, and Clutch Connect reporting.</span></a>
    </div>
  </div>

  <div class="clutch-cta page-width">
    <div>
      <p class="clutch-eyebrow">CUSTOM ORDERS</p>
      <h2>Need help choosing the right print setup?</h2>
      <p>Send what you need, your deadline, and whether you already have artwork.</p>
    </div>
    <a class="clutch-btn clutch-btn--primary" href="/pages/contact">Start Custom Order</a>
  </div>
</section>

<style>
  .clutch-home { --clutch-orange:#FFA665; --clutch-navy:#384862; --clutch-ink:#17202b; --clutch-soft:#fff7f0; --clutch-border:rgba(56,72,98,.16); color:var(--clutch-ink); }
  .clutch-home .page-width { max-width:1180px; margin:0 auto; padding-left:22px; padding-right:22px; }
  .clutch-hero { display:grid; grid-template-columns:minmax(0,1.15fr) minmax(280px,.85fr); gap:36px; align-items:center; padding-top:60px; padding-bottom:48px; }
  .clutch-eyebrow { margin:0 0 12px; font-size:12px; font-weight:800; letter-spacing:.16em; color:var(--clutch-orange); text-transform:uppercase; }
  .clutch-eyebrow--light { color:var(--clutch-orange); }
  .clutch-hero h1, .clutch-section h2, .clutch-cta h2 { margin:0; line-height:.95; letter-spacing:-.04em; color:var(--clutch-navy); }
  .clutch-hero h1 { font-size:clamp(44px,8vw,92px); max-width:780px; }
  .clutch-lead { margin:22px 0 0; font-size:clamp(17px,2vw,22px); line-height:1.45; max-width:720px; }
  .clutch-actions { display:flex; flex-wrap:wrap; gap:14px; margin-top:28px; }
  .clutch-btn { display:inline-flex; align-items:center; justify-content:center; min-height:48px; padding:0 22px; border-radius:999px; font-weight:800; text-decoration:none; transition:transform .15s ease, box-shadow .15s ease; }
  .clutch-btn:hover { transform:translateY(-1px); }
  .clutch-btn--primary { background:var(--clutch-orange); color:var(--clutch-navy); box-shadow:0 10px 24px rgba(255,166,101,.28); }
  .clutch-btn--secondary { background:white; color:var(--clutch-navy); border:1px solid var(--clutch-border); }
  .clutch-hero__card { border-radius:30px; padding:28px; background:linear-gradient(145deg,var(--clutch-navy),#243044); color:#fff; box-shadow:0 24px 60px rgba(56,72,98,.24); }
  .clutch-card__top { font-weight:900; letter-spacing:.12em; color:var(--clutch-orange); margin-bottom:20px; }
  .clutch-qr-box { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; aspect-ratio:1; max-width:260px; background:white; border-radius:22px; padding:20px; margin-bottom:20px; }
  .clutch-qr-box span { background:var(--clutch-navy); border-radius:8px; }
  .clutch-qr-box span:nth-child(2n) { background:var(--clutch-orange); }
  .clutch-hero__card p { margin:10px 0 0; color:rgba(255,255,255,.82); }
  .clutch-strip { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; padding-top:8px; padding-bottom:34px; }
  .clutch-strip div { border:1px solid var(--clutch-border); border-radius:22px; padding:18px; background:#fff; }
  .clutch-strip strong, .clutch-strip span { display:block; }
  .clutch-strip strong { color:var(--clutch-navy); }
  .clutch-strip span { margin-top:4px; font-size:14px; opacity:.78; }
  .clutch-section { padding-top:58px; padding-bottom:58px; }
  .clutch-section__heading { max-width:760px; margin-bottom:28px; }
  .clutch-section__heading--center { text-align:center; margin-left:auto; margin-right:auto; }
  .clutch-section h2, .clutch-cta h2 { font-size:clamp(34px,5vw,58px); }
  .clutch-section__heading p:not(.clutch-eyebrow), .clutch-cta p { font-size:18px; line-height:1.55; opacity:.78; }
  .clutch-grid { display:grid; gap:16px; }
  .clutch-grid--products { grid-template-columns:repeat(4,1fr); }
  .clutch-product, .clutch-kit { text-decoration:none; color:inherit; border:1px solid var(--clutch-border); border-radius:24px; padding:22px; background:white; min-height:150px; transition:transform .15s ease, border-color .15s ease; }
  .clutch-product:hover, .clutch-kit:hover { transform:translateY(-2px); border-color:var(--clutch-orange); }
  .clutch-product span, .clutch-product small, .clutch-kit small, .clutch-kit strong, .clutch-kit span { display:block; }
  .clutch-product span { font-size:21px; font-weight:900; color:var(--clutch-navy); }
  .clutch-product small, .clutch-kit span { margin-top:10px; font-size:14px; line-height:1.45; opacity:.75; }
  .clutch-section--navy { background:var(--clutch-navy); color:#fff; }
  .clutch-section--navy h2 { color:#fff; }
  .clutch-qr-section { display:grid; grid-template-columns:.9fr 1.1fr; gap:32px; align-items:start; }
  .clutch-grid--features { grid-template-columns:repeat(2,1fr); }
  .clutch-grid--features div { border:1px solid rgba(255,255,255,.14); border-radius:22px; padding:22px; background:rgba(255,255,255,.06); }
  .clutch-grid--features strong, .clutch-grid--features span { display:block; }
  .clutch-grid--features strong { color:var(--clutch-orange); }
  .clutch-grid--features span { margin-top:8px; color:rgba(255,255,255,.78); line-height:1.45; }
  .clutch-grid--kits { grid-template-columns:repeat(3,1fr); }
  .clutch-kit small { color:var(--clutch-orange); font-weight:900; text-transform:uppercase; letter-spacing:.08em; }
  .clutch-kit strong { margin-top:8px; font-size:28px; color:var(--clutch-navy); }
  .clutch-kit--featured { background:var(--clutch-soft); border-color:rgba(255,166,101,.55); }
  .clutch-cta { margin-top:20px; margin-bottom:70px; border-radius:30px; padding-top:34px; padding-bottom:34px; background:var(--clutch-soft); display:flex; align-items:center; justify-content:space-between; gap:24px; }
  .clutch-cta div { max-width:760px; }
  @media (max-width:900px){ .clutch-hero, .clutch-qr-section { grid-template-columns:1fr; } .clutch-grid--products { grid-template-columns:repeat(2,1fr); } .clutch-strip, .clutch-grid--kits { grid-template-columns:1fr; } .clutch-cta { display:block; } .clutch-cta .clutch-btn { margin-top:18px; } }
  @media (max-width:560px){ .clutch-hero { padding-top:36px; } .clutch-grid--products, .clutch-grid--features { grid-template-columns:1fr; } .clutch-actions .clutch-btn { width:100%; } .clutch-hero__card { padding:22px; } }
</style>

{% schema %}
{
  "name": "Clutch homepage",
  "settings": [],
  "presets": [
    {
      "name": "Clutch homepage"
    }
  ]
}
{% endschema %}
