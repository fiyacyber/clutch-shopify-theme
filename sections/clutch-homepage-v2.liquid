{%- liquid
  assign print_collection = section.settings.print_collection
  if print_collection == blank
    assign print_collection = collections.all
  endif

  assign business_cards_product = section.settings.business_cards_product
  if business_cards_product == blank
    assign business_cards_product = all_products['standard-business-cards']
  endif

  assign flyer_product = section.settings.flyer_product
  if flyer_product == blank
    assign flyer_product = all_products['premium-flyers']
  endif

  assign door_hanger_product = section.settings.door_hanger_product
  if door_hanger_product == blank
    assign door_hanger_product = all_products['door-hangers']
  endif

  assign yard_sign_product = section.settings.yard_sign_product
  if yard_sign_product == blank
    assign yard_sign_product = all_products['yard-signs']
  endif

  assign postcard_product = section.settings.postcard_product
  if postcard_product == blank
    assign postcard_product = all_products['premium-postcards']
  endif

  assign brochure_product = section.settings.brochure_product
  if brochure_product == blank
    assign brochure_product = all_products['tri-fold-brochures']
  endif

  assign banner_product = section.settings.banner_product
  if banner_product == blank
    assign banner_product = all_products['vinyl-banners']
  endif

  assign starter_kit_product = section.settings.starter_kit_product
  if starter_kit_product == blank
    assign starter_kit_product = all_products['startup-kit']
  endif

  assign growth_kit_product = section.settings.growth_kit_product
  if growth_kit_product == blank
    assign growth_kit_product = all_products['growth-kit']
  endif

  assign custom_kit_product = section.settings.custom_kit_product
  if custom_kit_product == blank
    assign custom_kit_product = all_products['contractor-kit']
  endif

  assign nfc_product = section.settings.nfc_product
  if nfc_product == blank
    assign nfc_product = all_products['clutch-connect-card']
  endif

  assign connect_page = section.settings.connect_page
  if connect_page == blank
    assign connect_url = '/pages/qr-pro'
  else
    assign connect_url = connect_page.url
  endif

  assign custom_order_page = section.settings.custom_order_page
  if custom_order_page == blank
    assign custom_order_url = '/pages/contact'
  else
    assign custom_order_url = custom_order_page.url
  endif

  assign upload_page = pages['file-upload-requirements']
  assign upload_url = '/pages/file-upload-requirements'
  if upload_page != blank
    assign upload_url = upload_page.url
  endif
-%}

<main class="chp-home" data-chp-home>
  <section class="chp-hero" aria-labelledby="chp-hero-title">
    <div class="chp-shell chp-hero__grid">
      <div class="chp-hero__copy chp-reveal">
        <p class="chp-eyebrow">{{ section.settings.hero_eyebrow | default: 'PROFESSIONAL PRINT FOR GROWING BUSINESSES' }}</p>
        <h1 id="chp-hero-title">{{ section.settings.hero_heading | default: 'Print Smarter with Trackable Results.' }}</h1>
        <p>{{ section.settings.hero_text | default: 'Professional business cards, flyers, signs, postcards, banners, and print essentials built to help your business stay visible, look credible, and connect physical marketing with measurable digital engagement.' }}</p>
        <div class="chp-actions">
          <a class="chp-btn chp-btn--primary" href="{{ print_collection.url | default: '/collections/all' }}">Shop Print Products<span aria-hidden="true">→</span></a>
          <a class="chp-btn chp-btn--secondary" href="#print-products" data-chp-scroll>Explore What We Print<span aria-hidden="true">→</span></a>
        </div>
        <a class="chp-text-link" href="#custom-order" data-chp-scroll>Need something custom?</a>
        <p class="chp-trust">Free shipping · Professional production · Custom order support</p>
        <a class="chp-scroll-cue" href="#print-products" data-chp-scroll>
          <span>Explore Clutch Print Shop</span>
          <span aria-hidden="true">↓</span>
        </a>
      </div>
      <div class="chp-hero__visual chp-reveal" data-chp-depth>
        {%- if section.settings.hero_image != blank -%}
          {{ section.settings.hero_image | image_url: width: 1200 | image_tag: widths: '360, 540, 720, 960, 1200', sizes: '(min-width: 990px) 48vw, 92vw', loading: 'eager', class: 'chp-hero__image', alt: section.settings.hero_image.alt | default: 'Clutch Print Shop print product samples' }}
        {%- else -%}
          <div class="chp-print-stack" aria-label="Popular print products">
            <span>Business Cards</span>
            <span>Flyers</span>
            <span>Door Hangers</span>
            <span>Postcards</span>
            <span>Yard Signs</span>
            <span>Banners</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="chp-section chp-products" id="print-products" aria-labelledby="chp-products-title">
    <div class="chp-shell">
      <div class="chp-section-head chp-reveal">
        <p class="chp-eyebrow">PRINT PRODUCT EXPLORER</p>
        <h2 id="chp-products-title">Everything Your Business Needs in Print</h2>
        <p>Explore essential print products for marketing, sales, events, storefronts, local outreach, and everyday customer interactions.</p>
      </div>
      <div class="chp-product-rail" aria-label="Print product categories">
        {%- liquid
          assign product_cards = 'business_cards_product|Business Cards|Professional printed cards for networking, appointments, and everyday business use.|BC||flyer_product|Flyers|Promote services, offers, events, and local campaigns.|FL||door_hanger_product|Door Hangers|Reach neighborhoods with direct, targeted local marketing.|DH||yard_sign_product|Yard Signs|Build visibility for services, events, promotions, and properties.|YS||postcard_product|Postcards|Create focused direct-mail and handout campaigns.|PC||brochure_product|Brochures|Present services and business information in a polished format.|BR||banner_product|Banners|Create high-visibility messaging for storefronts, locations, and events.|BN' | split: '||'
        -%}
        {%- for item in product_cards -%}
          {%- liquid
            assign parts = item | split: '|'
            assign product_key = parts[0]
            assign title = parts[1]
            assign desc = parts[2]
            assign initials = parts[3]
            assign card_product = blank
            case product_key
              when 'business_cards_product'
                assign card_product = business_cards_product
              when 'flyer_product'
                assign card_product = flyer_product
              when 'door_hanger_product'
                assign card_product = door_hanger_product
              when 'yard_sign_product'
                assign card_product = yard_sign_product
              when 'postcard_product'
                assign card_product = postcard_product
              when 'brochure_product'
                assign card_product = brochure_product
              when 'banner_product'
                assign card_product = banner_product
            endcase
            assign card_url = card_product.url
            if card_url == blank
              assign card_url = print_collection.url | default: '/collections/all'
            endif
          -%}
          <a class="chp-product-card chp-reveal" href="{{ card_url }}" style="--chp-stagger: {{ forloop.index0 | times: 80 }}ms">
            <span class="chp-product-card__media">
              {%- if card_product.featured_image != blank -%}
                {{ card_product.featured_image | image_url: width: 520 | image_tag: widths: '240, 360, 520', sizes: '(min-width: 990px) 24vw, 68vw', loading: 'lazy', alt: card_product.featured_image.alt | default: title }}
              {%- else -%}
                <span>{{ initials }}</span>
              {%- endif -%}
            </span>
            <span class="chp-product-card__body">
              <strong>{{ title }}</strong>
              <span>{{ desc }}</span>
              <em>View Products <span aria-hidden="true">→</span></em>
            </span>
          </a>
        {%- endfor -%}
      </div>
      <div class="chp-section-actions chp-reveal">
        <a class="chp-btn chp-btn--primary" href="{{ print_collection.url | default: '/collections/all' }}">Shop All Print Products<span aria-hidden="true">→</span></a>
        <a class="chp-progress-link" href="#trackable-print" data-chp-scroll>See how Clutch makes print trackable<span aria-hidden="true">↓</span></a>
      </div>
    </div>
  </section>

  <section class="chp-section chp-track" id="trackable-print" aria-labelledby="chp-track-title">
    <div class="chp-shell chp-split">
      <div class="chp-copy chp-reveal">
        <p class="chp-eyebrow">PRINT THAT DOES MORE</p>
        <h2 id="chp-track-title">Turn Every Printed Piece Into a Clear Next Step</h2>
        <p>Connect eligible print products to a dynamic QR destination so customers can scan, learn more, request a quote, view an offer, or visit your digital profile.</p>
        <div class="chp-flow" aria-label="Trackable print flow">
          <span>Printed Product</span>
          <span>QR Scan</span>
          <span>Digital Destination</span>
          <span>Engagement</span>
        </div>
        <a class="chp-btn chp-btn--secondary" href="#clutch-nfc-card" data-chp-scroll>See Connected Business Tools<span aria-hidden="true">→</span></a>
      </div>
      <div class="chp-use-grid">
        {%- assign uses = 'Flyers|Promotion Page|Send customers to a service page, promotion, or booking link.||Door Hangers|Quote Form|Connect local outreach to a quote request or contact form.||Postcards|Campaign Offer|Link direct-mail campaigns to an offer or campaign landing page.||Business Cards|Digital Profile|Give customers a digital destination they can revisit after the conversation.' | split: '||' -%}
        {%- for use in uses -%}
          {%- assign parts = use | split: '|' -%}
          <article class="chp-use-card chp-reveal" tabindex="0" style="--chp-stagger: {{ forloop.index0 | times: 80 }}ms">
            <h3>{{ parts[0] }}</h3>
            <p>{{ parts[2] }}</p>
            <strong>{{ parts[0] }} → {{ parts[1] }}</strong>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="chp-section chp-business-card" id="business-cards" aria-labelledby="chp-business-card-title">
    <div class="chp-shell chp-split chp-split--reverse">
      <div class="chp-product-spotlight chp-reveal">
        <div class="chp-product-spotlight__media">
          {%- if business_cards_product.featured_image != blank -%}
            {{ business_cards_product.featured_image | image_url: width: 760 | image_tag: widths: '320, 520, 760', sizes: '(min-width: 990px) 38vw, 92vw', loading: 'lazy', alt: business_cards_product.featured_image.alt | default: business_cards_product.title }}
          {%- else -%}
            <span>Printed Cards</span>
          {%- endif -%}
        </div>
        <div>
          <h3>{{ business_cards_product.title | default: 'Standard Business Cards' }}</h3>
          {%- if business_cards_product != blank -%}
            <p class="chp-price">From {{ business_cards_product.price_min | money }}</p>
          {%- endif -%}
          <p>Premium printed cards with current Shopify options and quantities available on the product page.</p>
        </div>
      </div>
      <div class="chp-copy chp-reveal">
        <p class="chp-eyebrow">PRINTED BUSINESS CARDS</p>
        <h2 id="chp-business-card-title">Make the Right First Impression</h2>
        <p>Professional printed business cards for appointments, networking, customer handouts, events, and everyday business use.</p>
        <div class="chp-actions">
          <a class="chp-btn chp-btn--primary" href="{{ business_cards_product.url | default: '/products/standard-business-cards' }}">Shop Business Cards<span aria-hidden="true">→</span></a>
          <a class="chp-btn chp-btn--secondary" href="{{ print_collection.url | default: '/collections/all' }}">Compare Card Options<span aria-hidden="true">→</span></a>
        </div>
        <a class="chp-progress-link" href="#clutch-nfc-card" data-chp-scroll>Looking for one reusable card? See the Clutch NFC Card<span aria-hidden="true">↓</span></a>
      </div>
    </div>
  </section>

  <section class="chp-section chp-kits" id="business-kits" aria-labelledby="chp-kits-title">
    <div class="chp-shell">
      <div class="chp-section-head chp-reveal">
        <p class="chp-eyebrow">READY-TO-GO BUSINESS KITS</p>
        <h2 id="chp-kits-title">Print Essentials Bundled for the Way You Work</h2>
        <p>Choose a curated print package or request a custom kit built around your business, campaign, location, or event.</p>
      </div>
      <div class="chp-kit-grid">
        {%- liquid
          assign kits = 'starter|Starter Kit|Launch-ready print for new businesses.|Business cards, flyers, and artwork review.||growth|Growth Kit|A stronger package for local promotion.|Cards, flyers, door hangers, and add-on options.||custom|Custom Business Kit|Built around your campaign, location, or event.|Custom quantities, product mix, and production guidance.' | split: '||'
        -%}
        {%- for kit in kits -%}
          {%- liquid
            assign parts = kit | split: '|'
            assign kit_key = parts[0]
            assign kit_product = blank
            case kit_key
              when 'starter'
                assign kit_product = starter_kit_product
              when 'growth'
                assign kit_product = growth_kit_product
              when 'custom'
                assign kit_product = custom_kit_product
            endcase
            assign kit_url = kit_product.url
            if kit_key == 'custom' and kit_url == blank
              assign kit_url = custom_order_url
            elsif kit_url == blank
              assign kit_url = '/collections/business-kits'
            endif
          -%}
          <a class="chp-kit-card chp-reveal{% if kit_key == 'growth' %} chp-kit-card--featured{% endif %}" href="{{ kit_url }}" style="--chp-stagger: {{ forloop.index0 | times: 80 }}ms">
            {%- if kit_key == 'growth' -%}<span class="chp-marker">Featured</span>{%- endif -%}
            <h3>{{ kit_product.title | default: parts[1] }}</h3>
            <p>{{ parts[2] }}</p>
            <ul>
              <li>{{ parts[3] }}</li>
              <li>Shopify checkout or custom quote path.</li>
            </ul>
            {%- if kit_key == 'custom' and kit_product.price_min == 0 -%}
              <strong>Custom Quote</strong>
            {%- elsif kit_product != blank and kit_product.price_min > 0 -%}
              <strong>From {{ kit_product.price_min | money }}</strong>
            {%- else -%}
              <strong>View Details</strong>
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>
      <div class="chp-section-actions chp-reveal">
        <a class="chp-btn chp-btn--primary" href="{{ routes.collections_url }}/business-kits">View Business Kits<span aria-hidden="true">→</span></a>
        <a class="chp-btn chp-btn--secondary" href="#custom-order" data-chp-scroll>Build a Custom Kit<span aria-hidden="true">→</span></a>
        <a class="chp-progress-link" href="#clutch-nfc-card" data-chp-scroll>Explore the Clutch NFC Card<span aria-hidden="true">↓</span></a>
      </div>
    </div>
  </section>

  <section class="chp-section chp-nfc" id="clutch-nfc-card" aria-labelledby="chp-nfc-title">
    <div class="chp-shell chp-split">
      <div class="chp-copy chp-reveal">
        <p class="chp-eyebrow">THE CLUTCH NFC CARD</p>
        <h2 id="chp-nfc-title">One Card. Every Connection.</h2>
        <p>A premium matte-black NFC card that opens your Clutch Connect digital profile with a tap or QR scan. Share your contact details, links, services, and next steps without handing out another paper card.</p>
        <ul class="chp-feature-list">
          <li>Matte-black metal card</li>
          <li>NFC tap sharing</li>
          <li>QR backup</li>
          <li>Clutch Connect profile</li>
          <li>Guided setup after checkout</li>
          <li>Editable digital destination</li>
          <li>No app required</li>
          <li>Optional engraving where currently supported</li>
        </ul>
        <p class="chp-support-copy">Matte black · Guided setup included · No app required</p>
        <div class="chp-actions">
          <a class="chp-btn chp-btn--primary" href="{{ nfc_product.url | default: '/products/clutch-connect-card' }}">Shop the Clutch NFC Card<span aria-hidden="true">→</span></a>
          <a class="chp-btn chp-btn--secondary" href="#nfc-process" data-chp-scroll>See How It Works<span aria-hidden="true">→</span></a>
          <a class="chp-text-link" href="#clutch-connect" data-chp-scroll>Explore the Digital Profile</a>
        </div>
      </div>
      <div class="chp-nfc-visual chp-reveal" data-chp-depth>
        {%- if section.settings.nfc_card_front != blank and section.settings.nfc_card_back != blank -%}
          {{ section.settings.nfc_card_back | image_url: width: 900 | image_tag: widths: '360, 540, 720, 900', sizes: '(min-width: 990px) 34vw, 80vw', loading: 'lazy', class: 'chp-nfc-card chp-nfc-card--back', alt: section.settings.nfc_card_back.alt | default: 'Clutch NFC Card mockup behind' }}
          {{ section.settings.nfc_card_front | image_url: width: 900 | image_tag: widths: '360, 540, 720, 900', sizes: '(min-width: 990px) 34vw, 80vw', loading: 'lazy', class: 'chp-nfc-card chp-nfc-card--front', alt: section.settings.nfc_card_front.alt | default: 'Matte-black Clutch NFC Card mockup' }}
        {%- else -%}
          <img
            class="chp-nfc-card chp-nfc-card--back"
            src="{{ 'clutch-nfc-card-back.svg' | asset_url }}"
            alt="Clutch NFC Card back mockup"
            loading="lazy"
            width="900"
            height="540"
          >
          <img
            class="chp-nfc-card chp-nfc-card--front"
            src="{{ 'clutch-nfc-card-front.svg' | asset_url }}"
            alt="Matte-black Clutch NFC Card front mockup"
            loading="lazy"
            width="900"
            height="540"
          >
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="chp-section chp-process" id="nfc-process" aria-labelledby="chp-process-title">
    <div class="chp-shell">
      <div class="chp-section-head chp-reveal">
        <p class="chp-eyebrow">FROM CHECKOUT TO TAP-READY</p>
        <h2 id="chp-process-title">Simple to Order. Easy to Start Sharing.</h2>
      </div>
      <div class="chp-timeline" data-chp-timeline>
        <article class="chp-timeline__step chp-reveal"><span>1</span><h3>Order Your Card</h3><p>Choose the Clutch NFC Card and complete checkout through Shopify.</p></article>
        <article class="chp-timeline__step chp-reveal"><span>2</span><h3>Build Your Profile</h3><p>Follow the guided setup to add your contact information, links, branding, and lead actions.</p></article>
        <article class="chp-timeline__step chp-reveal"><span>3</span><h3>Start Sharing</h3><p>Tap the card against a compatible smartphone or scan the QR code to open your profile.</p></article>
      </div>
      <div class="chp-section-actions chp-reveal">
        <a class="chp-btn chp-btn--secondary" href="#clutch-connect" data-chp-scroll>Explore the Clutch Connect Profile<span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="chp-section chp-connect" id="clutch-connect" aria-labelledby="chp-connect-title">
    <div class="chp-shell chp-split chp-split--reverse">
      <div class="chp-connect-visual chp-reveal">
        {%- if section.settings.connect_profile_image != blank -%}
          {{ section.settings.connect_profile_image | image_url: width: 960 | image_tag: widths: '360, 540, 720, 960', sizes: '(min-width: 990px) 42vw, 92vw', loading: 'lazy', class: 'chp-connect-preview', alt: section.settings.connect_profile_image.alt | default: 'Clutch Connect digital profile preview' }}
        {%- else -%}
          <img
            class="chp-connect-preview"
            src="{{ 'clutch-connect-phone-mockup.svg' | asset_url }}"
            alt="Clutch Connect phone profile mockup"
            loading="lazy"
            width="810"
            height="1440"
          >
        {%- endif -%}
      </div>
      <div class="chp-copy chp-reveal">
        <p class="chp-eyebrow">CLUTCH CONNECT</p>
        <h2 id="chp-connect-title">Your Digital Profile, Built for Business</h2>
        <p>Create a professional profile where customers can save your contact information, visit your links, view your services, request a quote, and connect with your business.</p>
        <div class="chp-selector" role="list" aria-label="Clutch Connect profile features">
          {%- assign connect_features = 'Save Contact|Make it easy for customers to keep your information.||Lead Capture|Collect quote requests and follow-up details.||Social Links|Send visitors to the channels that matter.||Request a Quote|Give customers a clear next step.||Profile Builder|Shape your business profile with guided setup.' | split: '||' -%}
          {%- for feature in connect_features -%}
            {%- assign parts = feature | split: '|' -%}
            <button class="chp-selector__item" type="button" role="listitem" data-chp-feature>{{ parts[0] }}<span>{{ parts[1] }}</span></button>
          {%- endfor -%}
        </div>
        <div class="chp-actions">
          <a class="chp-btn chp-btn--primary" href="{{ connect_url }}">Explore Clutch Connect<span aria-hidden="true">→</span></a>
          <a class="chp-btn chp-btn--secondary" href="{{ nfc_product.url | default: '/products/clutch-connect-card' }}">Shop the Clutch NFC Card<span aria-hidden="true">→</span></a>
        </div>
        <a class="chp-progress-link" href="#business-kits" data-chp-scroll>Need a complete print setup? Explore Business Kits<span aria-hidden="true">↑</span></a>
      </div>
    </div>
  </section>

  <section class="chp-section chp-custom" id="custom-order" aria-labelledby="chp-custom-title">
    <div class="chp-shell chp-custom__inner">
      <div class="chp-copy chp-reveal">
        <p class="chp-eyebrow">CUSTOM PRINTING</p>
        <h2 id="chp-custom-title">Have a Specific Project in Mind?</h2>
        <p>Tell us what you are printing, the quantity, finished size, artwork status, and deadline. We will help you identify the right product and production approach.</p>
        <div class="chp-actions">
          <a class="chp-btn chp-btn--primary" href="{{ custom_order_url }}">Request a Custom Order<span aria-hidden="true">→</span></a>
          <a class="chp-btn chp-btn--secondary" href="#print-products" data-chp-scroll>Browse Print Products First<span aria-hidden="true">→</span></a>
        </div>
      </div>
      <div class="chp-planning chp-reveal">
        <div class="chp-prompt-grid">
          <span>Product type</span>
          <span>Quantity</span>
          <span>Finished size</span>
          <span>Needed-by date</span>
        </div>
        <details class="chp-details">
          <summary>What information should I include?</summary>
          <ul>
            <li>Product or format</li>
            <li>Quantity</li>
            <li>Size</li>
            <li>Single- or double-sided</li>
            <li>Artwork status</li>
            <li>Delivery deadline</li>
            <li>Any finishing requirements</li>
          </ul>
        </details>
      </div>
    </div>
  </section>

  <section class="chp-section chp-why" aria-labelledby="chp-why-title">
    <div class="chp-shell">
      <div class="chp-section-head chp-reveal">
        <p class="chp-eyebrow">WHY CLUTCH PRINT SHOP</p>
        <h2 id="chp-why-title">Professional Print With a Clearer Customer Journey</h2>
      </div>
      <div class="chp-trust-grid">
        {%- assign reasons = 'Professional Print Products|Practical print materials for marketing, sales, events, storefronts, and everyday business use.||Free Shipping|Straightforward ordering with free shipping according to the current store policy.||Custom Order Support|Guidance with product selection, quantities, artwork requirements, and production options.||Connected Business Tools|Use QR, NFC, and digital profiles when they support the goal of your campaign.' | split: '||' -%}
        {%- for reason in reasons -%}
          {%- assign parts = reason | split: '|' -%}
          <article class="chp-reason chp-reveal" style="--chp-stagger: {{ forloop.index0 | times: 80 }}ms">
            <h3>{{ parts[0] }}</h3>
            <p>{{ parts[1] }}</p>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="chp-section chp-faq" aria-labelledby="chp-faq-title">
    <div class="chp-shell">
      <div class="chp-section-head chp-reveal">
        <p class="chp-eyebrow">FAQ</p>
        <h2 id="chp-faq-title">Questions Before You Print?</h2>
      </div>
      <div class="chp-faq-list">
        {%- assign fallback_faqs = 'What print products do you offer?|Clutch Print Shop offers business cards, flyers, door hangers, yard signs, postcards, brochures, banners, Business Kits, and other products currently available in the store.||Can I request a product that is not listed?|Yes. Use the Custom Order form to provide the product type, size, quantity, artwork details, and deadline.||What artwork should I provide?|Upload high-resolution, print-ready artwork according to the current File Upload Requirements.||Is shipping included?|Free shipping is available according to the current Clutch Print Shop shipping policy.||What are Business Kits?|Business Kits bundle multiple print products into one coordinated package for a business, campaign, location, or event.||What is the Clutch NFC Card?|The Clutch NFC Card is a matte-black metal card that opens a digital profile through an NFC tap or QR scan.||Is the Clutch NFC Card the same as a printed business card?|No. Traditional business cards are printed paper products. The Clutch NFC Card is a reusable metal card connected to a digital destination.||What is Clutch Connect?|Clutch Connect is the digital-profile experience used to share contact information, business links, services, lead actions, and other details.||Do customers need an app?|No. The digital profile opens in the phone’s browser.||Can I update the profile later?|Yes. Profile information and links can be updated without replacing the physical NFC card.||Is guided setup included?|The current onboarding process provides setup guidance after checkout for the Clutch NFC Card and connected profile.||Is engraving available?|Optional engraving may be selected where supported by the current Clutch NFC Card product configuration.' | split: '||' -%}
        {%- for item in fallback_faqs -%}
          {%- assign parts = item | split: '|' -%}
          <details class="chp-faq-item chp-reveal">
            <summary>{{ parts[0] }}</summary>
            <p>{{ parts[1] }}{%- if parts[0] == 'What artwork should I provide?' -%} <a href="{{ upload_url }}">View file requirements</a>.{%- endif -%}</p>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="chp-final" aria-labelledby="chp-final-title">
    <div class="chp-shell chp-final__inner chp-reveal">
      <p class="chp-eyebrow">READY TO GET STARTED?</p>
      <h2 id="chp-final-title">Put Your Business in Front of More Customers</h2>
      <p>Shop professional print products, choose a ready-to-go Business Kit, or request a custom solution built around your next campaign.</p>
      <div class="chp-actions">
        <a class="chp-btn chp-btn--dark" href="{{ print_collection.url | default: '/collections/all' }}">Shop Print Products<span aria-hidden="true">→</span></a>
        <a class="chp-btn chp-btn--secondary" href="{{ routes.collections_url }}/business-kits">View Business Kits<span aria-hidden="true">→</span></a>
        <a class="chp-btn chp-btn--secondary" href="{{ custom_order_url }}">Request a Custom Order<span aria-hidden="true">→</span></a>
      </div>
      <a class="chp-text-link" href="{{ nfc_product.url | default: '/products/clutch-connect-card' }}">Looking for one reusable card? Shop the Clutch NFC Card</a>
    </div>
  </section>
</main>

{% stylesheet %}
  .chp-home {
    --chp-navy: #384862;
    --chp-orange: #FFA665;
    --chp-white: #FFFFFF;
    --chp-dark: #071D33;
    --chp-soft: #F4F7FA;
    --chp-muted: #66758C;
    --chp-border: #DDE6EF;
    background: var(--chp-soft);
    color: var(--chp-dark);
    font-family: 'Montserrat', sans-serif;
    overflow-x: clip;
    scroll-behavior: smooth;
  }

  .chp-home *,
  .chp-home *::before,
  .chp-home *::after {
    box-sizing: border-box;
  }

  .chp-shell {
    margin-inline: auto;
    max-width: 1240px;
    padding-inline: clamp(1rem, 4vw, 2.5rem);
    width: 100%;
  }

  .chp-section {
    padding-block: clamp(3.5rem, 7vw, 6.25rem);
  }

  .chp-eyebrow {
    color: var(--chp-orange);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    line-height: 1.2;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  .chp-home h1,
  .chp-home h2,
  .chp-home h3 {
    color: var(--chp-dark);
    font-family: 'Exo 2', sans-serif;
    letter-spacing: -0.025em;
    line-height: 1;
    margin: 0;
  }

  .chp-home p {
    color: var(--chp-muted);
    line-height: 1.65;
    margin: 0;
  }

  .chp-section-head {
    display: grid;
    gap: 0.85rem;
    margin: 0 auto clamp(1.6rem, 4vw, 3rem);
    max-width: 820px;
    text-align: center;
  }

  .chp-section-head h2,
  .chp-copy h2,
  .chp-final h2 {
    font-size: clamp(2rem, 4.8vw, 3.75rem);
    text-wrap: balance;
  }

  .chp-section-head p,
  .chp-copy > p,
  .chp-final p {
    font-size: clamp(0.98rem, 1.45vw, 1.08rem);
  }

  .chp-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .chp-btn,
  .chp-text-link,
  .chp-progress-link,
  .chp-scroll-cue {
    align-items: center;
    border-radius: 12px;
    display: inline-flex;
    font-weight: 900;
    gap: 0.35rem;
    justify-content: center;
    min-height: 48px;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .chp-btn {
    padding: 0.9rem 1.3rem;
  }

  .chp-btn span,
  .chp-text-link span,
  .chp-progress-link span {
    transition: transform 0.2s ease;
  }

  .chp-btn:hover,
  .chp-text-link:hover,
  .chp-progress-link:hover {
    transform: translateY(-2px);
  }

  .chp-btn:hover span,
  .chp-text-link:hover span,
  .chp-progress-link:hover span {
    transform: translateX(5px);
  }

  .chp-btn:focus-visible,
  .chp-text-link:focus-visible,
  .chp-progress-link:focus-visible,
  .chp-scroll-cue:focus-visible,
  .chp-selector__item:focus-visible,
  .chp-faq-item summary:focus-visible {
    outline: 3px solid rgba(255, 166, 101, 0.7);
    outline-offset: 3px;
  }

  .chp-btn--primary {
    background: var(--chp-orange);
    box-shadow: 0 16px 32px rgba(255, 166, 101, 0.28);
    color: var(--chp-dark);
  }

  .chp-btn--secondary {
    background: var(--chp-white);
    border: 1px solid var(--chp-border);
    color: var(--chp-navy);
  }

  .chp-btn--dark {
    background: var(--chp-dark);
    color: var(--chp-white);
  }

  .chp-text-link,
  .chp-progress-link {
    color: var(--chp-navy);
    min-height: 44px;
    padding: 0.2rem;
  }

  .chp-card,
  .chp-product-card,
  .chp-kit-card,
  .chp-reason,
  .chp-use-card,
  .chp-product-spotlight,
  .chp-timeline__step,
  .chp-faq-item {
    background: var(--chp-white);
    border: 1px solid var(--chp-border);
    border-radius: 20px;
    box-shadow: 0 16px 36px rgba(7, 29, 51, 0.07);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .chp-product-card:hover,
  .chp-kit-card:hover,
  .chp-use-card:hover,
  .chp-reason:hover,
  .chp-product-spotlight:hover {
    border-color: rgba(255, 166, 101, 0.62);
    box-shadow: 0 24px 54px rgba(7, 29, 51, 0.12);
    transform: translateY(-4px);
  }

  .chp-hero {
    background:
      radial-gradient(circle at 14% 18%, rgba(255, 166, 101, 0.2), transparent 28%),
      linear-gradient(180deg, #ffffff 0%, #f4f7fa 100%);
    padding-block: clamp(5.5rem, 8vw, 7rem) clamp(3rem, 5vw, 4.5rem);
  }

  .chp-hero__grid,
  .chp-split {
    align-items: center;
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    grid-template-columns: minmax(0, 1fr);
  }

  .chp-hero__copy {
    display: grid;
    gap: 1rem;
  }

  .chp-hero h1 {
    font-size: clamp(2.85rem, 7vw, 6rem);
    max-width: 760px;
    text-wrap: balance;
  }

  .chp-hero__copy > p:not(.chp-eyebrow):not(.chp-trust) {
    font-size: clamp(1rem, 1.5vw, 1.16rem);
    max-width: 710px;
  }

  .chp-trust {
    color: var(--chp-navy);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .chp-scroll-cue {
    color: var(--chp-muted);
    justify-self: start;
    margin-top: 0.25rem;
    min-height: 44px;
  }

  .chp-hero__visual {
    min-width: 0;
    position: relative;
  }

  .chp-hero__image {
    border-radius: 26px;
    box-shadow: 0 24px 64px rgba(7, 29, 51, 0.16);
    display: block;
    height: auto;
    object-fit: contain;
    width: 100%;
  }

  .chp-print-stack {
    display: grid;
    gap: 0.8rem;
    transform-style: preserve-3d;
  }

  .chp-print-stack span {
    background: var(--chp-white);
    border: 1px solid var(--chp-border);
    border-radius: 18px;
    box-shadow: 0 18px 42px rgba(7, 29, 51, 0.1);
    color: var(--chp-navy);
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1.05rem, 2vw, 1.45rem);
    font-weight: 900;
    padding: 1.1rem 1.2rem;
  }

  .chp-print-stack span:nth-child(2n) {
    transform: translateX(7%);
  }

  .chp-product-rail {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  }

  .chp-product-card {
    display: grid;
    gap: 0.9rem;
    overflow: hidden;
    padding: 0.8rem;
  }

  .chp-product-card__media {
    align-items: center;
    aspect-ratio: 4 / 3;
    background: linear-gradient(145deg, #ffffff, #eef3f8);
    border: 1px solid var(--chp-border);
    border-radius: 16px;
    display: grid;
    justify-items: center;
    overflow: hidden;
  }

  .chp-product-card__media img {
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease;
    width: 100%;
  }

  .chp-product-card:hover img {
    transform: scale(1.02);
  }

  .chp-product-card__media span {
    color: rgba(56, 72, 98, 0.24);
    font-family: 'Exo 2', sans-serif;
    font-size: 2.6rem;
    font-weight: 900;
  }

  .chp-product-card__body {
    display: grid;
    gap: 0.45rem;
    padding: 0 0.15rem 0.25rem;
  }

  .chp-product-card strong,
  .chp-kit-card h3,
  .chp-product-spotlight h3,
  .chp-use-card h3,
  .chp-reason h3,
  .chp-timeline__step h3 {
    color: var(--chp-dark);
    font-family: 'Exo 2', sans-serif;
    font-size: 1.25rem;
    line-height: 1.1;
  }

  .chp-product-card em {
    color: var(--chp-orange);
    font-style: normal;
    font-weight: 900;
    margin-top: 0.2rem;
  }

  .chp-section-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
    margin-top: clamp(1.4rem, 3vw, 2.2rem);
  }

  .chp-split {
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
  }

  .chp-split--reverse {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  }

  .chp-copy {
    display: grid;
    gap: 1rem;
  }

  .chp-track,
  .chp-kits,
  .chp-connect,
  .chp-why {
    background: var(--chp-white);
  }

  .chp-flow {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .chp-flow span,
  .chp-prompt-grid span {
    background: rgba(255, 166, 101, 0.12);
    border: 1px solid rgba(255, 166, 101, 0.28);
    border-radius: 14px;
    color: var(--chp-navy);
    font-size: 0.82rem;
    font-weight: 900;
    padding: 0.75rem;
    text-align: center;
  }

  .chp-use-grid,
  .chp-kit-grid,
  .chp-trust-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .chp-use-card,
  .chp-reason,
  .chp-timeline__step {
    padding: 1.15rem;
  }

  .chp-use-card strong {
    color: var(--chp-orange);
    display: block;
    margin-top: 0.8rem;
  }

  .chp-business-card {
    background: linear-gradient(180deg, #f4f7fa, #ffffff);
  }

  .chp-product-spotlight {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  .chp-product-spotlight__media {
    align-items: center;
    aspect-ratio: 4 / 3;
    background: linear-gradient(145deg, #fff, #edf3f8);
    border-radius: 18px;
    display: grid;
    justify-items: center;
    overflow: hidden;
  }

  .chp-product-spotlight__media img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .chp-product-spotlight__media span {
    color: rgba(56, 72, 98, 0.28);
    font-family: 'Exo 2', sans-serif;
    font-size: 2rem;
    font-weight: 900;
  }

  .chp-price {
    color: var(--chp-navy);
    font-weight: 900;
    margin-top: 0.35rem;
  }

  .chp-kit-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .chp-kit-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.2rem;
  }

  .chp-kit-card--featured {
    border-color: rgba(255, 166, 101, 0.58);
    box-shadow: 0 24px 54px rgba(255, 166, 101, 0.16);
  }

  .chp-marker {
    background: var(--chp-dark);
    border-radius: 999px;
    color: var(--chp-white);
    font-size: 0.68rem;
    font-weight: 900;
    padding: 0.36rem 0.58rem;
    width: fit-content;
  }

  .chp-kit-card ul,
  .chp-feature-list,
  .chp-details ul {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .chp-kit-card li,
  .chp-feature-list li,
  .chp-details li {
    color: var(--chp-navy);
    display: grid;
    gap: 0.55rem;
    grid-template-columns: 18px 1fr;
    line-height: 1.45;
  }

  .chp-kit-card li::before,
  .chp-feature-list li::before,
  .chp-details li::before {
    color: var(--chp-orange);
    content: '✓';
    font-weight: 900;
  }

  .chp-kit-card > strong {
    color: var(--chp-dark);
    font-family: 'Exo 2', sans-serif;
    font-size: 1.35rem;
  }

  .chp-nfc {
    background: radial-gradient(circle at 80% 20%, rgba(255, 166, 101, 0.18), transparent 28%), linear-gradient(145deg, var(--chp-dark), var(--chp-navy));
  }

  .chp-nfc .chp-copy h2,
  .chp-nfc .chp-copy p,
  .chp-nfc .chp-feature-list li,
  .chp-nfc .chp-support-copy {
    color: var(--chp-white);
  }

  .chp-nfc .chp-copy > p,
  .chp-nfc .chp-support-copy {
    color: rgba(255, 255, 255, 0.78);
  }

  .chp-nfc-visual,
  .chp-connect-visual {
    align-items: center;
    display: grid;
    min-height: 320px;
    position: relative;
  }

  .chp-nfc-card {
    display: block;
    height: auto;
    object-fit: contain;
    transition: filter 0.2s ease, transform 0.2s ease;
    width: min(82vw, 520px);
  }

  .chp-nfc-card--back {
    filter: drop-shadow(0 18px 40px rgba(0, 0, 0, 0.26));
    justify-self: end;
    opacity: 0.92;
    transform: translate(-8%, 7%) scale(0.92);
  }

  .chp-nfc-card--front {
    filter: drop-shadow(0 24px 50px rgba(0, 0, 0, 0.32));
    grid-area: 1 / 1;
    justify-self: center;
    transform: translate(6%, -4%);
    z-index: 2;
  }

  .chp-nfc-visual:hover .chp-nfc-card--front {
    transform: translate(6%, -5%) scale(1.01);
  }

  .chp-asset-slot {
    background: rgba(255, 255, 255, 0.9);
    border: 1px dashed rgba(56, 72, 98, 0.28);
    border-radius: 24px;
    color: var(--chp-navy);
    display: grid;
    gap: 0.5rem;
    justify-items: center;
    padding: 2rem;
    text-align: center;
  }

  .chp-asset-slot strong {
    color: var(--chp-dark);
    font-family: 'Exo 2', sans-serif;
    font-size: 1.4rem;
  }

  .chp-timeline {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    position: relative;
  }

  .chp-timeline::before {
    background: linear-gradient(90deg, var(--chp-orange), rgba(255, 166, 101, 0.18));
    content: '';
    height: 3px;
    left: 16%;
    position: absolute;
    right: 16%;
    top: 36px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.8s ease;
  }

  .chp-timeline.is-visible::before {
    transform: scaleX(1);
  }

  .chp-timeline__step {
    position: relative;
    z-index: 1;
  }

  .chp-timeline__step span {
    align-items: center;
    background: var(--chp-orange);
    border-radius: 50%;
    color: var(--chp-dark);
    display: inline-flex;
    font-weight: 900;
    height: 44px;
    justify-content: center;
    margin-bottom: 1rem;
    width: 44px;
  }

  .chp-connect-preview {
    border-radius: 26px;
    display: block;
    height: auto;
    object-fit: contain;
    width: 100%;
  }

  .chp-selector {
    display: grid;
    gap: 0.65rem;
  }

  .chp-selector__item {
    background: var(--chp-white);
    border: 1px solid var(--chp-border);
    border-radius: 16px;
    color: var(--chp-dark);
    cursor: pointer;
    display: grid;
    font: inherit;
    font-weight: 900;
    gap: 0.25rem;
    min-height: 56px;
    padding: 0.85rem;
    text-align: left;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .chp-selector__item span {
    color: var(--chp-muted);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .chp-selector__item:hover,
  .chp-selector__item.is-active {
    border-color: rgba(255, 166, 101, 0.62);
    box-shadow: 0 14px 30px rgba(255, 166, 101, 0.14);
    transform: translateY(-2px);
  }

  .chp-custom {
    background: linear-gradient(145deg, var(--chp-dark), var(--chp-navy));
  }

  .chp-custom h2,
  .chp-custom p,
  .chp-custom .chp-prompt-grid span,
  .chp-custom .chp-details,
  .chp-custom .chp-details li {
    color: var(--chp-white);
  }

  .chp-custom .chp-copy > p {
    color: rgba(255, 255, 255, 0.78);
  }

  .chp-custom__inner {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
  }

  .chp-prompt-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .chp-custom .chp-prompt-grid span {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .chp-details {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 18px;
    margin-top: 1rem;
    padding: 1rem;
  }

  .chp-details summary {
    cursor: pointer;
    font-weight: 900;
  }

  .chp-details ul {
    margin-top: 0.8rem;
  }

  .chp-trust-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .chp-reason {
    padding: 1.15rem;
  }

  .chp-faq-list {
    display: grid;
    gap: 0.75rem;
    margin: 0 auto;
    max-width: 900px;
  }

  .chp-faq-item {
    padding: 0;
  }

  .chp-faq-item summary {
    cursor: pointer;
    font-family: 'Exo 2', sans-serif;
    font-size: 1.1rem;
    font-weight: 900;
    list-style: none;
    padding: 1rem 1.15rem;
  }

  .chp-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .chp-faq-item p {
    border-top: 1px solid var(--chp-border);
    padding: 1rem 1.15rem 1.15rem;
  }

  .chp-faq-item a {
    color: var(--chp-navy);
    font-weight: 900;
  }

  .chp-final {
    background: linear-gradient(180deg, #fff7f0, var(--chp-white));
    padding-block: clamp(3.5rem, 7vw, 5.5rem);
  }

  .chp-final__inner {
    display: grid;
    gap: 1rem;
    justify-items: center;
    max-width: 920px;
    text-align: center;
  }

  .chp-reveal {
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    transition: opacity 0.62s ease, transform 0.62s ease;
    transition-delay: var(--chp-stagger, 0ms);
  }

  .chp-reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .chp-highlight {
    animation: chpHighlight 1.2s ease;
  }

  @keyframes chpHighlight {
    0% { box-shadow: 0 0 0 rgba(255, 166, 101, 0); }
    35% { box-shadow: 0 0 0 6px rgba(255, 166, 101, 0.22); }
    100% { box-shadow: 0 0 0 rgba(255, 166, 101, 0); }
  }

  @media screen and (min-width: 990px) {
    .chp-hero__grid {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    }
  }

  @media screen and (max-width: 989px) {
    .chp-split,
    .chp-split--reverse,
    .chp-custom__inner {
      grid-template-columns: 1fr;
    }

    .chp-flow,
    .chp-trust-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .chp-kit-grid,
    .chp-timeline {
      grid-template-columns: 1fr;
    }

    .chp-timeline::before {
      bottom: 12%;
      height: auto;
      left: 22px;
      right: auto;
      top: 44px;
      transform: scaleY(0);
      width: 3px;
    }

    .chp-timeline.is-visible::before {
      transform: scaleY(1);
    }
  }

  @media screen and (max-width: 720px) {
    .chp-hero {
      padding-top: 5.25rem;
    }

    .chp-hero h1 {
      font-size: clamp(2.65rem, 13vw, 4rem);
    }

    .chp-product-rail {
      display: flex;
      margin-inline: calc(clamp(1rem, 4vw, 2.5rem) * -1);
      overflow-x: auto;
      padding-inline: clamp(1rem, 4vw, 2.5rem);
      scroll-snap-type: x mandatory;
    }

    .chp-product-card {
      flex: 0 0 min(78vw, 310px);
      scroll-snap-align: start;
    }

    .chp-use-grid,
    .chp-trust-grid,
    .chp-flow,
    .chp-prompt-grid {
      grid-template-columns: 1fr;
    }

    .chp-actions,
    .chp-actions .chp-btn {
      width: 100%;
    }

    .chp-nfc-card {
      width: min(88vw, 440px);
    }

    .chp-nfc-card--back,
    .chp-nfc-card--front {
      grid-area: auto;
      justify-self: center;
      transform: none;
    }

    .chp-nfc-visual {
      gap: 0.8rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chp-home {
      scroll-behavior: auto;
    }

    .chp-reveal,
    .chp-reveal.is-visible {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }

    .chp-timeline::before {
      transform: none !important;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const root = document.querySelector('[data-chp-home]');
    if (!root) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealItems = root.querySelectorAll('.chp-reveal');
    const timeline = root.querySelector('[data-chp-timeline]');

    if (reducedMotion) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
      if (timeline) timeline.classList.add('is-visible');
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          if (entry.target === timeline) entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });

      revealItems.forEach((item) => observer.observe(item));
      if (timeline) observer.observe(timeline);
    }

    root.querySelectorAll('[data-chp-scroll]').forEach((link) => {
      link.addEventListener('click', (event) => {
        const targetId = link.getAttribute('href');
        if (!targetId || !targetId.startsWith('#')) return;
        const target = root.querySelector(targetId);
        if (!target) return;
        event.preventDefault();
        target.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
        target.classList.remove('chp-highlight');
        window.setTimeout(() => target.classList.add('chp-highlight'), 80);
      });
    });

    root.querySelectorAll('[data-chp-feature]').forEach((button) => {
      button.addEventListener('click', () => {
        root.querySelectorAll('[data-chp-feature]').forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
      });
      button.addEventListener('mouseenter', () => {
        root.querySelectorAll('[data-chp-feature]').forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
      });
    });

    if (!reducedMotion) {
      root.querySelectorAll('[data-chp-depth]').forEach((panel) => {
        panel.addEventListener('pointermove', (event) => {
          if (window.innerWidth < 990) return;
          const rect = panel.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          panel.style.setProperty('--depth-x', `${x * 10}px`);
          panel.style.setProperty('--depth-y', `${y * 10}px`);
        });
        panel.addEventListener('pointerleave', () => {
          panel.style.removeProperty('--depth-x');
          panel.style.removeProperty('--depth-y');
        });
      });
    }
  })();
</script>

