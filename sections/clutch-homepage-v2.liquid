{%- liquid
  assign print_collection = section.settings.print_collection
  if print_collection == blank
    assign print_collection = collections.all
  endif

  assign kits_collection = section.settings.kits_collection
  assign kits_url = '/collections/business-kits'
  if kits_collection != blank
    assign kits_url = kits_collection.url
  endif

  assign business_cards_product = section.settings.business_cards_product
  if business_cards_product == blank
    assign business_cards_product = all_products['business-cards']
  endif

  assign starter_kit_product = section.settings.starter_kit_product
  if starter_kit_product == blank
    assign starter_kit_product = all_products['startup-kit']
  endif

  assign growth_kit_product = section.settings.growth_kit_product
  if growth_kit_product == blank
    assign growth_kit_product = all_products['growth-kit']
  endif

  assign nfc_product = section.settings.nfc_product
  if nfc_product == blank
    assign nfc_product = all_products['clutch-connect-card']
  endif

  assign custom_order_url = '/pages/contact'
  if section.settings.custom_order_page != blank
    assign custom_order_url = section.settings.custom_order_page.url
  endif

  assign clutch_codes_url = '/pages/qr-pro'
  if section.settings.clutch_codes_page != blank
    assign clutch_codes_url = section.settings.clutch_codes_page.url
  endif

  assign connect_url = section.settings.clutch_connect_preview_link
  if section.settings.connect_page != blank
    assign connect_url = section.settings.connect_page.url
  endif

  assign artwork_url = '/pages/file-upload-requirements'
  if section.settings.artwork_page != blank
    assign artwork_url = section.settings.artwork_page.url
  endif
-%}

<main class="clutch-home" data-clutch-home>
  <section class="clutch-home__section clutch-hero" aria-labelledby="clutch-hero-title">
    <div class="clutch-shell clutch-hero__layout">
      <div class="clutch-hero__copy clutch-reveal">
        <p class="clutch-eyebrow">PROFESSIONAL PRINT WITH BUILT-IN MARKETING TOOLS</p>
        <h1 id="clutch-hero-title">Print Smarter with Trackable Results</h1>
        <p class="clutch-lead">Order professional print, create trackable customer journeys, and manage your campaigns with Clutch Codes™ and Clutch Connect.</p>
        <div class="clutch-actions">
          <a class="clutch-button clutch-button--primary" href="{{ print_collection.url | default: '/collections/all' }}">Shop Print Products</a>
          <a class="clutch-button clutch-button--secondary" href="#how-tracking-works">See How Tracking Works</a>
        </div>
        <a class="clutch-inline-link" href="{{ custom_order_url }}">Request a Custom Order <span aria-hidden="true">→</span></a>
      </div>

      <div class="clutch-hero__visual clutch-reveal" aria-label="Printed marketing connected to a digital destination and scan activity">
        <div class="clutch-hero__print">
          {%- if section.settings.hero_print_image != blank -%}
            <picture class="clutch-hero__configured-media">
              {%- if section.settings.hero_print_image_mobile != blank -%}
                <source media="(max-width: 767px)" srcset="{{ section.settings.hero_print_image_mobile | image_url: width: 900 }}">
              {%- endif -%}
              {{ section.settings.hero_print_image | image_url: width: 1200 | image_tag: widths: '480, 720, 960, 1200', sizes: '(min-width: 1024px) 34vw, 62vw', loading: 'eager', fetchpriority: 'high', alt: section.settings.hero_print_image_alt }}
            </picture>
          {%- else -%}
            <span class="clutch-hero__print-mark">CLUTCH</span>
            <span class="clutch-hero__print-title">Make every impression count.</span>
            <span class="clutch-hero__code-badge">Dynamic Clutch Code</span>
            <small>Editable destination · Demo workflow</small>
          {%- endif -%}
        </div>
        <span class="clutch-hero__connector" aria-hidden="true">→</span>
        <div class="clutch-hero__phone">
          {%- if section.settings.hero_destination_image != blank -%}
            <picture class="clutch-hero__configured-media">
              {%- if section.settings.hero_destination_image_mobile != blank -%}
                <source media="(max-width: 767px)" srcset="{{ section.settings.hero_destination_image_mobile | image_url: width: 600 }}">
              {%- endif -%}
              {{ section.settings.hero_destination_image | image_url: width: 800 | image_tag: widths: '320, 480, 640, 800', sizes: '(min-width: 1024px) 17vw, 38vw', loading: 'eager', alt: section.settings.hero_destination_image_alt }}
            </picture>
          {%- else -%}
            <span class="clutch-hero__phone-bar" aria-hidden="true"></span>
            <span class="clutch-hero__phone-logo" aria-hidden="true">C</span>
            <strong>Campaign destination</strong>
            <span class="clutch-hero__phone-detail">Website, offer, booking page, or profile</span>
            <span class="clutch-hero__phone-action">Connected experience</span>
          {%- endif -%}
        </div>
        <div class="clutch-hero__analytics">
          {%- if section.settings.hero_analytics_image != blank -%}
            <picture class="clutch-hero__configured-media">
              {%- if section.settings.hero_analytics_image_mobile != blank -%}
                <source media="(max-width: 767px)" srcset="{{ section.settings.hero_analytics_image_mobile | image_url: width: 700 }}">
              {%- endif -%}
              {{ section.settings.hero_analytics_image | image_url: width: 900 | image_tag: widths: '360, 540, 720, 900', sizes: '(min-width: 1024px) 23vw, 52vw', loading: 'eager', alt: section.settings.hero_analytics_image_alt }}
            </picture>
          {%- else -%}
            <span>Scan Activity</span>
            <strong>Demo</strong>
            <i></i><i></i><i></i><i></i>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <section class="clutch-home__section clutch-shop-needs" aria-labelledby="clutch-needs-title">
    <div class="clutch-shell">
      <header class="clutch-section-heading clutch-reveal">
        <h2 id="clutch-needs-title">Everything Your Business Needs to Get Noticed</h2>
      </header>
      <div class="clutch-needs-grid" role="list">
        <a class="clutch-need-card clutch-reveal" href="{{ print_collection.url | default: '/collections/all' }}" role="listitem" style="--reveal-delay: 0ms">
          <span class="clutch-need-card__media">
            {%- if business_cards_product.featured_image != blank -%}
              {{ business_cards_product.featured_image | image_url: width: 720 | image_tag: widths: '320, 480, 720', sizes: '(min-width: 1024px) 25vw, (min-width: 640px) 46vw, 82vw', loading: 'lazy', alt: business_cards_product.featured_image.alt | default: 'Professional print products from Clutch Print Shop' }}
            {%- else -%}
              <span class="clutch-media-placeholder" aria-hidden="true">PRINT</span>
            {%- endif -%}
          </span>
          <span class="clutch-need-card__body"><span class="clutch-card-number">01</span><strong>Print Products</strong><span>Business cards, flyers, postcards, signs, banners, and other essentials.</span><em>Shop Print Products <span aria-hidden="true">→</span></em></span>
        </a>

        <a class="clutch-need-card clutch-reveal" href="{{ kits_url }}" role="listitem" style="--reveal-delay: 80ms">
          <span class="clutch-need-card__media clutch-need-card__media--kits">
            {%- if starter_kit_product.featured_image != blank -%}
              {{ starter_kit_product.featured_image | image_url: width: 720 | image_tag: widths: '320, 480, 720', sizes: '(min-width: 1024px) 25vw, (min-width: 640px) 46vw, 82vw', loading: 'lazy', alt: starter_kit_product.featured_image.alt | default: 'Clutch Print Shop Business Kit' }}
            {%- else -%}
              <span class="clutch-media-placeholder" aria-hidden="true">KITS</span>
            {%- endif -%}
          </span>
          <span class="clutch-need-card__body"><span class="clutch-card-number">02</span><strong>Business Kits</strong><span>Coordinated print products bundled for launches, campaigns, and local marketing.</span><em>Explore Business Kits <span aria-hidden="true">→</span></em></span>
        </a>

        <a class="clutch-need-card clutch-reveal" href="{{ clutch_codes_url }}" role="listitem" style="--reveal-delay: 160ms">
          <span class="clutch-need-card__media clutch-need-card__media--codes">
            <span class="clutch-code-card-mini" aria-hidden="true"><b>CLUTCH CODES™</b><i>Dynamic destination</i><small>Demo analytics</small></span>
          </span>
          <span class="clutch-need-card__body"><span class="clutch-card-number">03</span><strong>Clutch Codes™</strong><span>Dynamic QR campaigns with editable destinations and clearly labeled scan insights.</span><em>Explore Clutch Codes™ <span aria-hidden="true">→</span></em></span>
        </a>

        <a class="clutch-need-card clutch-reveal" href="{{ nfc_product.url | default: '/products/clutch-connect-card' }}" role="listitem" style="--reveal-delay: 240ms">
          <span class="clutch-need-card__media clutch-need-card__media--dark">
            {%- if nfc_product.featured_image != blank -%}
              {{ nfc_product.featured_image | image_url: width: 720 | image_tag: widths: '320, 480, 720', sizes: '(min-width: 1024px) 25vw, (min-width: 640px) 46vw, 82vw', loading: 'lazy', alt: nfc_product.featured_image.alt | default: 'Clutch NFC Card' }}
            {%- else -%}
              <span class="clutch-nfc-mini" aria-hidden="true"><b>CLUTCH</b><i></i><small>NFC + QR</small></span>
            {%- endif -%}
          </span>
          <span class="clutch-need-card__body"><span class="clutch-card-number">04</span><strong>Clutch NFC Card</strong><span>One reusable metal card connected to your editable digital profile.</span><em>Explore the Clutch NFC Card <span aria-hidden="true">→</span></em></span>
        </a>

        <a class="clutch-need-card clutch-reveal" href="{{ custom_order_url }}" role="listitem" style="--reveal-delay: 320ms">
          <span class="clutch-need-card__media clutch-need-card__media--custom" aria-hidden="true">
            <span class="clutch-custom-stack"><i></i><i></i><i></i><b>YOUR IDEA</b></span>
          </span>
          <span class="clutch-need-card__body"><span class="clutch-card-number">05</span><strong>Custom Orders</strong><span>Custom products, quantities, sizes, artwork, and business packages.</span><em>Request a Custom Order <span aria-hidden="true">→</span></em></span>
        </a>
      </div>
    </div>
  </section>

  <section class="clutch-home__section clutch-tracking" id="how-tracking-works" aria-labelledby="clutch-tracking-title">
    <div class="clutch-shell">
      <header class="clutch-section-heading clutch-section-heading--light clutch-reveal">
        <p class="clutch-eyebrow">SEE HOW IT WORKS</p>
        <h2 id="clutch-tracking-title">Turn Printed Marketing Into a Measurable Customer Journey</h2>
      </header>
      {% render 'clutch-code-demo' %}
      <div class="clutch-tracking__footer clutch-reveal">
        <ul class="clutch-check-list">
          <li>Change where the code sends customers</li>
          <li>Measure scans and engagement</li>
          <li>Use one code for one clear campaign</li>
          <li>Manage connected experiences after checkout</li>
        </ul>
        <a class="clutch-button clutch-button--primary" href="{{ clutch_codes_url }}">Explore Clutch Codes™</a>
      </div>
    </div>
  </section>

  <section class="clutch-home__section clutch-kits" aria-labelledby="clutch-kits-title">
    <div class="clutch-shell clutch-kits__layout">
      <header class="clutch-section-heading clutch-section-heading--left clutch-reveal">
        <p class="clutch-eyebrow">READY-TO-GO BUSINESS KITS</p>
        <h2 id="clutch-kits-title">Launch With the Print Essentials Already Bundled</h2>
        <p>Choose a focused starting point, then review current products, quantities, and pricing in Shopify.</p>
        <div class="clutch-actions">
          <a class="clutch-button clutch-button--primary" href="{{ kits_url }}">Explore Business Kits</a>
          <a class="clutch-button clutch-button--secondary" href="{{ custom_order_url }}">Build a Custom Kit</a>
        </div>
      </header>
      <div class="clutch-kit-list" role="list">
        <a class="clutch-kit-row clutch-reveal" href="{{ starter_kit_product.url | default: kits_url }}" role="listitem" style="--reveal-delay: 0ms"><span>01</span><strong>{{ starter_kit_product.title | default: 'Starter Kit' }}</strong><small>A clear set of essentials for getting your business into market.</small><i aria-hidden="true">→</i></a>
        <a class="clutch-kit-row clutch-reveal" href="{{ growth_kit_product.url | default: kits_url }}" role="listitem" style="--reveal-delay: 80ms"><span>02</span><strong>{{ growth_kit_product.title | default: 'Growth Kit' }}</strong><small>More coordinated print for active local marketing and outreach.</small><i aria-hidden="true">→</i></a>
        <a class="clutch-kit-row clutch-reveal" href="{{ custom_order_url }}" role="listitem" style="--reveal-delay: 160ms"><span>03</span><strong>Custom Kit</strong><small>A tailored mix of products, quantities, sizes, and artwork support.</small><i aria-hidden="true">→</i></a>
      </div>
    </div>
  </section>

  <section class="clutch-home__section clutch-nfc" aria-labelledby="clutch-nfc-title">
    <div class="clutch-shell clutch-nfc__layout">
      <div class="clutch-nfc__visual clutch-reveal" aria-label="Clutch NFC Card connected to a Clutch Connect profile">
        <div class="clutch-nfc__tap" aria-hidden="true"><i></i><i></i><i></i></div>
        <div class="clutch-nfc__card">
          <span>CLUTCH</span>
          <small>NFC</small>
          <span class="clutch-demo-qr clutch-demo-qr--small" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span>
        </div>
        <div class="clutch-nfc__phone" aria-hidden="true">
          <span class="clutch-nfc__avatar">C</span>
          <strong>Clutch Connect</strong>
          <small>Digital profile preview</small>
          <i></i><i></i><i></i>
        </div>
      </div>
      <div class="clutch-nfc__copy clutch-reveal">
        <p class="clutch-eyebrow">THE CLUTCH NFC CARD</p>
        <h2 id="clutch-nfc-title">One Card. Every Connection.</h2>
        <p>Tap or scan one premium metal card to share your contact information, links, services, and next steps through an editable Clutch Connect profile.</p>
        <ul class="clutch-check-list clutch-check-list--single">
          <li>Reusable metal card</li>
          <li>NFC and QR sharing</li>
          <li>Editable digital profile</li>
          <li>Guided setup</li>
          <li>No app required for visitors</li>
        </ul>
        <div class="clutch-actions">
          <a class="clutch-button clutch-button--primary" href="{{ nfc_product.url | default: '/products/clutch-connect-card' }}">Explore the Clutch NFC Card</a>
          {%- if connect_url != blank -%}
            <a class="clutch-button clutch-button--secondary clutch-button--on-dark" href="{{ connect_url }}">Preview Clutch Connect</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <section class="clutch-home__section clutch-why" aria-labelledby="clutch-why-title">
    <div class="clutch-shell">
      <header class="clutch-section-heading clutch-reveal">
        <h2 id="clutch-why-title">Professional Print With a Smarter Follow-Through</h2>
      </header>
      <div class="clutch-trust-grid" role="list">
        <article class="clutch-trust-item clutch-reveal" role="listitem" style="--reveal-delay: 0ms"><span aria-hidden="true">01</span><h3>Free Shipping</h3><p>Shipping is included across the shop under the current store policy.</p></article>
        <article class="clutch-trust-item clutch-reveal" role="listitem" style="--reveal-delay: 80ms"><span aria-hidden="true">02</span><h3>Professional Production</h3><p>Practical print products produced for business, campaign, and event use.</p></article>
        <article class="clutch-trust-item clutch-reveal" role="listitem" style="--reveal-delay: 160ms"><span aria-hidden="true">03</span><h3>Artwork Support</h3><p>Review current file requirements or request help before production.</p><a href="{{ artwork_url }}">View artwork requirements</a></article>
        <article class="clutch-trust-item clutch-reveal" role="listitem" style="--reveal-delay: 240ms"><span aria-hidden="true">04</span><h3>Connected Marketing Tools</h3><p>Add QR, NFC, and digital experiences where they support your goal.</p></article>
      </div>
    </div>
  </section>

  <section class="clutch-home__section clutch-final" aria-labelledby="clutch-final-title">
    <div class="clutch-shell">
      <div class="clutch-final__cta clutch-reveal">
        <h2 id="clutch-final-title">Ready to Put Your Business in Front of More Customers?</h2>
        <div class="clutch-actions">
          <a class="clutch-button clutch-button--primary" href="{{ print_collection.url | default: '/collections/all' }}">Shop Print Products</a>
          <a class="clutch-button clutch-button--secondary clutch-button--on-dark" href="{{ custom_order_url }}">Request a Custom Order</a>
        </div>
      </div>
      <div class="clutch-faq" aria-label="Frequently asked questions">
        <details class="clutch-faq__item clutch-reveal"><summary>What products does Clutch Print Shop offer?<span aria-hidden="true">+</span></summary><p>Shop business cards, flyers, postcards, signs, banners, Business Kits, and other print products currently listed in the store. <a href="{{ print_collection.url | default: '/collections/all' }}">Browse print products</a>.</p></details>
        <details class="clutch-faq__item clutch-reveal"><summary>What is a Clutch Code?<span aria-hidden="true">+</span></summary><p>A Clutch Code™ is a dynamic QR campaign that connects printed marketing to an editable digital destination and scan activity. <a href="{{ clutch_codes_url }}">Explore Clutch Codes™</a>.</p></details>
        <details class="clutch-faq__item clutch-reveal"><summary>Do I have to add tracking to my print?<span aria-hidden="true">+</span></summary><p>No. Tracking is optional on eligible products, and ordinary print ordering remains available.</p></details>
        <details class="clutch-faq__item clutch-reveal"><summary>What is the Clutch NFC Card?<span aria-hidden="true">+</span></summary><p>It is a reusable metal card that shares an editable Clutch Connect profile through NFC tap or QR scan. <a href="{{ nfc_product.url | default: '/products/clutch-connect-card' }}">Explore the card</a>.</p></details>
        <details class="clutch-faq__item clutch-reveal"><summary>Can Clutch help with artwork?<span aria-hidden="true">+</span></summary><p>Yes. Review the current <a href="{{ artwork_url }}">artwork requirements</a> or <a href="{{ custom_order_url }}">request support</a> for your project.</p></details>
        <details class="clutch-faq__item clutch-reveal"><summary>Is shipping included?<span aria-hidden="true">+</span></summary><p>Yes. Free shipping is included across the shop under the current store policy.</p></details>
      </div>
    </div>
  </section>
</main>

{% stylesheet %}
  .clutch-home {
    --clutch-navy: #384862;
    --clutch-orange: #FFA665;
    --clutch-ink: #172033;
    --clutch-muted: #657085;
    --clutch-soft: #F5F7FA;
    --clutch-line: #DDE3EA;
    --clutch-white: #FFFFFF;
    background: var(--clutch-white);
    color: var(--clutch-ink);
    font-family: 'Montserrat', sans-serif;
    overflow: clip;
  }

  .clutch-home *,
  .clutch-home *::before,
  .clutch-home *::after {
    box-sizing: border-box;
  }

  .clutch-shell {
    margin-inline: auto;
    max-width: 1240px;
    padding-inline: clamp(1rem, 4vw, 2.5rem);
    width: 100%;
  }

  .clutch-home__section {
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .clutch-home h1,
  .clutch-home h2,
  .clutch-home h3,
  .clutch-home strong {
    font-family: 'Exo 2', sans-serif;
  }

  .clutch-home h1,
  .clutch-home h2,
  .clutch-home h3,
  .clutch-home p {
    margin: 0;
  }

  .clutch-home h1,
  .clutch-home h2 {
    color: var(--clutch-ink);
    letter-spacing: -0.035em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .clutch-home h1 {
    font-size: clamp(3rem, 7vw, 6.4rem);
  }

  .clutch-home h2 {
    font-size: clamp(2.2rem, 5vw, 4.6rem);
  }

  .clutch-home h3 {
    color: var(--clutch-ink);
    font-size: 1.25rem;
    line-height: 1.12;
  }

  .clutch-home p,
  .clutch-home li {
    color: var(--clutch-muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .clutch-eyebrow {
    color: var(--clutch-orange) !important;
    font-size: 0.72rem !important;
    font-weight: 800;
    letter-spacing: 0.14em;
    line-height: 1.3 !important;
    text-transform: uppercase;
  }

  .clutch-lead {
    font-size: clamp(1.05rem, 1.8vw, 1.2rem) !important;
    max-width: 680px;
  }

  .clutch-section-heading {
    display: grid;
    gap: 0.9rem;
    margin: 0 auto clamp(2rem, 5vw, 3.5rem);
    max-width: 860px;
    text-align: center;
  }

  .clutch-section-heading--left {
    margin-inline: 0;
    text-align: left;
  }

  .clutch-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .clutch-button,
  .clutch-inline-link {
    align-items: center;
    border-radius: 12px;
    display: inline-flex;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    text-decoration: none;
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .clutch-button {
    border: 1px solid transparent;
    padding: 0.85rem 1.2rem;
  }

  .clutch-button--primary {
    background: var(--clutch-navy);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 -3px 0 var(--clutch-orange), 0 12px 28px rgba(56, 72, 98, 0.2);
    color: var(--clutch-white);
  }

  .clutch-button--secondary {
    background: var(--clutch-white);
    border-color: var(--clutch-navy);
    color: var(--clutch-navy);
  }

  .clutch-button--on-dark {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.42);
    color: var(--clutch-white);
  }

  .clutch-inline-link {
    color: var(--clutch-navy);
    gap: 0.4rem;
    justify-self: start;
    padding-inline: 0.15rem;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.3em;
  }

  @media (hover: hover) and (pointer: fine) {
    .clutch-button:hover,
    .clutch-inline-link:hover {
      transform: translateY(-2px);
    }

    .clutch-button--primary:hover {
      background: #2D3C55;
      box-shadow: inset 0 -3px 0 var(--clutch-orange), 0 16px 34px rgba(56, 72, 98, 0.26);
    }

    .clutch-button--secondary:hover {
      border-color: var(--clutch-orange);
      box-shadow: 0 10px 24px rgba(56, 72, 98, 0.12);
    }

    .clutch-inline-link:hover {
      text-decoration-color: var(--clutch-orange);
    }
  }

  .clutch-button:active,
  .clutch-inline-link:active {
    box-shadow: none;
    transform: translateY(0);
  }

  .clutch-button:focus-visible,
  .clutch-inline-link:focus-visible,
  .clutch-home a:focus-visible,
  .clutch-home button:focus-visible,
  .clutch-home summary:focus-visible {
    outline: 3px solid var(--clutch-orange);
    outline-offset: 3px;
  }

  .clutch-hero {
    background: radial-gradient(circle at 82% 22%, rgba(56, 72, 98, 0.08), transparent 30%), linear-gradient(180deg, #FFFFFF 0%, #F7F8FA 100%);
    min-height: min(820px, calc(100svh - 80px));
    padding-top: clamp(5rem, 10vw, 8.5rem);
  }

  .clutch-hero__layout {
    align-items: center;
    display: grid;
    gap: clamp(2.5rem, 7vw, 5rem);
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
  }

  .clutch-hero__layout > *,
  .clutch-kits__layout > *,
