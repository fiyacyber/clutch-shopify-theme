    .clutch-hero__analytics {
      padding: 0.75rem;
    }

    .clutch-nfc__phone {
      border-width: 5px;
      min-height: 230px;
      padding: 0.8rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .clutch-home *,
    .clutch-home *::before,
    .clutch-home *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }

    .clutch-home.is-enhanced .clutch-reveal:not(.is-visible) {
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const roots = document.querySelectorAll('[data-clutch-home]');

    roots.forEach((root) => {
      root.classList.add('is-enhanced');

      const revealItems = root.querySelectorAll('.clutch-reveal');
      if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });

        revealItems.forEach((item) => observer.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add('is-visible'));
      }

      const demo = root.querySelector('[data-clutch-code-demo]');
      if (!demo) return;

      const buttons = demo.querySelectorAll('[data-demo-destination]');
      const kicker = demo.querySelector('[data-demo-kicker]');
      const title = demo.querySelector('[data-demo-title]');
      const action = demo.querySelector('[data-demo-action]');

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          buttons.forEach((item) => {
            item.classList.remove('is-active');
            item.setAttribute('aria-pressed', 'false');
          });
          button.classList.add('is-active');
          button.setAttribute('aria-pressed', 'true');
          kicker.textContent = button.dataset.kicker;
          title.textContent = button.dataset.title;
          action.textContent = button.dataset.action;
          demo.dataset.active = button.dataset.demoDestination;
        });
      });
    });
  })();
{% endjavascript %}

