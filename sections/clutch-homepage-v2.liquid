{% comment %}
  Clutch Print Shop homepage - Phase 1 premium SaaS foundation.
  Header, cart, checkout, product forms, and footer remain controlled by the theme.
{% endcomment %}

<main class="chp-home">
  <section class="chp-hero" aria-labelledby="chp-hero-title">
    <div class="chp-shell chp-hero__grid">
      <div class="chp-hero__copy">
        <span class="chp-badge">Premium print powered by Clutch Connect</span>
        <h1 id="chp-hero-title">Print Smarter. Track Everything.</h1>
        <p>
          Premium print products and Smart Clutch Cards powered by Clutch Connect - track QR scans, NFC taps, leads,
          contact saves, profile views, and campaign performance from one dashboard.
        </p>
        <div class="chp-actions">
          <a class="chp-btn chp-btn--primary" href="/collections/business-kits">Shop Business Kits</a>
          <a class="chp-btn chp-btn--secondary" href="/products/clutch-connect-card">Shop Smart Clutch Card</a>
        </div>
        <div class="chp-proof" aria-label="Platform highlights">
          <span>QR scan tracking</span>
          <span>NFC smart cards</span>
          <span>30 days dashboard access with new orders</span>
        </div>
      </div>

    </div>
  </section>

  <section class="chp-section chp-steps" aria-labelledby="chp-steps-title">
    <div class="chp-shell">
      <div class="chp-section-head">
        <span class="chp-eyebrow">How Clutch Works</span>
        <h2 id="chp-steps-title">Premium print, connected to measurable marketing.</h2>
      </div>
      <div class="chp-step-grid">
        <article class="chp-card chp-step-card"><span>01</span><h3>Order premium print</h3><p>Choose business kits, cards, flyers, signs, banners, or custom campaign materials.</p></article>
        <article class="chp-card chp-step-card"><span>02</span><h3>Launch a trackable campaign</h3><p>Connect print to a dynamic QR, NFC smart card, Clutch Connect profile, form, or offer.</p></article>
        <article class="chp-card chp-step-card"><span>03</span><h3>Customers scan or tap</h3><p>Engagement starts through QR scans, NFC taps, digital profiles, contact saves, and lead forms.</p></article>
        <article class="chp-card chp-step-card"><span>04</span><h3>View results in Clutch Connect</h3><p>See campaign analytics, top locations, leads, profile activity, and performance signals.</p></article>
      </div>
    </div>
  </section>

  <section class="chp-section chp-platform" id="clutch-connect" aria-labelledby="chp-platform-title">
    <div class="chp-shell chp-platform__grid">
      <div class="chp-platform__copy">
        <span class="chp-eyebrow">Clutch Connect Platform</span>
        <h2 id="chp-platform-title">Every print piece can become a trackable campaign.</h2>
        <p>
          Clutch Connect connects your printed marketing to campaign analytics, digital profiles,
          lead capture, QR/NFC engagement, and location visibility.
        </p>
        <a class="chp-btn chp-btn--primary" href="/pages/qr-pro">Explore Clutch Connect</a>
      </div>
      <div class="chp-feature-grid">
        <article class="chp-card chp-feature"><h3>Dynamic QR Codes</h3><p>Update destinations after printing and measure campaign scans.</p></article>
        <article class="chp-card chp-feature"><h3>NFC Smart Cards</h3><p>Metal cards connected to a live profile and tap analytics.</p></article>
        <article class="chp-card chp-feature"><h3>Digital Business Card</h3><p>Share contact details, links, socials, reviews, and lead actions.</p></article>
        <article class="chp-card chp-feature"><h3>Lead Capture</h3><p>Turn print engagement into follow-up opportunities.</p></article>
        <article class="chp-card chp-feature"><h3>Campaign Analytics</h3><p>View scans, taps, profile views, links, leads, and performance.</p></article>
        <article class="chp-card chp-feature"><h3>Heatmap Visibility</h3><p>Understand where your printed marketing is creating engagement.</p></article>
      </div>
    </div>
  </section>

  <section class="chp-section chp-smart-cards" aria-labelledby="chp-smart-cards-title">
    <div class="chp-shell chp-smart-cards__grid">
      <div class="chp-smart-cards__copy">
        <span class="chp-eyebrow">Smart Clutch Card</span>
        <h2 id="chp-smart-cards-title">Blank metal NFC cards connected to your Clutch Connect profile.</h2>
        <p>
          Choose matte black, brushed silver, or brushed gold NTAG213 metal cards. Optional custom engraving is available,
          and new orders include 30 days of Clutch dashboard access.
        </p>
        <div class="chp-smart-cards__badges">
          <span>Optional custom engraving</span>
          <span>30 days dashboard access with new orders</span>
          <span>NFC tap + dynamic QR setup</span>
        </div>
        <div class="chp-actions">
          <a class="chp-btn chp-btn--primary" href="/products/clutch-connect-card">Shop Smart Clutch Card</a>
          <a class="chp-btn chp-btn--secondary" href="/pages/smart-business-card">View Details</a>
        </div>
      </div>
      <div class="chp-smart-cards__visual">
        {% render 'clutch-connect-card-mockup' %}
      </div>
    </div>
  </section>

  {% render 'clutch-connect-card-section' %}

  {%- liquid
    assign kits = 'starter-kit::STARTER::$399::Starter Kit::250 business cards, 250 flyers, QR campaign tracking, and artwork review.||growth-kit::GROWTH::$649::Growth Kit::500 business cards, 500 flyers, 500 door hangers, Clutch Connect reporting, and optional 100 yard signs.||custom-order::AGENCY / CUSTOM::Custom quote::Custom quantities, multi-location campaigns, yard signs, banners, and reporting setup.' | split: '||'
  -%}

  <section class="chp-section chp-kits" id="business-kits" aria-labelledby="chp-kits-title">
    <div class="chp-shell">
      <div class="chp-section-head">
        <span class="chp-eyebrow">Business Kits</span>
        <h2 id="chp-kits-title">Print campaigns with analytics included.</h2>
        <p>
          Kits are positioned around outcomes: trackable print, QR campaign tracking, smart card options,
          Clutch Connect access, and campaign reporting.
        </p>
      </div>
      <div class="chp-kit-grid">
        {%- for kit in kits -%}
          {%- assign parts = kit | split: '::' -%}
          {%- assign handle = parts[0] -%}
          {%- assign keyline = parts[1] -%}
          {%- assign price = parts[2] -%}
          {%- assign label = parts[3] -%}
          {%- assign desc = parts[4] -%}
          {%- assign product = all_products[handle] -%}
          {%- if product == blank and handle == 'starter-kit' -%}{%- assign product = all_products['startup-kit'] -%}{%- endif -%}
          {%- assign url = product.url -%}
          {%- if url == blank -%}
            {%- if handle == 'starter-kit' -%}
              {%- assign url = '/products/startup-kit' -%}
            {%- elsif handle == 'custom-order' -%}
              {%- assign url = '/pages/contact' -%}
            {%- else -%}
              {%- assign url = '/products/' | append: handle -%}
            {%- endif -%}
          {%- endif -%}
          <a class="chp-card chp-kit{% if forloop.index == 2 %} chp-kit--featured{% endif %}" href="{{ url }}">
            {%- if forloop.index == 2 -%}<span class="chp-kit__flag">Most popular</span>{%- endif -%}
            <small>{{ keyline }}</small>
            <h3>{{ label }}</h3>
            <em>{{ price }}</em>
            <p>{{ desc }}</p>
            <ul>
              {%- if handle == 'starter-kit' -%}
                <li>250 business cards</li>
                <li>250 flyers</li>
                <li>QR campaign tracking</li>
              {%- elsif handle == 'growth-kit' -%}
                <li>500 business cards</li>
                <li>500 flyers + 500 door hangers</li>
                <li>Optional: Add 100 1-color, 2-sided yard signs for $399.</li>
              {%- else -%}
                <li>Custom print quantities</li>
                <li>Yard signs, banners, and mailers</li>
                <li>Campaign reporting setup</li>
              {%- endif -%}
            </ul>
            <strong>{% if handle == 'custom-order' %}Request custom order{% else %}View kit details{% endif %}</strong>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="chp-section chp-difference" aria-labelledby="chp-difference-title">
    <div class="chp-shell">
      <div class="chp-section-head">
        <span class="chp-eyebrow">Why Clutch Is Different</span>
        <h2 id="chp-difference-title">Premium print with attribution built in.</h2>
      </div>
      <div class="chp-compare-grid">
        <article class="chp-card chp-compare chp-compare--plain">
          <span>Traditional printer</span>
          <h3>Products without performance data.</h3>
          <ul><li>Prints products</li><li>No tracking</li><li>No location insights</li><li>No lead capture</li></ul>
        </article>
        <article class="chp-card chp-compare chp-compare--clutch">
          <span>Clutch</span>
          <h3>Trackable print campaigns connected to software.</h3>
          <ul><li>Trackable print campaigns</li><li>QR/NFC analytics</li><li>Clutch Connect profile</li><li>Lead capture and campaign reporting</li></ul>
        </article>
      </div>
    </div>
  </section>

  {%- liquid
    assign products = 'standard-business-cards::Business Cards::Premium cards for everyday networking and campaign handoffs.||premium-flyers::Flyers::Promotional print built for trackable campaigns.||door-hangers::Door Hangers::Local outreach pieces ready for scan reporting.||yard-signs::Yard Signs::Outdoor visibility with campaign destinations.||premium-postcards::Postcards::Direct mail and leave-behind campaigns.||tri-fold-brochures::Brochures::Polished informational print for service businesses.||vinyl-banners::Banners::Large-format brand moments for events and locations.' | split: '||'
  -%}

  <section class="chp-section chp-products" aria-labelledby="chp-products-title">
    <div class="chp-shell">
      <div class="chp-section-head">
        <span class="chp-eyebrow">Products</span>
        <h2 id="chp-products-title">Premium print products built for measurable marketing.</h2>
      </div>
      <div class="chp-product-grid">
        {%- for item in products -%}
          {%- assign parts = item | split: '::' -%}
          {%- assign handle = parts[0] -%}
          {%- assign label = parts[1] -%}
          {%- assign desc = parts[2] -%}
          {%- assign product = all_products[handle] -%}
          {%- assign product_url = product.url -%}
          {%- if product_url == blank -%}{%- assign product_url = '/products/' | append: handle -%}{%- endif -%}
          <a class="chp-card chp-product" href="{{ product_url }}">
            <span>Trackable print</span>
            <h3>{{ label }}</h3>
            <p>{{ desc }}</p>
            {%- if product.price -%}<strong>From {{ product.price | money }}</strong>{%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="chp-final" aria-labelledby="chp-final-title">
    <div class="chp-shell chp-final__inner">
      <span class="chp-eyebrow">Start tracking your print marketing</span>
      <h2 id="chp-final-title">Launch print that looks premium and reports like software.</h2>
      <div class="chp-actions">
        <a class="chp-btn chp-btn--dark" href="/collections/business-kits">Shop Business Kits</a>
        <a class="chp-btn chp-btn--secondary" href="/pages/contact">Contact Clutch</a>
      </div>
    </div>
  </section>
</main>

{% stylesheet %}
  .chp-home {
    --chp-navy: #384862;
    --chp-dark: #071D33;
    --chp-orange: #FFA665;
    --chp-soft: #F4F7FA;
    --chp-white: #FFFFFF;
    --chp-border: #DDE6EF;
    --chp-muted: #66758C;
    background: var(--chp-soft);
    color: var(--chp-dark);
    font-family: 'Montserrat', sans-serif;
    overflow: hidden;
  }

  .chp-home *, .chp-home *::before, .chp-home *::after { box-sizing: border-box; }
  .chp-shell { margin-inline: auto; max-width: 1240px; padding-inline: clamp(1rem, 4vw, 2.5rem); width: 100%; }
  .chp-section { padding: clamp(3.5rem, 7vw, 6rem) 0; }
  .chp-section-head { margin: 0 auto clamp(1.8rem, 4vw, 3rem); max-width: 820px; text-align: center; }
  .chp-section-head h2, .chp-hero h1, .chp-platform__copy h2, .chp-final h2 { color: var(--chp-dark); font-family: 'Exo 2', sans-serif; letter-spacing: -0.025em; line-height: 0.98; margin: 0; text-wrap: balance; }
  .chp-section-head h2, .chp-platform__copy h2, .chp-final h2 { font-size: clamp(2rem, 4.8vw, 3.75rem); }
  .chp-section-head p, .chp-platform__copy p { color: var(--chp-muted); font-size: clamp(0.98rem, 1.6vw, 1.08rem); line-height: 1.7; margin: 1rem auto 0; max-width: 760px; }
  .chp-eyebrow, .chp-badge { color: var(--chp-orange); display: block; font-size: 0.74rem; font-weight: 900; letter-spacing: 0.12em; line-height: 1.2; margin: 0 0 0.8rem; text-transform: uppercase; }
  .chp-badge { background: rgba(255,166,101,0.14); border: 1px solid rgba(255,166,101,0.34); border-radius: 999px; display: inline-flex; padding: 0.5rem 0.72rem; }
  .chp-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; }
  .chp-btn { align-items: center; border-radius: 10px; display: inline-flex; font-weight: 900; justify-content: center; line-height: 1.15; min-height: 48px; padding: 0.9rem 1.35rem; text-align: center; text-decoration: none; transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease, background 0.18s ease; }
  .chp-btn:hover { transform: translateY(-2px); }
  .chp-btn--primary { background: var(--chp-orange); color: var(--chp-dark); box-shadow: 0 16px 32px rgba(255,166,101,0.28); }
  .chp-btn--secondary { background: var(--chp-white); border: 1px solid var(--chp-border); color: var(--chp-navy); }
  .chp-btn--dark { background: var(--chp-dark); color: #fff; box-shadow: 0 16px 32px rgba(7,29,51,0.22); }
  .chp-card { background: var(--chp-white); border: 1px solid var(--chp-border); border-radius: 20px; box-shadow: 0 16px 36px rgba(7,29,51,0.07); color: inherit; text-decoration: none; transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease; }
  a.chp-card:hover { border-color: rgba(255,166,101,0.58); box-shadow: 0 24px 54px rgba(7,29,51,0.12); transform: translateY(-4px); }

  .chp-hero { background: radial-gradient(circle at 18% 18%, rgba(255,166,101,0.24), transparent 28%), radial-gradient(circle at 88% 8%, rgba(255,255,255,0.12), transparent 22%), linear-gradient(135deg, var(--chp-dark), var(--chp-navy)); padding: clamp(6.5rem, 8vw, 7.8rem) 0 clamp(3rem, 5vw, 4.5rem); }
  .chp-hero__grid { align-items: center; display: grid; justify-items: center; gap: clamp(2rem, 5vw, 4rem); grid-template-columns: minmax(0, 1fr); }
  .chp-hero__copy { display: grid; justify-items: center; text-align: center; }
  .chp-hero h1 { color: #fff; font-size: clamp(2.8rem, 6.8vw, 5.6rem); max-width: 920px; overflow-wrap: normal; text-wrap: balance; }
  .chp-hero__copy > p { color: rgba(255,255,255,0.82); font-size: clamp(1rem, 2vw, 1.18rem); line-height: 1.75; margin: 1.35rem auto 0; max-width: 760px; }
  .chp-hero .chp-actions { margin-top: 1.65rem; }
  .chp-proof { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin-top: 1.1rem; }
  .chp-proof span { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.14); border-radius: 999px; color: rgba(255,255,255,0.82); font-size: 0.78rem; font-weight: 800; padding: 0.5rem 0.7rem; }

  .chp-step-grid, .chp-feature-grid, .chp-kit-grid, .chp-product-grid, .chp-compare-grid { display: grid; gap: 1rem; }
  .chp-step-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .chp-step-card, .chp-feature, .chp-product { padding: 1.15rem; }
  .chp-step-card span, .chp-kit small, .chp-product span, .chp-compare span { color: var(--chp-orange); display: block; font-size: 0.72rem; font-weight: 900; letter-spacing: 0.1em; margin-bottom: 0.8rem; text-transform: uppercase; }
  .chp-step-card h3, .chp-feature h3, .chp-kit h3, .chp-product h3, .chp-compare h3 { color: var(--chp-dark); font-family: 'Exo 2', sans-serif; font-size: 1.25rem; line-height: 1.1; margin: 0; }
  .chp-step-card p, .chp-feature p, .chp-kit p, .chp-product p { color: var(--chp-muted); line-height: 1.6; margin: 0.8rem 0 0; }
  .chp-platform { background: #fff; }
  .chp-platform__grid { align-items: start; display: grid; gap: clamp(2rem, 5vw, 4rem); grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr); }
  .chp-platform__copy { position: sticky; top: 2rem; }
  .chp-platform__copy .chp-btn { margin-top: 1.5rem; }
  .chp-feature-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .chp-feature { min-height: 172px; }
  .chp-smart-cards { background: #fff; }
  .chp-smart-cards__grid { align-items: center; display: grid; gap: clamp(2rem, 5vw, 4rem); grid-template-columns: minmax(0, 0.9fr) minmax(340px, 1.1fr); }
  .chp-smart-cards__copy h2 { color: var(--chp-dark); font-family: 'Exo 2', sans-serif; font-size: clamp(2rem, 4.8vw, 3.75rem); letter-spacing: -0.025em; line-height: 0.98; margin: 0; text-wrap: balance; }
  .chp-smart-cards__copy p { color: var(--chp-muted); font-size: clamp(0.98rem, 1.6vw, 1.08rem); line-height: 1.7; margin: 1rem 0 0; max-width: 720px; }
  .chp-smart-cards__badges { display: flex; flex-wrap: wrap; gap: 0.6rem; margin: 1.25rem 0 1.5rem; }
  .chp-smart-cards__badges span { background: #fff7f0; border: 1px solid rgba(255,166,101,0.36); border-radius: 999px; color: var(--chp-navy); font-size: 0.78rem; font-weight: 850; padding: 0.52rem 0.72rem; }
  .chp-smart-cards__visual { min-width: 0; }
  .chp-kits { background: linear-gradient(180deg, #F4F7FA, #fff); }
  .chp-kit-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .chp-kit { display: grid; padding: 1.35rem; }
  .chp-kit--featured { border-color: rgba(255,166,101,0.62); box-shadow: 0 24px 54px rgba(255,166,101,0.18); }
  .chp-kit__flag { background: var(--chp-dark); border-radius: 999px; color: #fff; display: inline-flex; font-size: 0.68rem; font-weight: 900; margin-bottom: 0.8rem; padding: 0.36rem 0.6rem; width: fit-content; }
  .chp-kit em { color: var(--chp-dark); display: block; font-family: 'Exo 2', sans-serif; font-size: 1.55rem; font-style: normal; font-weight: 900; line-height: 1; margin-top: 0.7rem; }
  .chp-kit ul, .chp-compare ul { color: var(--chp-navy); display: grid; gap: 0.55rem; list-style: none; margin: 1rem 0; padding: 0; }
  .chp-kit li, .chp-compare li { align-items: start; display: grid; gap: 0.55rem; grid-template-columns: 18px 1fr; line-height: 1.45; }
  .chp-kit li::before, .chp-compare li::before { color: var(--chp-orange); content: '+'; font-weight: 900; }
  .chp-kit > strong { color: var(--chp-navy); margin-top: auto; }
  .chp-difference { background: #fff; }
  .chp-compare-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .chp-compare { padding: clamp(1.25rem, 3vw, 2rem); }
  .chp-compare--plain { background: var(--chp-soft); }
  .chp-compare--clutch { background: linear-gradient(145deg, var(--chp-dark), var(--chp-navy)); color: #fff; }
  .chp-compare--clutch h3 { color: #fff; }
  .chp-compare--clutch li { color: rgba(255,255,255,0.84); }
  .chp-products { background: var(--chp-soft); }
  .chp-product-grid { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .chp-product { min-height: 184px; }
  .chp-product strong { color: var(--chp-navy); display: block; margin-top: 0.9rem; }
  .chp-final { background: var(--chp-orange); padding: clamp(3.5rem, 7vw, 5.5rem) 0; }
  .chp-final__inner { align-items: center; display: grid; gap: 1.5rem; justify-items: center; max-width: 900px; text-align: center; }
  .chp-final .chp-eyebrow { color: rgba(7,29,51,0.72); }

  @media screen and (max-width: 980px) {
    .chp-hero__grid, .chp-platform__grid, .chp-smart-cards__grid { grid-template-columns: 1fr; }
    .chp-platform__copy { position: static; }
    .chp-step-grid, .chp-kit-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media screen and (max-width: 720px) {
    .chp-hero { padding-top: 6.75rem; }
    .chp-hero h1 { font-size: clamp(2.55rem, 13vw, 3.75rem); }
    .chp-step-grid, .chp-feature-grid, .chp-kit-grid, .chp-compare-grid { grid-template-columns: 1fr; }
    .chp-actions, .chp-actions .chp-btn { width: 100%; }
    .chp-actions .chp-btn { display: flex; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Clutch Homepage",
  "settings": [],
  "presets": [
    {
      "name": "Clutch Homepage"
    }
  ]
}
{% endschema %}
