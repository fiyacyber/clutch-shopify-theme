{% comment %}
  Clutch Homepage — all homepage sections in one place.
  Header and footer are injected by layout/theme.liquid automatically.
{% endcomment %}

<!-- ============================================================
  1. HERO
============================================================ -->
<section class="ch-hero">
  <div class="ch-hero__glow ch-hero__glow--orange" aria-hidden="true"></div>
  <div class="ch-hero__glow ch-hero__glow--blue" aria-hidden="true"></div>
  <div class="ch-inner ch-hero__inner">
    <img
      class="ch-hero__logo"
      src="{{ 'clutch-hero-logo-1920x700.png' | asset_url }}"
      alt="Clutch Print Shop"
      width="1920"
      height="700"
      loading="eager"
    >
    <h1 class="ch-hero__headline">Print Smarter. Connect Faster.</h1>
    <p class="ch-hero__sub">
      Premium print products powered by QR Pro — smart business cards, QR/NFC profiles,
      and trackable marketing tools built to help growing businesses get found, get saved, and get leads.
    </p>
    <div class="ch-hero__actions">
      <a class="ch-btn ch-btn--primary" href="/collections/all">Shop Products</a>
      <a class="ch-btn ch-btn--ghost" href="/pages/qr-pro">See QR Pro</a>
    </div>
  </div>
</section>

{% render 'clutch-connect-card-section' %}

<!-- ============================================================
  2. QR PRO / CLUTCH QR TRACKING
============================================================ -->
<section class="ch-qrpro" id="qr-tracking">
  <div class="ch-inner ch-qrpro__inner">
    <div class="ch-qrpro__text">
      <p class="ch-eyebrow ch-eyebrow--light">Clutch QR™</p>
      <h2>Print Smarter. Track Everything.</h2>
      <p>
        Business Kits can assign dynamic Clutch QR tracking to each printed material,
        so cards, flyers, door hangers, and signs can each show their own scan performance.
      </p>
      <ul class="ch-qrpro__features">
        <li>Track scans by printed material</li>
        <li>Update QR destinations anytime</li>
        <li>Compare campaign performance</li>
        <li>QR Pro dashboard access and analytics</li>
      </ul>
      <a class="ch-btn ch-btn--primary" href="/pages/qr-pro">Learn About Clutch QR™</a>
    </div>
    <div class="ch-qrpro__visual" aria-hidden="true">
      <div class="ch-qrpro__mockup-wrap">
        <div class="ch-qrpro__mockup-orb ch-qrpro__mockup-orb--one"></div>
        <div class="ch-qrpro__mockup-orb ch-qrpro__mockup-orb--two"></div>
        <div class="ch-qrpro__mockup">
        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" fill="none">
          <rect width="200" height="200" rx="16" fill="#384862"/>
          <rect x="24" y="24" width="64" height="64" rx="6" fill="#FFA665"/>
          <rect x="36" y="36" width="40" height="40" rx="3" fill="#384862"/>
          <rect x="44" y="44" width="24" height="24" rx="2" fill="#FFA665"/>
          <rect x="112" y="24" width="64" height="64" rx="6" fill="#FFA665"/>
          <rect x="124" y="36" width="40" height="40" rx="3" fill="#384862"/>
          <rect x="132" y="44" width="24" height="24" rx="2" fill="#FFA665"/>
          <rect x="24" y="112" width="64" height="64" rx="6" fill="#FFA665"/>
          <rect x="36" y="124" width="40" height="40" rx="3" fill="#384862"/>
          <rect x="44" y="132" width="24" height="24" rx="2" fill="#FFA665"/>
          <rect x="112" y="112" width="16" height="16" rx="2" fill="#FFA665"/>
          <rect x="134" y="112" width="16" height="16" rx="2" fill="#FFA665"/>
          <rect x="156" y="112" width="20" height="16" rx="2" fill="#FFA665"/>
          <rect x="112" y="134" width="20" height="16" rx="2" fill="#FFA665"/>
          <rect x="138" y="134" width="16" height="16" rx="2" fill="#FFA665"/>
          <rect x="112" y="156" width="16" height="20" rx="2" fill="#FFA665"/>
          <rect x="134" y="156" width="42" height="20" rx="2" fill="#FFA665"/>
        </svg>
        <p class="ch-qrpro__mockup-label">Clutch QR™ Code</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
  3. BUSINESS KITS
============================================================ -->
{%- liquid
  assign kits = 'starter-kit::STARTER::Starter Kit::View Kit Details &rarr;::Professional Design Free|Business Cards + QR Tracking|Flyers + QR Tracking|Editable QR Destinations|Launch-Ready Campaign||growth-kit::GROWTH::Growth Kit::View Kit Details &rarr;::Professional Design Free|Business Cards + QR Tracking|Flyers + QR Tracking|Door Hangers + QR Tracking|Compare Scans by Material|QR Pro Dashboard Access||contractor-kit::CONTRACTOR::Contractor Kit::View Kit Details &rarr;::Professional Design Free|Business Cards + QR Tracking|Door Hangers + QR Tracking|Yard Signs + QR Tracking|Lead Tracking & Review Links|QR Pro Dashboard Access' | split: '||'
-%}

<section class="ch-kits" id="business-kits">
  <div class="ch-inner">
    <div class="ch-section-header">
      <p class="ch-eyebrow">Business Kits</p>
      <h2>Everything you need, bundled and trackable.</h2>
      <p class="ch-kits__subtitle">
        Every Business Kit includes dynamic Clutch QR technology for each printed marketing piece in the kit.
        Track scans by material type, compare what works, and update QR destinations without reprinting.
      </p>
    </div>

    <div class="ch-kits__grid">
      {%- for kit in kits -%}
        {%- assign kparts  = kit | split: '::' -%}
        {%- assign khandle = kparts[0] -%}
        {%- assign keyline = kparts[1] -%}
        {%- assign klabel  = kparts[2] -%}
        {%- assign kbutton = kparts[3] -%}
        {%- assign kfeatures = kparts[4] | split: '|' -%}
        {%- assign kproduct = all_products[khandle] -%}
        {%- if kproduct == blank and khandle == 'starter-kit' -%}
          {%- assign kproduct = all_products['startup-kit'] -%}
        {%- endif -%}
        {%- assign kurl = kproduct.url -%}
        {%- if kurl == blank -%}
          {%- if khandle == 'starter-kit' -%}
            {%- assign kurl = '/products/startup-kit' -%}
          {%- else -%}
            {%- assign kurl = '/products/' | append: khandle -%}
          {%- endif -%}
        {%- endif -%}
        <article class="ch-kit-card{% if forloop.index == 2 %} ch-kit-card--featured{% endif %}">
          <div class="ch-kit-card__body">
            {%- if forloop.index == 2 -%}
              <span class="ch-kit-card__flag">Most Popular</span>
            {%- endif -%}
            <p class="ch-kit-card__eyebrow">{{ keyline }}</p>
            <h3>{{ klabel }}</h3>
            <ul class="ch-kit-card__features" aria-label="{{ klabel }} features">
              {%- for feature in kfeatures -%}
                <li>
                  <span class="ch-kit-card__feature-text">
                    {%- if feature contains 'Clutch QR™ Code' -%}
                      {{ feature | replace: 'Clutch QR™ Code', '<span class="ch-kit-card__feature-highlight">Clutch QR™ Code</span>' }}
                    {%- else -%}
                      {{ feature }}
                    {%- endif -%}
                  </span>
                </li>
              {%- endfor -%}
            </ul>
            <a class="ch-btn ch-btn--outline ch-kit-card__button" href="{{ kurl }}">{{ kbutton }}</a>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% render 'clutch-business-kit-tracking-callout' %}

<!-- ============================================================
  5. BUSINESS ESSENTIALS
============================================================ -->
{%- liquid
  assign essentials = 'standard-business-cards::Business Cards::Professional cards for everyday networking.||premium-flyers::Flyers::Promote offers, events, and services fast.||door-hangers::Door Hangers::Neighborhood-ready print for local outreach.||yard-signs::Yard Signs::Durable outdoor signs for local visibility.||premium-postcards::Postcards::Compact promos for offers and follow-ups.||tri-fold-brochures::Brochures::Folded print pieces for polished presentations.||vinyl-banners::Banners::Large-format banners for bold displays.' | split: '||'
-%}

<section class="ch-essentials" id="business-essentials">
  <div class="ch-inner">
    <div class="ch-section-header">
      <p class="ch-eyebrow">Business Essentials</p>
      <h2>Essential print products for growing businesses.</h2>
    </div>

    <div class="ch-essentials__grid">
      {%- for item in essentials -%}
        {%- assign parts = item | split: '::' -%}
        {%- assign handle = parts[0] -%}
        {%- assign label  = parts[1] -%}
        {%- assign desc   = parts[2] -%}
        {%- assign product = all_products[handle] -%}
        {%- assign product_url = product.url -%}
        {%- if product_url == blank -%}
          {%- assign product_url = '/products/' | append: handle -%}
        {%- endif -%}
        <a class="ch-card" href="{{ product_url }}">
          {%- if product.featured_media != blank -%}
            {{
              product.featured_media.preview_image
              | image_url: width: 640
              | image_tag:
                class: 'ch-card__img',
                loading: 'lazy',
                sizes: '(min-width: 990px) 25vw, (min-width: 650px) 50vw, 100vw',
                alt: label
            }}
          {%- else -%}
            <div class="ch-card__img-placeholder">{{ label | slice: 0, 2 }}</div>
          {%- endif -%}
          <div class="ch-card__body">
            <span class="ch-card__badge">QR Tracking Available</span>
            <h3 class="ch-card__title">{{ label }}</h3>
            <p class="ch-card__desc">{{ desc }}</p>
            {%- if product.price -%}
              <p class="ch-card__price">From {{ product.price | money }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ============================================================
  6. CUSTOM ORDER CTA
============================================================ -->
<section class="ch-cta">
  <div class="ch-inner ch-cta__inner">
    <h2>Need something custom?</h2>
    <p>
      We handle custom sizes, quantities, finishes, and branded kits. Tell us
      what you need and we'll make it happen.
    </p>
    <div class="ch-cta__actions">
      <a class="ch-btn ch-btn--primary" href="/pages/contact">Request Custom Order</a>
      <a class="ch-btn ch-btn--ghost-dark" href="/collections/all">Browse All Products</a>
    </div>
  </div>
</section>

{% stylesheet %}
/* ====================================================
   SHARED TOKENS
==================================================== */
.ch-inner {
  margin-inline: auto;
  max-width: 1280px;
  padding-inline: clamp(1rem, 4vw, 2.5rem);
  width: 100%;
}

.shopify-section:has(.ch-hero),
.shopify-section:has(.ch-essentials),
.shopify-section:has(.ch-qrpro),
.shopify-section:has(.ch-kits),
.shopify-section:has(.ch-cta) {
  overflow: clip;
}

.ch-eyebrow {
  color: #FFA665;
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  margin: 0 0 0.5rem;
  text-transform: uppercase;
}

.ch-eyebrow--light { color: rgba(255,255,255,0.7); }

.ch-section-header {
  margin-bottom: clamp(2rem, 4vw, 3rem);
  text-align: center;
}

.ch-section-header p,
.ch-section-header h2 {
  position: relative;
  z-index: 1;
}

.ch-section-header h2 {
  color: #384862;
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  margin: 0;
}

/* ====================================================
   BUTTONS
==================================================== */
.ch-btn {
  box-shadow: 0 12px 30px rgba(56, 72, 98, 0.12);
  border-radius: 6px;
  cursor: pointer;
  display: inline-block;
  font-size: 0.95rem;
  font-weight: 700;
  line-height: 1;
  padding: 0.85rem 1.75rem;
  text-align: center;
  text-decoration: none;
  transform: translateY(0);
  transition: opacity 0.18s, transform 0.18s, box-shadow 0.18s, border-color 0.18s, background-color 0.18s;
}

.ch-btn:hover {
  box-shadow: 0 18px 34px rgba(56, 72, 98, 0.18);
  opacity: 1;
  transform: translateY(-2px);
}

.ch-btn--primary {
  background: #FFA665;
  color: #384862;
}

.ch-btn--ghost {
  background: transparent;
  border: 2px solid rgba(255,255,255,0.72);
  color: #fff;
}

.ch-btn--outline {
  background: transparent;
  border: 2px solid #FFA665;
  color: #FFA665;
  margin-top: 1rem;
}

.ch-btn--ghost-dark {
  background: transparent;
  border: 2px solid #384862;
  color: #384862;
}

/* ====================================================
   1. HERO
==================================================== */
.ch-hero {
  background:
    radial-gradient(circle at top left, rgba(255, 166, 101, 0.28), transparent 30%),
    radial-gradient(circle at 85% 20%, rgba(255, 255, 255, 0.12), transparent 18%),
    linear-gradient(135deg, rgba(56,72,98,0.98), rgba(44,58,82,0.92));
  box-sizing: border-box;
  display: grid;
  min-height: clamp(540px, 58vh, 660px);
  overflow: hidden;
  padding: clamp(4.5rem, 9vw, 7rem) 0 clamp(3.5rem, 6vw, 5rem);
  place-items: center;
  position: relative;
  width: 100%;
}

.ch-hero__glow {
  border-radius: 999px;
  filter: blur(18px);
  pointer-events: none;
  position: absolute;
}

.ch-hero__glow--orange {
  background: rgba(255, 166, 101, 0.2);
  height: 320px;
  left: -80px;
  top: 40px;
  width: 320px;
}

.ch-hero__glow--blue {
  background: rgba(255, 255, 255, 0.08);
  height: 220px;
  right: 6%;
  top: 80px;
  width: 220px;
}

.ch-hero__inner {
  background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 28px;
  box-shadow: 0 24px 70px rgba(16, 22, 32, 0.26);
  display: grid;
  justify-items: center;
  padding: clamp(1.5rem, 4vw, 2.5rem);
  position: relative;
  text-align: center;
}

.ch-hero__logo {
  aspect-ratio: 1920/700;
  display: block;
  filter: drop-shadow(0 16px 30px rgba(0, 0, 0, 0.18));
  height: auto;
  margin-bottom: clamp(0.75rem, 2vw, 1.25rem);
  max-width: min(500px, 80vw);
  object-fit: contain;
  width: 100%;
}

.ch-hero__headline {
  color: #fff;
  letter-spacing: -0.03em;
  text-shadow: 0 10px 28px rgba(0, 0, 0, 0.24);
  font-size: clamp(1.8rem, 5.5vw, 3.5rem);
  line-height: 1.05;
  margin: 0 auto 1rem;
  max-width: 820px;
  text-wrap: balance;
}

.ch-hero__sub {
  color: rgba(255,255,255,0.82);
  font-size: clamp(0.92rem, 2vw, 1.05rem);
  line-height: 1.6;
  margin: 0 auto 0;
  max-width: 640px;
  text-wrap: pretty;
}

.ch-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
  margin-top: 2.25rem;
}

/* ====================================================
   2. BUSINESS ESSENTIALS
==================================================== */
.ch-essentials {
  background:
    radial-gradient(circle at top center, rgba(255, 166, 101, 0.12), transparent 32%),
    #fff;
  padding: clamp(3rem, 6vw, 5rem) 0;
}

.ch-essentials__grid {
  display: grid;
  gap: 1.25rem;
  grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
}

.ch-card {
  background: linear-gradient(180deg, #ffffff, #f7f8fb);
  border: 1px solid rgba(56,72,98,0.08);
  border-radius: 18px;
  box-shadow: 0 16px 40px rgba(56,72,98,0.08);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  text-decoration: none;
  transition: box-shadow 0.2s, transform 0.2s;
}

.ch-card::before {
  background: linear-gradient(90deg, #FFA665, rgba(255, 166, 101, 0.25));
  content: '';
  height: 4px;
  left: 0;
  position: absolute;
  right: 0;
  top: 0;
}

.ch-card:hover {
  box-shadow: 0 24px 50px rgba(56,72,98,0.14);
  transform: translateY(-6px);
}

.ch-card__img {
  aspect-ratio: 4/3;
  display: block;
  object-fit: cover;
  transition: transform 0.3s ease;
  width: 100%;
}

.ch-card:hover .ch-card__img,
.ch-kit-card:hover .ch-kit-card__img {
  transform: scale(1.04);
}

.ch-card__img-placeholder {
  align-items: center;
  aspect-ratio: 4/3;
  background: #384862;
  color: #FFA665;
  display: flex;
  font-size: 2rem;
  font-weight: 800;
  justify-content: center;
  width: 100%;
}

.ch-card__body {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  padding: 1rem 1.1rem 1.25rem;
}

.ch-card__badge {
  background: #FFA665;
  border-radius: 999px;
  box-shadow: 0 10px 22px rgba(255, 166, 101, 0.28);
  color: #384862;
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.06em;
  margin-bottom: 0.5rem;
  padding: 0.2rem 0.5rem;
  text-transform: uppercase;
}

.ch-card__title {
  color: #384862;
  font-size: 1rem;
  font-weight: 700;
  margin: 0 0 0.35rem;
}

.ch-card__desc {
  color: #666;
  flex-grow: 1;
  font-size: 0.85rem;
  line-height: 1.4;
  margin: 0 0 0.5rem;
}

.ch-card__price {
  color: #384862;
  font-size: 0.9rem;
  font-weight: 600;
  margin: 0;
}

/* ====================================================
   3. QR PRO
==================================================== */
.ch-qrpro {
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 166, 101, 0.18), transparent 22%),
    linear-gradient(180deg, #384862, #2f3d53);
  padding: clamp(3rem, 6vw, 5.5rem) 0;
}

.ch-qrpro__inner {
  align-items: center;
  display: grid;
  gap: clamp(2rem, 5vw, 4rem);
  grid-template-columns: 1fr;
}

@media screen and (min-width: 768px) {
  .ch-qrpro__inner { grid-template-columns: 1fr 1fr; }
}

.ch-qrpro__text h2 {
  color: #fff;
  font-size: clamp(1.5rem, 3.5vw, 2.2rem);
  letter-spacing: -0.02em;
  margin: 0.5rem 0 1rem;
  text-wrap: balance;
}

.ch-qrpro__text p {
  color: rgba(255,255,255,0.8);
  font-size: 0.98rem;
  line-height: 1.65;
  margin: 0 0 1.25rem;
}

.ch-qrpro__features {
  color: rgba(255,255,255,0.85);
  display: grid;
  font-size: 0.93rem;
  gap: 0.6rem;
  line-height: 1.5;
  list-style: none;
  margin: 0 0 1.75rem;
  padding: 0;
}

.ch-qrpro__features li {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 0.85rem 1rem;
}

.ch-qrpro__features li::before {
  color: #FFA665;
  content: '✓  ';
  font-weight: 700;
}

.ch-qrpro__visual {
  display: flex;
  justify-content: center;
}

.ch-qrpro__mockup-wrap {
  align-items: center;
  display: grid;
  min-height: 340px;
  place-items: center;
  position: relative;
  width: min(100%, 360px);
}

.ch-qrpro__mockup-orb {
  border-radius: 999px;
  filter: blur(6px);
  position: absolute;
}

.ch-qrpro__mockup-orb--one {
  background: rgba(255, 166, 101, 0.35);
  height: 120px;
  left: 10%;
  top: 10%;
  width: 120px;
}

.ch-qrpro__mockup-orb--two {
  background: rgba(255, 255, 255, 0.12);
  bottom: 12%;
  height: 90px;
  right: 12%;
  width: 90px;
}

.ch-qrpro__mockup {
  align-items: center;
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 28px;
  box-shadow: 0 26px 60px rgba(18, 24, 34, 0.35);
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  max-width: 280px;
  padding: 1.25rem;
  position: relative;
  width: 100%;
}

.ch-qrpro__mockup svg { width: 100%; }

.ch-qrpro__mockup-label {
  color: rgba(255,255,255,0.5);
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  margin: 0;
  text-transform: uppercase;
}

/* ====================================================
   4. BUSINESS KITS
==================================================== */
.ch-kits {
  background:
    linear-gradient(180deg, #f4f6f9, #eef2f7);
  padding: clamp(3rem, 6vw, 5rem) 0;
}

.ch-kits__grid {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: repeat(3, minmax(280px, 1fr));
  margin-inline: auto;
  max-width: 1240px;
  width: 100%;
}

.ch-kits__subtitle {
  color: rgba(56,72,98,0.82);
  font-size: clamp(0.98rem, 2vw, 1.08rem);
  line-height: 1.6;
  margin: 0.75rem auto 0;
  max-width: 760px;
  text-wrap: pretty;
}

.ch-kit-card {
  background: #fff;
  border: 1px solid rgba(56,72,98,0.08);
  border-radius: 22px;
  box-shadow: 0 18px 42px rgba(56,72,98,0.08);
  display: flex;
  flex-direction: column;
  justify-content: stretch;
  min-height: 405px;
  overflow: hidden;
  transition: box-shadow 0.2s, transform 0.2s;
}

.ch-kit-card:hover {
  box-shadow: 0 24px 52px rgba(56,72,98,0.14);
  transform: translateY(-6px);
}

.ch-kit-card--featured {
  background: linear-gradient(180deg, #fffdfb, #fff7f0);
  border-color: rgba(255,166,101,0.58);
  box-shadow: 0 24px 54px rgba(255,166,101,0.2);
}

.ch-kit-card--featured:hover {
  box-shadow: 0 28px 58px rgba(255,166,101,0.24);
}

.ch-kit-card__body {
  align-items: stretch;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  padding: 1.7rem 1.35rem;
  text-align: center;
}

.ch-kit-card__flag {
  background: #384862;
  border-radius: 999px;
  box-shadow: 0 12px 24px rgba(56,72,98,0.18);
  color: #fff;
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  margin: 0 0 0.9rem;
  padding: 0.4rem 0.75rem;
  text-transform: uppercase;
}

.ch-kit-card__eyebrow {
  color: #FFA665;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  line-height: 1.2;
  margin: 0 0 0.7rem;
  text-transform: uppercase;
}

.ch-kit-card__body h3 {
  color: #384862;
  font-size: clamp(1.35rem, 3vw, 1.85rem);
  font-weight: 800;
  line-height: 1.1;
  margin: 0 0 0.95rem;
  text-wrap: balance;
}

.ch-kit-card__features {
  align-content: start;
  display: grid;
  flex: 1 1 auto;
  gap: 0.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
  text-align: left;
}

.ch-kit-card__features li {
  align-items: flex-start;
  background: #F6F8FB;
  border: 1px solid rgba(56,72,98,0.08);
  border-radius: 12px;
  color: rgba(56,72,98,0.92);
  display: grid;
  font-size: 0.93rem;
  gap: 0.7rem;
  grid-template-columns: 18px 1fr;
  line-height: 1.45;
  padding: 0.62rem 0.78rem;
}

.ch-kit-card--featured .ch-kit-card__features li {
  background: rgba(255, 166, 101, 0.08);
  border-color: rgba(255, 166, 101, 0.18);
}

.ch-kit-card__features li::before {
  color: #FFA665;
  content: '✓';
  font-size: 0.9rem;
  font-weight: 900;
  line-height: 1.45;
  text-align: center;
}

.ch-kit-card__feature-text {
  min-width: 0;
}

.ch-kit-card__feature-highlight {
  color: #FFA665;
  display: block;
  font-weight: 800;
  grid-column: 2;
  white-space: nowrap;
}

.ch-kit-card__button {
  margin-top: 1.2rem;
  min-height: 48px;
  width: 100%;
}

/* ====================================================
   5. CUSTOM CTA
==================================================== */
.ch-cta {
  background:
    radial-gradient(circle at top center, rgba(255,255,255,0.35), transparent 26%),
    #FFA665;
  padding: clamp(3.5rem, 7vw, 5.5rem) 0;
  text-align: center;
}

.ch-cta__inner {
  background: rgba(255,255,255,0.3);
  border: 1px solid rgba(56,72,98,0.08);
  border-radius: 28px;
  box-shadow: 0 24px 46px rgba(170, 101, 41, 0.18);
  display: grid;
  justify-items: center;
  max-width: 700px;
  padding: clamp(1.5rem, 4vw, 2.4rem);
}

.ch-cta h2 {
  color: #384862;
  font-size: clamp(1.6rem, 4vw, 2.5rem);
  margin: 0 0 1rem;
}

.ch-cta p {
  color: #384862;
  font-size: 1rem;
  line-height: 1.6;
  margin: 0 0 2rem;
  opacity: 0.85;
}

.ch-cta__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
}

.ch-cta .ch-btn--primary {
  background: #384862;
  color: #fff;
}

/* ====================================================
   MOBILE
==================================================== */
@media screen and (max-width: 749px) {
  .ch-hero {
    min-height: auto;
    padding-top: 4rem;
  }

  .ch-hero__inner {
    border-radius: 22px;
    padding: 1.25rem;
  }

  .ch-hero__actions {
    flex-direction: column;
    width: 100%;
  }

  .ch-hero__actions .ch-btn { width: 100%; }

  .ch-essentials__grid { grid-template-columns: repeat(2, 1fr); }

  .ch-kits__grid { grid-template-columns: 1fr; }

  .ch-qrpro__mockup-wrap {
    min-height: 280px;
    width: 100%;
  }

  .ch-cta__actions { flex-direction: column; width: 100%; }
  .ch-cta__actions .ch-btn { width: 100%; }
}

@media screen and (max-width: 480px) {
  .ch-essentials__grid { grid-template-columns: 1fr; }
}
{% endstylesheet %}

