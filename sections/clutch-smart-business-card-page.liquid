<section class="smart-card-page" aria-labelledby="smart-card-title">
  <div class="smart-card-page__hero">
    <div class="smart-card-page__copy">
      <p class="smart-card-page__eyebrow">Smart Clutch Card</p>
      <h1 id="smart-card-title">Metal NFC + QR cards powered by Clutch Connect.</h1>
      <p>
        Premium NTAG213 metal NFC cards with a dynamic QR backup, Clutch Connect profile,
        lead capture, contact save options, and tap/scan analytics.
      </p>
      <div class="smart-card-page__price" aria-label="Smart Clutch Card highlights">
        <span>$49.99 one-time card price</span>
        <span>Clutch Connect Basic included free</span>
        <span>NFC tap + QR scan access</span>
      </div>
      <div class="smart-card-page__actions">
        <a class="smart-card-page__button smart-card-page__button--primary" href="/products/clutch-connect-card">
          Shop Smart Clutch Card
        </a>
        <a class="smart-card-page__button smart-card-page__button--secondary" href="/pages/contact">
          Request Custom Quote
        </a>
      </div>
    </div>

    <div class="smart-card-page__visual">
      {% render 'clutch-connect-card-mockup' %}
    </div>
  </div>

  <div class="smart-card-page__band">
    <div class="smart-card-page__section-heading">
      <p class="smart-card-page__eyebrow">Includes Clutch Connect Basic Free</p>
      <h2>Every Smart Business Card includes a free Clutch Connect Basic profile.</h2>
      <p>
        Every Smart Business Card includes a free Clutch Connect Basic profile, so customers can tap your card and instantly
        view your contact info, links, request form, and save-contact options.
      </p>
      <ul class="smart-card-page__included-list" aria-label="Included with Smart Business Card">
        <li>Metal Smart Business Card</li>
        <li>Clutch Connect Basic profile</li>
        <li>NFC tap + QR scan access</li>
        <li>Contact buttons</li>
        <li>Social links</li>
        <li>Basic request form</li>
        <li>Save contact option</li>
      </ul>
      <p class="smart-card-page__upgrade-callout">
        Optional upgrades: Add Connect+ for advanced profile customization, custom forms,
        lead tools, profile analytics, and branding controls.
        Add QR Pro when you need dynamic QR codes and print campaign tracking.
      </p>
    </div>
  </div>

  <div class="smart-card-page__band">
    <div class="smart-card-page__section-heading">
      <p class="smart-card-page__eyebrow">How It Works</p>
      <h2>Share faster, update anytime, and know what is working.</h2>
    </div>
    <div class="smart-card-page__steps">
      <article>
        <span>01</span>
        <h3>Tap or Scan</h3>
        <p>Your metal NFC card opens your editable digital profile with a tap, while the QR code gives every phone a scan option.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Get Saved</h3>
        <p>Customers can call, text, visit your website, leave a review, book, or save your contact details in seconds.</p>
      </article>
      <article>
        <span>03</span>
        <h3>Track Engagement</h3>
        <p>Clutch Connect powers editable destinations, dashboard access, and scan/tap analytics for your card.</p>
      </article>
    </div>
  </div>

  <div class="smart-card-page__split">
    <div>
      <p class="smart-card-page__eyebrow">NTAG213 Metal Card. Clutch Profile.</p>
      <h2>Built on real NFC card hardware and connected to your live profile.</h2>
      <p>
        Your card uses NTAG213 NFC technology and is programmed to a dynamic destination URL. After checkout,
        setup guidance directs you into the Clutch portal where your profile, links, and destinations can be managed.
      </p>
    </div>
    <div class="smart-card-page__features">
      <span>Dynamic QR code</span>
      <span>NFC tap destination</span>
      <span>Editable Clutch Profile</span>
      <span>Contact save options where available</span>
      <span>Lead capture form</span>
      <span>Scan/tap tracking</span>
      <span>Basic analytics dashboard</span>
      <span>PNG, SVG, JPEG, and PDF QR downloads</span>
      <span>Unlimited profile updates</span>
      <span>NTAG213 NFC chip</span>
      <span>CR80 metal card format</span>
    </div>
  </div>

  <div class="smart-card-page__band">
    <div class="smart-card-page__section-heading">
      <p class="smart-card-page__eyebrow">What Clutch Connect Includes</p>
      <h2>The live profile and analytics behind your physical card.</h2>
      <p>
        Clutch Connect powers your digital profile, dynamic QR destination, NFC tap destination,
        scan/tap tracking, lead capture, contact save options where available, and QR downloads.
      </p>
    </div>
  </div>

  <div class="smart-card-page__specs">
    <div class="smart-card-page__section-heading">
      <p class="smart-card-page__eyebrow">Card Specs</p>
      <h2>Premium NTAG213 metal NFC cards.</h2>
      <p>Aligned with our wholesale metal NFC card supply so your storefront, QR portal, and fulfillment details match.</p>
    </div>
    <div class="smart-card-page__spec-grid">
      <article><span>Chip</span><strong>NTAG213</strong><p>13.56 MHz NFC with 7-byte UID and 144 bytes memory.</p></article>
      <article><span>Size</span><strong>CR80</strong><p>85.5 mm x 54 mm x 1.2 mm metal card format.</p></article>
      <article><span>Antenna</span><strong>40 mm</strong><p>Internal 40 mm x 40 mm aluminum antenna construction.</p></article>
      <article><span>Durability</span><strong>Rigid + water resistant</strong><p>Metal/PET/PVC construction suitable for premium everyday use.</p></article>
    </div>
  </div>

  <div class="smart-card-page__finishes">
    <div class="smart-card-page__section-heading">
      <p class="smart-card-page__eyebrow">Finish Options</p>
      <h2>Choose a card finish that matches your brand.</h2>
    </div>
    <div class="smart-card-page__finish-grid">
      <article class="smart-card-page__finish smart-card-page__finish--black">
        <div aria-hidden="true"></div>
        <h3>Matte Black Metal</h3>
        <p>Black metal card with silver edge styling, built for crisp laser engraving.</p>
      </article>
      <article class="smart-card-page__finish smart-card-page__finish--silver">
        <div aria-hidden="true"></div>
        <h3>Brushed Silver Metal</h3>
        <p>Silver plated finish with matching silver edge for a clean polished look.</p>
      </article>
      <article class="smart-card-page__finish smart-card-page__finish--gold">
        <div aria-hidden="true"></div>
        <h3>Brushed Gold Metal</h3>
        <p>Gold plated finish with matching gold edge for a bold premium impression.</p>
      </article>
    </div>
  </div>

  <div class="smart-card-page__after">
    <div class="smart-card-page__section-heading">
      <p class="smart-card-page__eyebrow">After Checkout</p>
      <h2>What happens after you order?</h2>
    </div>
    <div class="smart-card-page__timeline">
      <article>
        <h3>1. Place your order</h3>
        <p>Choose matte black, brushed silver, or brushed gold and complete your Shopify order.</p>
      </article>
      <article>
        <h3>2. Start profile setup</h3>
        <p>You receive setup guidance after checkout. Profile setup happens inside the Clutch portal, not on Shopify.</p>
      </article>
      <article>
        <h3>3. Review and activate</h3>
        <p>You review your Clutch Profile, then start using your card to share, save, and track engagement.</p>
      </article>
    </div>
  </div>

  <div class="smart-card-page__faq">
    <div class="smart-card-page__section-heading">
      <p class="smart-card-page__eyebrow">FAQ</p>
      <h2>Smart Clutch Card basics, without the fog.</h2>
    </div>
    <details>
      <summary>Do I need a monthly plan?</summary>
      <p>No. Every Smart Business Card includes Clutch Connect Basic free. You can upgrade to Connect+ for advanced profile tools or QR Pro for campaign tracking.</p>
    </details>
    <details>
      <summary>Can I update my links after the card is made?</summary>
      <p>Yes. Your Clutch Profile can be updated without reprinting or replacing your metal card.</p>
    </details>
    <details>
      <summary>Does it work if someone cannot use NFC?</summary>
      <p>Yes. The card also includes a QR scan option, so customers can still open your profile quickly.</p>
    </details>
  </div>
</section>

{% stylesheet %}
  .smart-card-page {
    background: #fff;
    color: #384862;
    font-family: 'Montserrat', sans-serif;
    overflow: hidden;
  }

  .smart-card-page *,
  .smart-card-page *::before,
  .smart-card-page *::after {
    box-sizing: border-box;
  }

  .smart-card-page__hero,
  .smart-card-page__band,
  .smart-card-page__split,
  .smart-card-page__specs,
  .smart-card-page__finishes,
  .smart-card-page__after,
  .smart-card-page__faq {
    margin-inline: auto;
    max-width: 1180px;
    padding-inline: clamp(1.25rem, 4vw, 2rem);
  }

  .smart-card-page__hero {
    align-items: center;
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr);
    padding-block: clamp(2.5rem, 5vw, 4.25rem);
  }

  .smart-card-page__copy h1,
  .smart-card-page h2 {
    color: #384862;
    font-family: 'Exo 2', sans-serif;
    letter-spacing: -0.02em;
    line-height: 0.98;
    margin: 0;
    text-wrap: balance;
  }

  .smart-card-page__copy h1 {
    font-size: clamp(2.25rem, 4.8vw, 4.35rem);
    max-width: 700px;
  }

  .smart-card-page h2 {
    font-size: clamp(2rem, 4vw, 3.6rem);
  }

  .smart-card-page h3 {
    color: #384862;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    margin: 0;
  }

  .smart-card-page p {
    color: rgba(56, 72, 98, 0.78);
    font-size: clamp(1rem, 1.7vw, 1.16rem);
    line-height: 1.7;
    margin: 0;
  }

  .smart-card-page__copy > p {
    margin-top: 1rem;
    max-width: 620px;
  }

  .smart-card-page__eyebrow {
    color: #FFA665;
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    line-height: 1.2;
    margin: 0 0 0.9rem;
    text-transform: uppercase;
  }

  .smart-card-page__price {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1.15rem 0;
  }

  .smart-card-page__price span,
  .smart-card-page__features span {
    background: #F7F8FA;
    border: 1px solid rgba(255, 166, 101, 0.32);
    border-radius: 999px;
    box-shadow: 0 14px 30px rgba(56, 72, 98, 0.06);
    color: rgba(56, 72, 98, 0.82);
    display: inline-flex;
    font-weight: 750;
    gap: 0.35rem;
    padding: 0.75rem 1rem;
  }

  .smart-card-page__price strong {
    color: #384862;
  }

  .smart-card-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .smart-card-page__button {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    justify-content: center;
    letter-spacing: 0.06em;
    min-height: 52px;
    padding: 0.9rem 1.35rem;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  .smart-card-page__button:hover {
    transform: translateY(-2px);
  }

  .smart-card-page__button--primary {
    background: #FFA665;
    box-shadow: 0 18px 42px rgba(255, 166, 101, 0.32);
    color: #384862;
  }

  .smart-card-page__button--secondary {
    background: #fff;
    border: 1px solid rgba(56, 72, 98, 0.16);
    color: #384862;
  }

  .smart-card-page__upgrade-callout {
    background: #fff7f0;
    border: 1px solid rgba(255, 166, 101, 0.34);
    border-radius: 14px;
    color: #384862 !important;
    font-weight: 800;
    margin-top: 1rem;

  .smart-card-page__included-list {
    display: grid;
    gap: 0.5rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }

  .smart-card-page__included-list li {
    align-items: center;
    background: #fff;
    border: 1px solid rgba(56, 72, 98, 0.12);
    border-radius: 12px;
    color: #384862;
    display: grid;
    gap: 0.55rem;
    grid-template-columns: 14px 1fr;
    line-height: 1.4;
    padding: 0.58rem 0.72rem;
  }

  .smart-card-page__included-list li::before {
    color: #FFA665;
    content: '+';
    font-weight: 900;
    text-align: center;
  }
    padding: 0.9rem;
  }

  .smart-card-page__visual {
    min-width: 0;
  }

  .smart-card-page__band,
  .smart-card-page__specs,
  .smart-card-page__finishes,
  .smart-card-page__after,
  .smart-card-page__faq {
    padding-block: clamp(2.75rem, 7vw, 5rem);
  }

  .smart-card-page__band {
    background:
      radial-gradient(circle at 12% 10%, rgba(255, 166, 101, 0.14), transparent 34%),
      #F7F8FA;
    border-radius: 32px;
  }

  .smart-card-page__section-heading {
    margin: 0 auto clamp(1.5rem, 4vw, 2.5rem);
    max-width: 820px;
    text-align: center;
  }

  .smart-card-page__steps,
  .smart-card-page__finish-grid,
  .smart-card-page__timeline {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .smart-card-page__steps article,
  .smart-card-page__finish,
  .smart-card-page__timeline article,
  .smart-card-page__faq details {
    background: #fff;
    border: 1px solid rgba(255, 166, 101, 0.35);
    border-radius: 22px;
    box-shadow: 0 24px 54px rgba(56, 72, 98, 0.08);
    min-height: 100%;
    padding: clamp(1.2rem, 2.4vw, 1.7rem);
  }

  .smart-card-page__steps span {
    color: #FFA665;
    display: block;
    font-family: 'Exo 2', sans-serif;
    font-size: 0.9rem;
    font-weight: 950;
    letter-spacing: 0.16em;
    margin-bottom: 1.2rem;
  }

  .smart-card-page__steps p,
  .smart-card-page__timeline p,
  .smart-card-page__finish p {
    font-size: 0.98rem;
    margin-top: 0.75rem;
  }

  .smart-card-page__split {
    align-items: center;
    display: grid;
    gap: clamp(1.5rem, 5vw, 3rem);
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 1.1fr);
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }

  .smart-card-page__split p:not(.smart-card-page__eyebrow) {
    margin-top: 1rem;
  }

  .smart-card-page__features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .smart-card-page__specs {
    padding-block: clamp(2.75rem, 7vw, 5rem);
  }

  .smart-card-page__spec-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .smart-card-page__spec-grid article {
    background: #fff;
    border: 1px solid rgba(255, 166, 101, 0.35);
    border-radius: 22px;
    box-shadow: 0 24px 54px rgba(56, 72, 98, 0.08);
    padding: clamp(1.1rem, 2vw, 1.45rem);
  }

  .smart-card-page__spec-grid span {
    color: #FFA665;
    display: block;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin-bottom: 0.65rem;
    text-transform: uppercase;
  }

  .smart-card-page__spec-grid strong {
    color: #384862;
    display: block;
    font-family: 'Exo 2', sans-serif;
    font-size: 1.2rem;
    line-height: 1.1;
  }

  .smart-card-page__spec-grid p {
    font-size: 0.94rem;
    margin-top: 0.7rem;
  }

  .smart-card-page__finish-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .smart-card-page__finish div {
    aspect-ratio: 1.586 / 1;
    border-radius: 22px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.32), inset 0 -18px 46px rgba(0, 0, 0, 0.12);
    margin-bottom: 1.15rem;
    overflow: hidden;
    position: relative;
  }

  .smart-card-page__finish div::before {
    background:
      linear-gradient(115deg, transparent 20%, rgba(255, 255, 255, 0.48) 38%, transparent 58%),
      repeating-linear-gradient(100deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 10px);
    content: '';
    inset: -30%;
    position: absolute;
    transform: rotate(8deg);
  }

  .smart-card-page__finish--black div {
    background: linear-gradient(135deg, #111827, #1e2f4d, #0b1220);
    border: 1px solid rgba(255, 166, 101, 0.38);
  }

  .smart-card-page__finish--silver div {
    background:
      linear-gradient(135deg, rgba(255,255,255,0.72), transparent 42%),
      repeating-linear-gradient(100deg, rgba(56,72,98,0.12) 0 1px, transparent 1px 9px),
      linear-gradient(135deg, #ffffff, #dfe5ed, #bfc8d3);
    border: 1px solid rgba(56, 72, 98, 0.14);
  }

  .smart-card-page__finish--gold div {
    background:
      linear-gradient(135deg, rgba(255,255,255,0.5), transparent 42%),
      repeating-linear-gradient(100deg, rgba(120,75,20,0.12) 0 1px, transparent 1px 9px),
      linear-gradient(135deg, #ffe2a8, #d5a34d, #95621c);
    border: 1px solid rgba(56, 72, 98, 0.14);
  }

  .smart-card-page__timeline {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .smart-card-page__faq {
    max-width: 980px;
  }

  .smart-card-page__faq details + details {
    margin-top: 0.9rem;
  }

  .smart-card-page__faq summary {
    color: #384862;
    cursor: pointer;
    font-family: 'Exo 2', sans-serif;
    font-size: 1.15rem;
    font-weight: 900;
  }

  .smart-card-page__faq details p {
    font-size: 1rem;
    margin-top: 0.8rem;
  }

  @media screen and (max-width: 900px) {
    .smart-card-page__hero,
    .smart-card-page__split {
      grid-template-columns: 1fr;
    }

    .smart-card-page__visual {
      order: -1;
    }

    .smart-card-page__steps,
    .smart-card-page__spec-grid,
    .smart-card-page__timeline {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 680px) {
    .smart-card-page__hero,
    .smart-card-page__band,
    .smart-card-page__split,
    .smart-card-page__finishes,
    .smart-card-page__after,
    .smart-card-page__faq {
      padding-inline: 1rem;
    }

    .smart-card-page__copy h1 {
      font-size: clamp(2.25rem, 13vw, 3.4rem);
    }

    .smart-card-page__actions,
    .smart-card-page__button,
    .smart-card-page__price span {
      width: 100%;
    }

    .smart-card-page__finish-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Smart Clutch Card page",
  "settings": []
}
{% endschema %}
