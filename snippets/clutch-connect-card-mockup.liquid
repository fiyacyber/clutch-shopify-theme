{% doc %}
Static blank metal NFC card showcase inspired by wholesale card finish references.
{% enddoc %}

<div class="ccard-showcase" aria-label="Blank metal Smart Clutch Card finish preview">
  <div class="ccard-showcase__cards">
    <article class="ccard-blank-card ccard-blank-card--black" aria-label="Matte black blank metal NFC card"></article>
    <article class="ccard-blank-card ccard-blank-card--silver" aria-label="Brushed silver blank metal NFC card"></article>
    <article class="ccard-blank-card ccard-blank-card--gold" aria-label="Brushed gold blank metal NFC card"></article>
  </div>

  <div class="ccard-showcase__finish-labels" aria-hidden="true">
    <span>Matte Black</span>
    <span>Brushed Silver</span>
    <span>Brushed Gold</span>
  </div>
</div>

{% stylesheet %}
  .ccard-showcase {
    display: grid;
    gap: 0.7rem;
    margin-inline: auto;
    max-width: 620px;
    width: 100%;
  }

  .ccard-showcase__header {
    align-items: end;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .ccard-showcase__header span {
    color: #FFA665;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ccard-showcase__header strong {
    color: #384862;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1rem, 2.2vw, 1.45rem);
    line-height: 1.05;
    text-align: right;
  }

  .ccard-showcase__cards {
    display: grid;
    gap: clamp(0.75rem, 2vw, 1rem);
  }

  .ccard-blank-card {
    aspect-ratio: 1.586 / 1;
    border-radius: 18px;
    box-shadow: 0 20px 42px rgba(15, 23, 42, 0.18);
    display: grid;
    overflow: hidden;
    padding: 0;
    position: relative;
  }

  .ccard-blank-card::before {
    background:
      linear-gradient(115deg, transparent 18%, rgba(255, 255, 255, 0.58) 42%, transparent 62%),
      repeating-linear-gradient(100deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 10px);
    content: '';
    inset: -24%;
    opacity: 0.55;
    pointer-events: none;
    position: absolute;
    transform: rotate(7deg);
  }

  .ccard-blank-card--black {
    background:
      linear-gradient(135deg, #101827 0%, #1e2b44 45%, #060a13 100%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
  }

  .ccard-blank-card--silver {
    background:
      repeating-linear-gradient(100deg, rgba(56, 72, 98, 0.12) 0 1px, transparent 1px 10px),
      linear-gradient(135deg, #ffffff 0%, #dfe5ed 52%, #bfc8d3 100%);
    border: 1px solid rgba(56, 72, 98, 0.16);
    color: #071D33;
  }

  .ccard-blank-card--gold {
    background:
      repeating-linear-gradient(100deg, rgba(120, 75, 20, 0.14) 0 1px, transparent 1px 10px),
      linear-gradient(135deg, #ffe2a8 0%, #d5a34d 52%, #95621c 100%);
    border: 1px solid rgba(120, 75, 20, 0.18);
    color: #071D33;
  }

  .ccard-showcase__finish-labels {
    display: grid;
    gap: clamp(0.75rem, 2vw, 1rem);
  }

  .ccard-showcase__finish-labels span {
    color: #384862;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-align: center;
    text-transform: uppercase;
  }

  .ccard-showcase__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .ccard-showcase__highlights span {
    background: #fff7f0;
    border: 1px solid rgba(255, 166, 101, 0.36);
    border-radius: 999px;
    color: #384862;
    font-size: 0.78rem;
    font-weight: 850;
    padding: 0.52rem 0.72rem;
  }

  @media (min-width: 760px) {
    .ccard-showcase__cards {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .ccard-showcase__finish-labels {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .ccard-blank-card {
      min-height: 136px;
    }
  }

  @media (max-width: 759px) {
    .ccard-showcase__header {
      align-items: start;
      display: grid;
    }

    .ccard-showcase__header strong {
      text-align: left;
    }

    .ccard-showcase__highlights span {
      width: 100%;
    }
  }
{% endstylesheet %}
