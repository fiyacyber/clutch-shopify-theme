{% doc %}
  Clutch print product options.

  Renders print-specific line item properties inside the existing Shopify product form.
  Theme-only line item properties capture customer intent; paid add-on charging should be backed by real Shopify products,
  variants, selling plans, or an app before launch.

  @param {object} product - The current product.
  @param {string} section_id - The parent section ID used for unique form control IDs.
{% enddoc %}

{% liquid
  assign product_handle = product.handle | downcase
  assign is_business_kit = false
  assign is_connect_card = false
  assign tracked_print_enabled = false

  if product.metafields.custom.tracked_print_enabled.value == true
    assign tracked_print_enabled = true
  endif

  case product_handle
    when 'starter-business-kit', 'growth-business-kit', 'starter-kit', 'startup-kit', 'growth-kit'
      assign is_business_kit = true
  endcase

  if product_handle == 'clutch-connect-card'
    assign is_connect_card = true
  endif

  assign professional_design_product = all_products['professional-design']
  assign professional_design_variant = professional_design_product.selected_or_first_available_variant
  assign professional_design_variant_id = professional_design_variant.id | default: 44481017970730
  assign smart_card_engraving_addon_product = all_products['smart-card-engraving-add-on']
  assign smart_card_engraving_addon_variant = smart_card_engraving_addon_product.selected_or_first_available_variant
  assign smart_card_engraving_addon_variant_id = smart_card_engraving_addon_variant.id

  assign no_engraving_variant_id = blank
  assign add_engraving_variant_id = blank
  for product_variant in product.variants
    if product_variant.options contains 'No Engraving' and no_engraving_variant_id == blank
      assign no_engraving_variant_id = product_variant.id
    endif
    if product_variant.options contains 'Add Engraving' and add_engraving_variant_id == blank
      assign add_engraving_variant_id = product_variant.id
    endif
  endfor

%}

<div class="clutch-print-options" id="clutch-artwork-upload" data-clutch-print-options>
  {% if is_connect_card %}
    <div
      class="smart-card-engraving"
      data-smart-card-engraving
      data-no-engraving-variant-id="{{ no_engraving_variant_id }}"
      data-add-engraving-variant-id="{{ add_engraving_variant_id }}"
    >
      <button
        class="smart-card-engraving__trigger"
        type="button"
        data-smart-card-engraving-trigger
        aria-expanded="false"
      >
        <span>ADD CUSTOM ENGRAVING (+ $10)</span>
      </button>

      <div class="smart-card-engraving__content" data-smart-card-engraving-content hidden>
        <input
          id="smart-card-engraving-toggle-{{ section_id }}"
          type="checkbox"
          data-smart-card-engraving-toggle
          hidden
        >

        <input
          id="smart-card-engraving-addon-{{ section_id }}"
          type="checkbox"
          form="BuyButtons-ProductForm-{{ section_id }}"
          data-smart-card-engraving-addon
          data-clutch-addon-variant-id="{{ smart_card_engraving_addon_variant_id }}"
          data-clutch-addon-title="Smart Card Custom Engraving"
          data-clutch-addon-quantity="1"
          data-clutch-addon-unique="true"
          {% if smart_card_engraving_addon_variant_id == blank %}disabled{% endif %}
          hidden
        >

        <div class="smart-card-engraving__fields" data-smart-card-engraving-fields hidden>
          <label>
            <span>Business Name</span>
            <input type="text" name="properties[Business Name]" data-smart-card-engraving-field disabled>
          </label>
          <label>
            <span>Title</span>
            <input type="text" name="properties[Title]" data-smart-card-engraving-field disabled>
          </label>
          <label>
            <span>Business Phone Number</span>
            <input type="tel" name="properties[Business Phone Number]" data-smart-card-engraving-field disabled>
          </label>
          <label>
            <span>Business Email</span>
            <input type="email" name="properties[Business Email]" data-smart-card-engraving-field disabled>
          </label>
          <label>
            <span>Custom Details (Optional)</span>
            <textarea name="properties[Custom details]" rows="4" placeholder="Want to add a logo or branding? No problem. Tell us what you need!" data-smart-card-engraving-field data-smart-card-engraving-optional disabled></textarea>
          </label>
        </div>

        <p class="smart-card-engraving__error" data-smart-card-engraving-error hidden>
          Please complete your engraving details before adding the card to cart.
        </p>
      </div>
    </div>

    <script>
      (function () {
        const container = document.querySelector('[data-smart-card-engraving]');
        if (!container || container.dataset.bound === 'true') return;
        container.dataset.bound = 'true';

        const form = container.closest('form');
        if (!form) return;

        const trigger = container.querySelector('[data-smart-card-engraving-trigger]');
        const content = container.querySelector('[data-smart-card-engraving-content]');
        const toggle = container.querySelector('[data-smart-card-engraving-toggle]');
        const fieldsWrap = container.querySelector('[data-smart-card-engraving-fields]');
        const engravingAddon = container.querySelector('[data-smart-card-engraving-addon]');
        const fields = Array.from(container.querySelectorAll('[data-smart-card-engraving-field]'));
        const error = container.querySelector('[data-smart-card-engraving-error]');

        const getAddToCartButton = () => form.querySelector('[name="add"], .add-to-cart-button');

        const noEngravingVariantId = container.getAttribute('data-no-engraving-variant-id');
        const addEngravingVariantId = container.getAttribute('data-add-engraving-variant-id');
        const hasEngravingVariantMapping = !!(noEngravingVariantId && addEngravingVariantId);
        const variantPicker = document.querySelector('variant-picker[data-product-id="{{ product.id }}"]');

        const setVariantByValue = (value, fallbackVariantId) => {
          if (variantPicker) {
            const radio = variantPicker.querySelector(`input[type="radio"][value="${value}"]`);
            if (radio) {
              radio.checked = true;
              radio.dispatchEvent(new Event('change', { bubbles: true }));
              radio.dispatchEvent(new Event('click', { bubbles: true }));
              return;
            }

            const option = Array.from(variantPicker.querySelectorAll('option')).find((opt) => (opt.value || '').toLowerCase() === value.toLowerCase());
            if (option) {
              option.selected = true;
              option.parentElement.dispatchEvent(new Event('change', { bubbles: true }));
              return;
            }
          }

          if (fallbackVariantId) {
            const variantInput = form.querySelector('input[name="id"]');
            if (variantInput) {
              variantInput.value = fallbackVariantId;
              variantInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
          }
        };

        const syncEngravingState = () => {
          const enabled = !!(toggle && toggle.checked);
          if (trigger) trigger.setAttribute('aria-expanded', enabled ? 'true' : 'false');
          if (content) content.hidden = !enabled;
          if (fieldsWrap) fieldsWrap.hidden = !enabled;
          if (engravingAddon) {
            engravingAddon.checked = enabled;
          }
          fields.forEach((field) => {
            field.disabled = !enabled;
            if (!enabled) field.value = '';
          });

          if (hasEngravingVariantMapping) {
            if (enabled) {
              setVariantByValue('Add Engraving', addEngravingVariantId);
            } else {
              setVariantByValue('No Engraving', noEngravingVariantId);
            }
          }

          syncValidationUi();
        };

        const hasMissingRequiredEngraving = () => {
          if (!(toggle && toggle.checked)) return false;
          return fields.some((field) => {
            if (field.hasAttribute('data-smart-card-engraving-optional')) return false;
            return !(field.value || '').trim();
          });
        };

        const syncValidationUi = () => {
          const missingRequired = hasMissingRequiredEngraving();
          const addToCartButton = getAddToCartButton();

          if (error) {
            error.hidden = !missingRequired;
          }

          if (addToCartButton) {
            addToCartButton.disabled = missingRequired;
            addToCartButton.setAttribute('aria-disabled', missingRequired ? 'true' : 'false');
          }
        };

        const blockWithErrorIfNeeded = (event) => {
          if (!hasMissingRequiredEngraving()) {
            syncValidationUi();
            return false;
          }
          event.preventDefault();
          event.stopImmediatePropagation();
          if (error) error.hidden = false;
          if (content && content.hidden) {
            trigger?.setAttribute('aria-expanded', 'true');
            content.hidden = false;
          }
          fields.find((field) => !(field.value || '').trim())?.focus();
          return true;
        };

        if (trigger && content) {
          trigger.addEventListener('click', () => {
            if (!toggle) return;
            toggle.checked = !toggle.checked;
            toggle.dispatchEvent(new Event('change', { bubbles: true }));
          });
        }

        toggle?.addEventListener('change', syncEngravingState);

        fields.forEach((field) => {
          field.addEventListener('input', syncValidationUi);
          field.addEventListener('change', syncValidationUi);
          field.addEventListener('blur', syncValidationUi);
        });

        form.addEventListener('submit', (event) => {
          blockWithErrorIfNeeded(event);
        }, true);

        getAddToCartButton()?.addEventListener('click', (event) => {
          blockWithErrorIfNeeded(event);
        }, true);

        form.addEventListener('click', (event) => {
          const target = event.target && event.target.closest ? event.target.closest('[name="add"], .add-to-cart-button') : null;
          if (!target) return;
          blockWithErrorIfNeeded(event);
        }, true);

        syncEngravingState();
        syncValidationUi();
      })();
    </script>
  {% else %}
    <p class="clutch-eyebrow">Premium print products with built-in marketing tools.</p>
    {% unless is_business_kit %}
      <p class="clutch-supporting-copy">
        Upload print-ready artwork, or add Professional Design for a $200 flat fee if you need help creating your file.
      </p>
    {% endunless %}

    {% if is_business_kit %}
      <div class="clutch-option-card clutch-option-card--included" data-business-kit-design-included>
        <p class="clutch-field-label">{{ 'tracked_print.business_kit.design_title' | t }}</p>
        <p class="clutch-design-value">{{ 'tracked_print.business_kit.design_value' | t }}</p>
        <p class="clutch-field-help">{{ 'tracked_print.business_kit.design_help' | t }}</p>
      </div>
    {% endif %}

    {% if tracked_print_enabled %}
      {% render 'tracked-print-product-controls', section_id: section_id, is_business_kit: is_business_kit %}
    {% elsif is_business_kit %}
      {% render 'tracked-print-product-controls', section_id: section_id, is_business_kit: true, artwork_only: true %}
    {% endif %}

    {% unless tracked_print_enabled or is_business_kit %}
    <div class="clutch-option-card clutch-option-card--highlight">
      <label class="clutch-field-label" for="clutch-artwork-file-{{ section_id }}">Artwork &amp; File Upload</label>
      <input
        id="clutch-artwork-file-{{ section_id }}"
        class="clutch-file-input field__input"
        type="file"
        name="properties[Artwork upload]"
        accept=".pdf,.ai,.eps,.psd,.png,.jpg,.jpeg,application/pdf,image/png,image/jpeg"
      >
      <p class="clutch-field-help">
        Accepted files: PDF, AI, EPS, PSD, PNG, JPG. 300 DPI recommended. 0.125 inch bleed required when applicable.
      </p>
    </div>
    {% endunless %}

    {% unless is_business_kit %}
      <div class="clutch-option-card">
        <label class="clutch-checkbox-row" for="clutch-professional-design-{{ section_id }}">
          <input
            id="clutch-professional-design-{{ section_id }}"
            type="checkbox"
            data-clutch-addon-variant-id="{{ professional_design_variant_id }}"
            data-clutch-addon-title="Professional Design"
            data-clutch-addon-quantity="1"
            data-clutch-addon-unique="true"
          >
          <span>
            <strong>Professional Design Add-On</strong>
            <small>$200 flat fee. Clutch will create a clean, print-ready layout for your order.</small>
          </span>
        </label>
      </div>
    {% endunless %}

    <div class="clutch-option-card clutch-option-card--shipping">
      <p class="clutch-field-label">Free Shipping</p>
      <p class="clutch-field-help">Free shipping is included on all orders across the shop.</p>
    </div>

    {% unless is_business_kit %}
      <div class="clutch-option-card clutch-option-card--qr">
        <p class="clutch-field-label">Clutch Codes™</p>
        <p class="clutch-field-help">
          One Clutch Code is included with eligible print campaigns. The same code is printed across the ordered quantity
          for that campaign or material type.
        </p>
        <a class="clutch-option-link" href="/pages/qr-pro">Explore Clutch Codes Plans</a>
      </div>
    {% endunless %}
  {% endif %}

  <input type="hidden" name="properties[Clutch print product]" value="{{ product.title | escape }}">
</div>

{% stylesheet %}
  .clutch-print-options {
    display: grid;
    gap: var(--gap-md);
    margin-block-start: var(--gap-md);
  }

  .smart-card-engraving {
    border: 0;
    border-radius: 0;
    display: grid;
    justify-items: center;
    overflow: visible;
    width: 100%;
  }

  .smart-card-engraving__trigger {
    align-items: center !important;
    background: #f5a161;
    border: 1px solid rgba(245, 161, 97, 0.95);
    border-radius: 999px;
    color: #ffffff;
    cursor: pointer;
    display: inline-flex !important;
    justify-items: center;
    justify-content: center;
    margin: 0.55rem auto;
    min-height: 44px;
    padding: 0.72rem 1.15rem;
    text-align: center !important;
    width: auto;
    max-width: 100%;
  }

  .smart-card-engraving__trigger span {
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .smart-card-engraving__trigger small {
    color: #ffffff;
    font-size: 0.88rem;
    text-align: center;
  }

  .smart-card-engraving__content {
    border-top: 1px solid rgba(56, 72, 98, 0.12);
    display: grid;
    gap: 0.8rem;
    padding: 0.95rem 1rem 1rem;
  }

  .smart-card-engraving__content[hidden] {
    display: none !important;
  }

  .smart-card-engraving [data-smart-card-engraving-toggle] {
    appearance: none !important;
    border: 0 !important;
    height: 0 !important;
    margin: 0 !important;
    opacity: 0 !important;
    padding: 0 !important;
    pointer-events: none !important;
    position: absolute !important;
    visibility: hidden !important;
    width: 0 !important;
  }

  .smart-card-engraving__toggle {
    align-items: center;
    color: #384862;
    display: flex;
    font-weight: 700;
    gap: 0.55rem;
  }

  .smart-card-engraving__fields {
    display: grid;
    gap: 0.65rem;
  }

  .smart-card-engraving__fields[hidden] {
    display: none !important;
  }

  .smart-card-engraving__fields label {
    display: grid;
    gap: 0.3rem;
  }

  .smart-card-engraving__fields span {
    color: #384862;
    font-size: 0.86rem;
    font-weight: 700;
  }

  .smart-card-engraving__fields input {
    background: #fff;
    border: 1px solid rgba(56, 72, 98, 0.2);
    border-radius: 10px;
    color: #384862;
    min-height: 44px;
    padding: 0.58rem 0.7rem;
    width: 100%;
  }

  .smart-card-engraving__fields textarea {
    background: #fff;
    border: 1px solid rgba(56, 72, 98, 0.2);
    border-radius: 10px;
    color: #384862;
    min-height: 96px;
    padding: 0.58rem 0.7rem;
    resize: vertical;
    width: 100%;
  }

  .smart-card-engraving__fields textarea[name='properties[Custom details]']:hover {
    background: #fff;
    border-color: rgba(56, 72, 98, 0.2);
    box-shadow: none;
    transform: none;
  }

  .smart-card-engraving__error {
    background: rgba(255, 166, 101, 0.14);
    border: 1px solid rgba(255, 166, 101, 0.55);
    border-radius: 10px;
    color: #384862;
    font-size: 0.86rem;
    font-weight: 700;
    margin: 0;
    padding: 0.62rem 0.72rem;
  }

  .clutch-supporting-copy {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.8);
  }

  .clutch-info-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--gap-md);
  }

  .clutch-info-grid--top {
    margin-block-start: var(--gap-2xs);
  }

  .clutch-info-panel,
  .clutch-option-card,
  .clutch-addon-callout {
    border: 1px solid rgb(var(--color-border-rgb) / 0.7);
    border-radius: 24px;
    background: linear-gradient(180deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 1));
    box-shadow: var(--shadow-popover);
    padding: clamp(var(--gap-md), 2vw, var(--gap-xl));
  }

  .clutch-info-panel--featured,
  .clutch-option-card--highlight,
  .clutch-addon-callout--qr {
    background:
      linear-gradient(180deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 1)),
      linear-gradient(135deg, rgb(56 72 98 / 0.05), rgb(255 166 101 / 0.1));
  }

  .clutch-option-card--included {
    background: linear-gradient(135deg, rgb(255 166 101 / 0.12), rgb(var(--color-background-rgb) / 1));
  }

  .clutch-design-value {
    color: #a64700;
    font-weight: 800;
    margin: 0 0 var(--gap-xs);
  }

  .clutch-option-card--shipping {
    background:
      linear-gradient(180deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 1)),
      linear-gradient(135deg, rgb(255 166 101 / 0.08), rgb(56 72 98 / 0.04));
  }

  .clutch-option-link {
    color: #384862;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .clutch-info-panel h3,
  .clutch-option-card .clutch-field-label,
  .clutch-addon-callout h3 {
    margin-top: 0;
    margin-bottom: var(--gap-xs);
    color: #384862;
  }

  .clutch-info-panel ul,
  .clutch-addon-badges {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .clutch-info-panel li {
    position: relative;
    padding-left: 1.35rem;
  }

  .clutch-info-panel li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.35rem;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    background: #ffa665;
    box-shadow: 0 0 0 4px rgb(255 166 101 / 0.16);
  }

  .clutch-addon-callout {
    display: grid;
    gap: var(--gap-sm);
  }

  .clutch-addon-badges {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .clutch-addon-badges span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 0.85rem;
    border-radius: 999px;
    background: rgb(56 72 98 / 0.07);
    color: #384862;
    font-size: var(--font-size--sm);
    font-weight: 600;
  }

  .clutch-field-label {
    display: block;
    margin-bottom: var(--gap-xs);
    font-weight: 700;
  }

  .clutch-checkbox-row {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-sm);
    cursor: pointer;
  }

  .clutch-checkbox-row strong,
  .clutch-checkbox-row small {
    display: block;
  }

  .clutch-checkbox-row small {
    color: rgb(var(--color-foreground-rgb) / 0.72);
  }

  .clutch-file-input,
  .clutch-select {
    width: 100%;
  }

  .clutch-file-input.field__input,
  .clutch-select.field__input {
    min-height: 52px;
    padding-block: var(--padding-md);
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    border-radius: var(--style-border-radius-inputs);
    background: var(--color-input-background);
    color: var(--color-input-text);
  }

  .clutch-file-input.field__input::file-selector-button {
    margin-inline-end: var(--padding-md);
    padding: 0.75rem 1rem;
    border: 0;
    border-radius: 999px;
    background: #384862;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
  }

  .clutch-file-input.field__input::-webkit-file-upload-button {
    margin-inline-end: var(--padding-md);
    padding: 0.75rem 1rem;
    border: 0;
    border-radius: 999px;
    background: #384862;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
  }

  .clutch-field-help {
    margin: var(--gap-xs) 0 0;
    color: rgb(var(--color-foreground-rgb) / 0.72);
  }

  @media screen and (max-width: 749px) {
    .clutch-print-options {
      gap: var(--gap-lg);
      margin-block-start: var(--gap-lg);
    }

    .clutch-supporting-copy {
      font-size: var(--font-size--md);
      line-height: 1.7;
    }

    .clutch-info-grid,
    .clutch-addon-badges {
      grid-template-columns: 1fr;
    }

    .clutch-info-panel,
    .clutch-option-card,
    .clutch-addon-callout {
      padding: var(--gap-lg);
      border-radius: 28px;
    }

    .clutch-info-panel h3,
    .clutch-option-card .clutch-field-label,
    .clutch-addon-callout h3 {
      font-size: clamp(1.1rem, 4.5vw, 1.35rem);
    }

    .clutch-info-panel li,
    .clutch-field-help,
    .clutch-checkbox-row small,
    .clutch-addon-callout p {
      font-size: var(--font-size--md);
      line-height: 1.65;
    }

    .clutch-addon-badges span {
      padding: 0.85rem 1rem;
      justify-content: flex-start;
    }

    .clutch-file-input.field__input,
    .clutch-select.field__input {
      min-height: 56px;
    }

    .clutch-checkbox-row {
      gap: var(--gap-md);
    }
  }
{% endstylesheet %}
