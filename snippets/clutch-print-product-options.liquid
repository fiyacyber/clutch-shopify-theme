{% doc %}
  Clutch print product options.

  Renders print-specific line item properties inside the existing Shopify product form.
  Theme-only line item properties capture customer intent; paid add-on charging should be backed by real Shopify products,
  variants, selling plans, or an app before launch.

  @param {object} product - The current product.
  @param {string} section_id - The parent section ID used for unique form control IDs.
{% enddoc %}

{% liquid
  assign product_handle = product.handle | downcase
  assign is_business_kit = false
  assign is_qr_product = false
  assign is_connect_card = false

  if product_handle == 'starter-kit' or product_handle == 'startup-kit' or product_handle == 'growth-kit'
    assign is_business_kit = true
  endif

  if product_handle == 'clutch-connect-card'
    assign is_connect_card = true
  endif

  if product_handle contains 'qr-pro'
    assign is_qr_product = true
  endif

  assign qr_pro_product = all_products['qr-pro']
  assign qr_pro_variant = qr_pro_product.selected_or_first_available_variant
  assign professional_design_product = all_products['professional-design']
  assign professional_design_variant = professional_design_product.selected_or_first_available_variant
%}

<div class="clutch-print-options" id="clutch-artwork-upload" data-clutch-print-options>
  {% if is_connect_card %}
    <div class="clutch-addon-callout clutch-addon-callout--qr">
      <p class="clutch-eyebrow">Premium metal NFC business card</p>
      <h3>Tap or scan to share your profile</h3>
      <p>
        Clutch Smart Business Card includes a premium metal NFC card, editable digital profile, dynamic QR code,
        and Clutch Connect Hosting with scan/tap analytics.
      </p>
      <div class="clutch-addon-badges">
        <span>$49.99 Smart Business Card</span>
        <span>$49.99 additional cards</span>
        <span>+$19.99 optional engraving</span>
        <span>$14.99/month Clutch Connect Hosting</span>
        <span>QR + NFC sharing</span>
        <span>Editable profile</span>
        <span>Scan analytics</span>
        <span>Apple Wallet contact card</span>
      </div>
    </div>
  {% elsif is_qr_product %}
    <div class="clutch-addon-callout clutch-addon-callout--qr">
      <p class="clutch-eyebrow">Clutch QR™ Add-On</p>
      <h3>Turn printed marketing into trackable marketing</h3>
      <p>
        Add a dynamic Clutch QR™ Code and track customer engagement beyond the mailbox, flyer, sign, or business card.
      </p>
      <div class="clutch-addon-badges">
        <span>Editable destination links</span>
        <span>Scan tracking</span>
        <span>QR analytics</span>
        <span>Review links</span>
        <span>Booking links</span>
        <span>Website traffic tracking</span>
        <span>Promotions and offers</span>
      </div>
    </div>

      <div class="clutch-info-grid">
        <div class="clutch-info-panel">
          <h3>Plan options</h3>
          <ul>
          <li>Clutch Connect Hosting - $14.99/month, up to 10 dynamic QR codes</li>
          <li>Business Kits can track scans by printed material from one dashboard</li>
        </ul>
      </div>
      <div class="clutch-info-panel">
        <h3>Support</h3>
        <p>Choose the plan that fits your campaign, then keep your destination link editable as your offers change.</p>
      </div>
    </div>
  {% else %}
    <p class="clutch-eyebrow">Premium print products with built-in marketing tools.</p>
    {% if is_business_kit %}
      <div class="clutch-addon-callout clutch-addon-callout--qr">
        <p class="clutch-eyebrow">Campaign-Level QR Tracking Included</p>
        <h3>Track each printed material separately</h3>
        <p>
          Each printed material in your Business Kit can receive its own dynamic Clutch QR Code. Track business cards,
          flyers, door hangers, yard signs, postcards, and more from one Clutch Connect dashboard.
        </p>
        <div class="clutch-addon-badges">
          <span>Business card scans</span>
          <span>Flyer scans</span>
          <span>Door hanger scans</span>
          <span>Yard sign scans</span>
          <span>Editable destinations</span>
          <span>$14.99/month Clutch Connect hosting</span>
        </div>
      </div>
    {% endif %}
    {% unless is_business_kit %}
      <p class="clutch-supporting-copy">
        Upload print-ready artwork, or add Professional Design for a $200 flat fee if you need help creating your file.
      </p>
    {% endunless %}

    <div class="clutch-option-card clutch-option-card--highlight">
      <label class="clutch-field-label" for="clutch-artwork-file-{{ section_id }}">Artwork &amp; File Upload</label>
      <input
        id="clutch-artwork-file-{{ section_id }}"
        class="clutch-file-input field__input"
        type="file"
        name="properties[Artwork upload]"
        accept=".pdf,.ai,.eps,.psd,.png,.jpg,.jpeg,application/pdf,image/png,image/jpeg"
      >
      <p class="clutch-field-help">
        Accepted files: PDF, AI, EPS, PSD, PNG, JPG. 300 DPI recommended. 0.125 inch bleed required when applicable.
      </p>
    </div>

    {% if is_business_kit %}
      <div class="clutch-option-card clutch-option-card--included">
        <p class="clutch-field-label">Professional Design Free</p>
        <p class="clutch-field-help">Professional Design is included with this kit.</p>
      </div>
    {% else %}
      <div class="clutch-option-card">
        <label class="clutch-checkbox-row" for="clutch-professional-design-{{ section_id }}">
          <input
            id="clutch-professional-design-{{ section_id }}"
            type="checkbox"
            name="properties[Professional Design]"
            value="Requested - $200 flat rate"
            data-clutch-professional-design-handle="professional-design"
            data-clutch-professional-design-variant-id="{{ professional_design_variant.id }}"
          >
          <span>
            <strong>Professional Design Add-On</strong>
            <small>$200 flat fee. Clutch will create a clean, print-ready layout for your order.</small>
          </span>
        </label>
      </div>
    {% endif %}

    <div class="clutch-option-card clutch-option-card--shipping">
      <p class="clutch-field-label">Free Shipping</p>
      <p class="clutch-field-help">Free shipping is included on all orders across the shop.</p>
    </div>

    <div class="clutch-option-card clutch-option-card--qr">
      <label class="clutch-field-label" for="clutch-qr-package-{{ section_id }}">Clutch QR™ Add-On</label>
      <select
        id="clutch-qr-package-{{ section_id }}"
        class="clutch-select field__input"
        name="properties[QR Package]"
      >
        <option value="QR Tracking Available - Add Clutch Connect hosting">
          QR Tracking Available — Add Clutch Connect hosting
        </option>
        <option
          value="Clutch Connect - $14.99/month, up to 10 dynamic QR codes"
          data-clutch-qr-addon-handle="qr-pro"
          data-clutch-qr-addon-variant-id="{{ qr_pro_variant.id }}"
        >
          Clutch Connect — $14.99/month, up to 10 dynamic QR codes
        </option>
      </select>
      <p class="clutch-field-help">
        Add Clutch Connect hosting for editable destinations, scan analytics, and dashboard access.
      </p>
    </div>
  {% endif %}

  <input type="hidden" name="properties[Clutch print product]" value="{{ product.title | escape }}">
</div>

{% stylesheet %}
  .clutch-print-options {
    display: grid;
    gap: var(--gap-md);
    margin-block-start: var(--gap-md);
  }

  .clutch-supporting-copy {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.8);
  }

  .clutch-info-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--gap-md);
  }

  .clutch-info-grid--top {
    margin-block-start: var(--gap-2xs);
  }

  .clutch-info-panel,
  .clutch-option-card,
  .clutch-addon-callout {
    border: 1px solid rgb(var(--color-border-rgb) / 0.7);
    border-radius: 24px;
    background: linear-gradient(180deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 1));
    box-shadow: var(--shadow-popover);
    padding: clamp(var(--gap-md), 2vw, var(--gap-xl));
  }

  .clutch-info-panel--featured,
  .clutch-option-card--highlight,
  .clutch-addon-callout--qr {
    background:
      linear-gradient(180deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 1)),
      linear-gradient(135deg, rgb(56 72 98 / 0.05), rgb(255 166 101 / 0.1));
  }

  .clutch-option-card--included {
    background: linear-gradient(135deg, rgb(255 166 101 / 0.12), rgb(var(--color-background-rgb) / 1));
  }

  .clutch-option-card--shipping {
    background:
      linear-gradient(180deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 1)),
      linear-gradient(135deg, rgb(255 166 101 / 0.08), rgb(56 72 98 / 0.04));
  }

  .clutch-info-panel h3,
  .clutch-option-card .clutch-field-label,
  .clutch-addon-callout h3 {
    margin-top: 0;
    margin-bottom: var(--gap-xs);
    color: #384862;
  }

  .clutch-info-panel ul,
  .clutch-addon-badges {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .clutch-info-panel li {
    position: relative;
    padding-left: 1.35rem;
  }

  .clutch-info-panel li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.35rem;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    background: #ffa665;
    box-shadow: 0 0 0 4px rgb(255 166 101 / 0.16);
  }

  .clutch-addon-callout {
    display: grid;
    gap: var(--gap-sm);
  }

  .clutch-addon-badges {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .clutch-addon-badges span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 0.85rem;
    border-radius: 999px;
    background: rgb(56 72 98 / 0.07);
    color: #384862;
    font-size: var(--font-size--sm);
    font-weight: 600;
  }

  .clutch-field-label {
    display: block;
    margin-bottom: var(--gap-xs);
    font-weight: 700;
  }

  .clutch-checkbox-row {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-sm);
    cursor: pointer;
  }

  .clutch-checkbox-row strong,
  .clutch-checkbox-row small {
    display: block;
  }

  .clutch-checkbox-row small {
    color: rgb(var(--color-foreground-rgb) / 0.72);
  }

  .clutch-file-input,
  .clutch-select {
    width: 100%;
  }

  .clutch-file-input.field__input,
  .clutch-select.field__input {
    min-height: 52px;
    padding-block: var(--padding-md);
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    border-radius: var(--style-border-radius-inputs);
    background: var(--color-input-background);
    color: var(--color-input-text);
  }

  .clutch-file-input.field__input::file-selector-button {
    margin-inline-end: var(--padding-md);
    padding: 0.75rem 1rem;
    border: 0;
    border-radius: 999px;
    background: #384862;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
  }

  .clutch-file-input.field__input::-webkit-file-upload-button {
    margin-inline-end: var(--padding-md);
    padding: 0.75rem 1rem;
    border: 0;
    border-radius: 999px;
    background: #384862;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
  }

  .clutch-field-help {
    margin: var(--gap-xs) 0 0;
    color: rgb(var(--color-foreground-rgb) / 0.72);
  }

  @media screen and (max-width: 749px) {
    .clutch-print-options {
      gap: var(--gap-lg);
      margin-block-start: var(--gap-lg);
    }

    .clutch-supporting-copy {
      font-size: var(--font-size--md);
      line-height: 1.7;
    }

    .clutch-info-grid,
    .clutch-addon-badges {
      grid-template-columns: 1fr;
    }

    .clutch-info-panel,
    .clutch-option-card,
    .clutch-addon-callout {
      padding: var(--gap-lg);
      border-radius: 28px;
    }

    .clutch-info-panel h3,
    .clutch-option-card .clutch-field-label,
    .clutch-addon-callout h3 {
      font-size: clamp(1.1rem, 4.5vw, 1.35rem);
    }

    .clutch-info-panel li,
    .clutch-field-help,
    .clutch-checkbox-row small,
    .clutch-addon-callout p {
      font-size: var(--font-size--md);
      line-height: 1.65;
    }

    .clutch-addon-badges span {
      padding: 0.85rem 1rem;
      justify-content: flex-start;
    }

    .clutch-file-input.field__input,
    .clutch-select.field__input {
      min-height: 56px;
    }

    .clutch-checkbox-row {
      gap: var(--gap-md);
    }
  }
{% endstylesheet %}
