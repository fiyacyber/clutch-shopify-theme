{% doc %}
  Renders the educational Clutch Code destination-switching demonstration.

  @example
  {% render 'clutch-code-demo' %}
{% enddoc %}

<div class="clutch-demo clutch-reveal" data-clutch-code-demo data-active="website">
  <div class="clutch-demo__stage">
    <div class="clutch-demo__print" aria-label="Printed Piece">
      <span class="clutch-demo__label">Printed Piece</span>
      <p>LOCAL SERVICES</p>
      <strong>Ready when your customers are.</strong>
      <span class="clutch-demo-qr" aria-label="Clutch Code demonstration">
        <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
      </span>
      <small>Clutch Code · Demo</small>
    </div>

    <span class="clutch-demo__arrow" aria-hidden="true">→</span>

    <div class="clutch-demo__phone" aria-live="polite">
      <span class="clutch-demo__label">Digital Destination</span>
      <span class="clutch-demo__phone-bar" aria-hidden="true"></span>
      <small data-demo-kicker>Demo website</small>
      <strong data-demo-title>Welcome to your next step</strong>
      <p>Educational destination preview</p>
      <span class="clutch-demo__phone-action" data-demo-action>Visit website</span>
    </div>

    <div class="clutch-demo__activity" aria-label="Scan Activity demonstration">
      <span class="clutch-demo__label">Scan Activity</span>
      <strong>Demo activity</strong>
      <div aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
      <small>Illustration only · no customer data</small>
    </div>
  </div>

  <div class="clutch-demo__controls" aria-label="Choose a demonstration destination">
    <span class="clutch-demo__label">Try a destination</span>
    <div>
      <button class="is-active" type="button" aria-pressed="true" data-demo-destination="website" data-kicker="Demo website" data-title="Welcome to your next step" data-action="Visit website">Website</button>
      <button type="button" aria-pressed="false" data-demo-destination="quote" data-kicker="Demo quote form" data-title="Tell us about your project" data-action="Request a quote">Request a Quote</button>
      <button type="button" aria-pressed="false" data-demo-destination="offer" data-kicker="Demo special offer" data-title="A focused offer for this campaign" data-action="View offer">Special Offer</button>
      <button type="button" aria-pressed="false" data-demo-destination="profile" data-kicker="Demo Clutch Connect profile" data-title="Contact, links, and next steps" data-action="View profile">Clutch Connect Profile</button>
    </div>
  </div>
</div>

{% stylesheet %}
  .clutch-demo {
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 24px;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .clutch-demo__stage {
    align-items: center;
    display: grid;
    gap: clamp(1rem, 3vw, 2.5rem);
    grid-template-columns: minmax(0, 1.15fr) auto minmax(180px, 0.72fr) minmax(160px, 0.72fr);
  }

  .clutch-demo__label {
    color: #FFA665;
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .clutch-demo__print {
    background: linear-gradient(145deg, #FFFFFF, #EEF1F5);
    border-radius: 16px;
    color: #172033;
    display: grid;
    gap: 0.7rem;
    min-height: 270px;
    padding: 1.25rem;
    transform: rotate(-2deg);
  }

  .clutch-demo__print p {
    color: #384862;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .clutch-demo__print strong {
    font-size: clamp(1.45rem, 3vw, 2.4rem);
    line-height: 1;
    max-width: 310px;
  }

  .clutch-demo__print small,
  .clutch-demo__activity small {
    color: #657085;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .clutch-demo__arrow {
    align-items: center;
    background: #FFA665;
    border-radius: 50%;
    color: #172033;
    display: flex;
    font-weight: 900;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  .clutch-demo__phone {
    background: #FFFFFF;
    border: 7px solid #101828;
    border-radius: 25px;
    color: #172033;
    display: grid;
    gap: 0.7rem;
    justify-items: center;
    min-height: 300px;
    padding: 1rem;
    text-align: center;
    transition: transform 220ms ease;
  }

  .clutch-demo[data-active='quote'] .clutch-demo__phone { transform: translateY(-3px); }
  .clutch-demo[data-active='offer'] .clutch-demo__phone { transform: rotate(1deg); }
  .clutch-demo[data-active='profile'] .clutch-demo__phone { transform: translateY(-3px) rotate(-1deg); }

  .clutch-demo__phone-bar {
    background: #DDE3EA;
    border-radius: 10px;
    height: 5px;
    width: 34%;
  }

  .clutch-demo__phone > small {
    color: #657085;
    font-size: 0.66rem;
    margin-top: 1rem;
  }

  .clutch-demo__phone > strong {
    font-size: 1.15rem;
    line-height: 1.1;
  }

  .clutch-demo__phone > p {
    color: #657085;
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .clutch-demo__phone-action {
    background: #FFA665;
    border-radius: 8px;
    color: #172033;
    font-size: 0.7rem;
    font-weight: 900;
    margin-top: auto;
    padding: 0.7rem 0.85rem;
    width: 100%;
  }

  .clutch-demo__activity {
    background: #FFFFFF;
    border-radius: 16px;
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
  }

  .clutch-demo__activity > strong {
    color: #384862;
  }

  .clutch-demo__activity > div {
    align-items: end;
    display: grid;
    gap: 5px;
    grid-template-columns: repeat(5, 1fr);
    height: 74px;
  }

  .clutch-demo__activity i {
    background: #FFA665;
    border-radius: 4px 4px 0 0;
    height: 28%;
  }

  .clutch-demo__activity i:nth-child(2) { height: 56%; }
  .clutch-demo__activity i:nth-child(3) { height: 38%; }
  .clutch-demo__activity i:nth-child(4) { height: 72%; }
  .clutch-demo__activity i:nth-child(5) { height: 48%; }

  .clutch-demo__controls {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .clutch-demo__controls > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .clutch-demo__controls button {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 9px;
    color: #FFFFFF;
    cursor: pointer;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 800;
    min-height: 44px;
    padding: 0.65rem 0.85rem;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .clutch-demo__controls button:hover,
  .clutch-demo__controls button.is-active {
    background: #FFA665;
    border-color: #FFA665;
    color: #172033;
  }

  @media (max-width: 900px) {
    .clutch-demo__stage {
      grid-template-columns: minmax(0, 1fr) auto minmax(180px, 0.8fr);
    }

    .clutch-demo__activity {
      grid-column: 1 / -1;
      grid-template-columns: auto 1fr;
    }

    .clutch-demo__activity > div,
    .clutch-demo__activity > small {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .clutch-demo__stage {
      grid-template-columns: 1fr;
    }

    .clutch-demo__print {
      min-height: 240px;
      transform: none;
    }

    .clutch-demo__arrow {
      justify-self: center;
      transform: rotate(90deg);
    }

    .clutch-demo__phone {
      justify-self: center;
      max-width: 240px;
      width: 72%;
    }

    .clutch-demo__controls > div {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 389px) {
    .clutch-demo__controls > div {
      grid-template-columns: 1fr;
    }

    .clutch-demo__phone {
      width: 78%;
    }
  }
{% endstylesheet %}
