{% doc %}
  Renders the Phase 4 tracked-print contract inside the native Shopify product form.

  The caller must gate this snippet with custom.tracked_print_enabled. Material type is
  deliberately not submitted by the browser; the application resolves it from its trusted registry.

  @param {string} section_id - Parent section identifier used to create unique control IDs.
  @param {object} product - Current product for the 90-day access feature gate.
  @param {boolean} [is_business_kit] - Uses the included Business Kit artwork presentation.
  @param {boolean} [artwork_only] - Omits the tracked-print contract when only artwork intake is required.
{% enddoc %}

{% liquid
  assign business_kit_access_enabled = false
  if is_business_kit and product.metafields.custom.clutch_codes_90_day_access_enabled.value == true
    assign business_kit_access_enabled = true
  endif
%}

<tracked-print-controls
  class="tracked-print-controls"
  data-tracked-print-controls
  {% if is_business_kit %}data-business-kit-artwork{% endif %}
  {% if business_kit_access_enabled %}data-business-kit-components{% endif %}
  {% if artwork_only %}data-artwork-only{% endif %}
  data-campaign-error="{{ 'tracked_print.validation.campaign' | t | escape }}"
  data-destination-error="{{ 'tracked_print.validation.destination' | t | escape }}"
  data-existing-error="{{ 'tracked_print.validation.existing' | t | escape }}"
  data-file-required-error="{{ 'tracked_print.validation.file_required' | t | escape }}"
  data-file-size-error="{{ 'tracked_print.validation.file_size' | t | escape }}"
  data-file-type-error="{{ 'tracked_print.validation.file_type' | t | escape }}"
  data-instructions-error="{{ 'tracked_print.validation.instructions' | t | escape }}"
  data-reorder-error="{{ 'tracked_print.validation.reorder' | t | escape }}"
>
  {% if product.metafields.custom.clutch_codes_90_day_access_enabled.value == true %}
    {% render 'clutch-codes-included-access', variant: 'full' %}
  {% endif %}
  {% if business_kit_access_enabled %}
  <div class="tracked-print-controls__heading">
    <h3>{{ 'tracked_print.business_kit.tracking_heading' | t }}</h3>
    <p>{{ 'tracked_print.business_kit.tracking_description' | t }}</p>
  </div>

  {% assign business_kit_component_contracts = 'business-cards|tracked_print.business_kit.business_cards|Business Cards Tracking Mode|Business Cards Campaign Name|Business Cards Destination URL|Business Cards Existing Clutch Code||door-hangers|tracked_print.business_kit.door_hangers|Door Hangers Tracking Mode|Door Hangers Campaign Name|Door Hangers Destination URL|Door Hangers Existing Clutch Code||flyers|tracked_print.business_kit.flyers|Flyers Tracking Mode|Flyers Campaign Name|Flyers Destination URL|Flyers Existing Clutch Code' | split: '||' %}
  {% for component_contract in business_kit_component_contracts %}
    {% liquid
      assign component_parts = component_contract | split: '|'
      assign component_key = component_parts[0]
      assign component_label = component_parts[1] | t
      assign tracking_property = component_parts[2]
      assign campaign_property = component_parts[3]
      assign destination_property = component_parts[4]
      assign existing_property = component_parts[5]
    %}
    <section
      class="business-kit-component"
      data-business-kit-component
      data-component-label="{{ component_label | escape }}"
      data-tracking-property="{{ tracking_property | escape }}"
      data-campaign-property="{{ campaign_property | escape }}"
      data-destination-property="{{ destination_property | escape }}"
      data-existing-property="{{ existing_property | escape }}"
    >
      <fieldset class="business-kit-component__choices" data-business-kit-tracking>
        <legend>{{ component_label }}</legend>
        <label>
          <input type="radio" name="properties[{{ tracking_property }}]" value="none" checked>
          <span><strong>{{ 'tracked_print.tracking.none_title' | t }}</strong><small>{{ 'tracked_print.tracking.none_help' | t }}</small></span>
        </label>
        <label>
          <input type="radio" name="properties[{{ tracking_property }}]" value="new_included_code">
          <span><strong>{{ 'tracked_print.tracking.new_title' | t }}</strong><small>{{ 'tracked_print.business_kit.new_component_help' | t }}</small></span>
        </label>
        <label>
          <input type="radio" name="properties[{{ tracking_property }}]" value="existing_code">
          <span><strong>{{ 'tracked_print.tracking.existing_title' | t }}</strong><small>{{ 'tracked_print.business_kit.existing_component_help' | t }}</small></span>
        </label>
      </fieldset>

      <div class="business-kit-component__panel" data-business-kit-panel="new_included_code" hidden>
        <label for="business-kit-{{ component_key }}-campaign-{{ section_id }}">{{ 'tracked_print.tracking.campaign' | t }}</label>
        <input id="business-kit-{{ component_key }}-campaign-{{ section_id }}" type="text" name="properties[{{ campaign_property }}]" maxlength="160" disabled>
        <label for="business-kit-{{ component_key }}-destination-{{ section_id }}">{{ 'tracked_print.tracking.destination' | t }}</label>
        <input id="business-kit-{{ component_key }}-destination-{{ section_id }}" type="url" name="properties[{{ destination_property }}]" placeholder="https://" maxlength="2048" disabled>
      </div>

      <div class="business-kit-component__panel" data-business-kit-panel="existing_code" hidden>
        <label for="business-kit-{{ component_key }}-existing-{{ section_id }}">{{ 'tracked_print.tracking.existing_reference' | t }}</label>
        <input id="business-kit-{{ component_key }}-existing-{{ section_id }}" type="text" name="properties[{{ existing_property }}]" maxlength="512" disabled>
        <p>{{ 'tracked_print.tracking.existing_reference_help' | t }}</p>
        <a href="https://qr.clutchprintshop.com/portal/qr" target="_blank" rel="noopener">{{ 'tracked_print.tracking.find_existing' | t }}</a>
      </div>
    </section>
  {% endfor %}
  {% elsif is_business_kit != true and artwork_only != true %}
  <div class="tracked-print-controls__heading">
    <p class="clutch-eyebrow">{{ 'tracked_print.eyebrow' | t }}</p>
    <h3>{{ 'tracked_print.heading' | t }}</h3>
    <p>{{ 'tracked_print.description' | t }}</p>
  </div>

  <fieldset class="tracked-print-controls__group" data-tracked-print-tracking>
    <legend>{{ 'tracked_print.tracking.legend' | t }}</legend>
    <label>
      <input type="radio" name="properties[Tracking Mode]" value="none" checked>
      <span><strong>{{ 'tracked_print.tracking.none_title' | t }}</strong><small>{{ 'tracked_print.tracking.none_help' | t }}</small></span>
    </label>
    <label>
      <input type="radio" name="properties[Tracking Mode]" value="new_included_code">
      <span><strong>{{ 'tracked_print.tracking.new_title' | t }}</strong><small>{{ 'tracked_print.tracking.new_help' | t }}</small></span>
    </label>
    <label>
      <input type="radio" name="properties[Tracking Mode]" value="existing_code">
      <span><strong>{{ 'tracked_print.tracking.existing_title' | t }}</strong><small>{{ 'tracked_print.tracking.existing_help' | t }}</small></span>
    </label>
  </fieldset>

  <div class="tracked-print-controls__panel" data-tracked-print-panel="new_included_code" hidden>
    <label for="tracked-print-campaign-{{ section_id }}">{{ 'tracked_print.tracking.campaign' | t }}</label>
    <input id="tracked-print-campaign-{{ section_id }}" type="text" name="properties[Campaign Name]" maxlength="160" disabled>
    <label for="tracked-print-destination-{{ section_id }}">{{ 'tracked_print.tracking.destination' | t }}</label>
    <input id="tracked-print-destination-{{ section_id }}" type="url" name="properties[Destination URL]" placeholder="https://" maxlength="2048" disabled>
  </div>

  <div class="tracked-print-controls__panel" data-tracked-print-panel="existing_code" hidden>
    <label for="tracked-print-existing-{{ section_id }}">{{ 'tracked_print.tracking.existing_reference' | t }}</label>
    <input id="tracked-print-existing-{{ section_id }}" type="text" name="properties[Existing Clutch Code]" maxlength="512" disabled>
    <p>{{ 'tracked_print.tracking.existing_reference_help' | t }}</p>
    <a href="https://qr.clutchprintshop.com/portal/qr" target="_blank" rel="noopener">{{ 'tracked_print.tracking.find_existing' | t }}</a>
  </div>

  <div class="tracked-print-controls__panel" data-tracked-print-placement hidden>
    <label for="tracked-print-placement-{{ section_id }}">{{ 'tracked_print.tracking.placement' | t }}</label>
    <textarea id="tracked-print-placement-{{ section_id }}" name="properties[QR Placement Instructions]" rows="3" maxlength="500" disabled></textarea>
  </div>
  {% endif %}

  <fieldset class="tracked-print-controls__group" data-tracked-print-artwork>
    <legend>
      {% if is_business_kit %}
        {{ 'tracked_print.business_kit.artwork_legend' | t }}
      {% else %}
        {{ 'tracked_print.artwork.legend' | t }}
      {% endif %}
    </legend>
    <label>
      <input type="radio" name="properties[Artwork Method]" value="upload_now">
      <span>
        <strong>{% if is_business_kit %}{{ 'tracked_print.business_kit.upload_now_title' | t }}{% else %}{{ 'tracked_print.artwork.upload_now_title' | t }}{% endif %}</strong>
        <small>{% if is_business_kit %}{{ 'tracked_print.business_kit.upload_now_help' | t }}{% else %}{{ 'tracked_print.artwork.upload_now_help' | t }}{% endif %}</small>
      </span>
    </label>
    <label>
      <input type="radio" name="properties[Artwork Method]" value="upload_later" checked>
      <span>
        <strong>{% if is_business_kit %}{{ 'tracked_print.business_kit.upload_later_title' | t }}{% else %}{{ 'tracked_print.artwork.upload_later_title' | t }}{% endif %}</strong>
        <small>{% if is_business_kit %}{{ 'tracked_print.business_kit.upload_later_help' | t }}{% else %}{{ 'tracked_print.artwork.upload_later_help' | t }}{% endif %}</small>
      </span>
    </label>
    <label>
      <input type="radio" name="properties[Artwork Method]" value="request_design">
      <span>
        <strong>{% if is_business_kit %}{{ 'tracked_print.business_kit.request_design_title' | t }}{% else %}{{ 'tracked_print.artwork.request_design_title' | t }}{% endif %}</strong>
        <small>{% if is_business_kit %}{{ 'tracked_print.business_kit.request_design_help' | t }}{% else %}{{ 'tracked_print.artwork.request_design_help' | t }}{% endif %}</small>
      </span>
    </label>
    <label{% if is_business_kit %} class="tracked-print-controls__choice--secondary"{% endif %}>
      <input type="radio" name="properties[Artwork Method]" value="reorder_existing">
      <span>
        <strong>{% if is_business_kit %}{{ 'tracked_print.business_kit.reorder_title' | t }}{% else %}{{ 'tracked_print.artwork.reorder_title' | t }}{% endif %}</strong>
        <small>{{ 'tracked_print.artwork.reorder_help' | t }}</small>
      </span>
    </label>
  </fieldset>

  <div class="tracked-print-controls__panel" data-artwork-panel="upload_now" hidden>
    <label for="tracked-print-artwork-{{ section_id }}">{{ 'tracked_print.artwork.file' | t }}</label>
    <input
      id="tracked-print-artwork-{{ section_id }}"
      type="file"
      name="properties[Artwork Upload URL]"
      accept=".pdf,.png,.jpg,.jpeg,.tif,.tiff,.eps,application/pdf,image/png,image/jpeg,image/tiff,application/postscript"
      data-tracked-print-file
      disabled
    >
    <p>{{ 'tracked_print.artwork.file_help' | t }}</p>
  </div>

  <div class="tracked-print-controls__panel" data-artwork-panel="request_design" hidden>
    {% if is_business_kit %}
      <h4>{{ 'tracked_print.business_kit.request_panel_title' | t }}</h4>
      <p id="tracked-print-design-help-{{ section_id }}">{{ 'tracked_print.business_kit.request_panel_help' | t }}</p>
      <label for="tracked-print-instructions-{{ section_id }}">{{ 'tracked_print.artwork.instructions' | t }}</label>
      <textarea
        id="tracked-print-instructions-{{ section_id }}"
        name="properties[Artwork Instructions]"
        rows="5"
        maxlength="2000"
        placeholder="{{ 'tracked_print.business_kit.instructions_placeholder' | t | escape }}"
        aria-describedby="tracked-print-design-help-{{ section_id }}"
        disabled
      ></textarea>
    {% else %}
      <p>{{ 'tracked_print.artwork.request_design_prompt' | t }}</p>
    {% endif %}
  </div>

  <div class="tracked-print-controls__panel" data-artwork-panel="reorder_existing" hidden>
    <label for="tracked-print-reorder-{{ section_id }}">{{ 'tracked_print.artwork.reorder_reference' | t }}</label>
    <input id="tracked-print-reorder-{{ section_id }}" type="text" name="properties[Reorder Reference]" maxlength="200" disabled>
  </div>

  {% unless is_business_kit %}
  <div class="tracked-print-controls__panel">
    <label for="tracked-print-instructions-{{ section_id }}">{{ 'tracked_print.artwork.instructions' | t }}</label>
    <textarea id="tracked-print-instructions-{{ section_id }}" name="properties[Artwork Instructions]" rows="4" maxlength="2000"></textarea>
    <p>{{ 'tracked_print.artwork.instructions_help' | t }}</p>
  </div>
  {% endunless %}

  <div class="tracked-print-controls__errors" role="alert" tabindex="-1" data-tracked-print-errors hidden>
    <strong>{{ 'tracked_print.validation.heading' | t }}</strong>
    <ul></ul>
  </div>
  {% if artwork_only != true or business_kit_access_enabled %}
    <input type="hidden" name="properties[_Tracked Print Contract]" value="phase4_v1">
  {% endif %}
  {% if is_business_kit != true and product.metafields.custom.clutch_codes_90_day_access_enabled.value == true %}
    <input type="hidden" name="properties[Clutch Codes Access]" value="none" data-clutch-codes-access-property>
  {% endif %}
</tracked-print-controls>

{% stylesheet %}
  .tracked-print-controls { display: grid; gap: 1.25rem; padding: 1.25rem; border: 1px solid color-mix(in srgb, #384862 25%, transparent); border-radius: 0.75rem; background: #fff; color: #384862; }
  .tracked-print-controls__heading > * { margin-block: 0 0.45rem; }
  .tracked-print-controls__heading h3 { color: #384862; }
  .business-kit-component { display: grid; gap: 0.75rem; padding-block: 0.25rem 1rem; border-bottom: 1px solid #d7dce3; }
  .business-kit-component:last-of-type { border-bottom: 0; }
  .business-kit-component__choices { display: grid; gap: 0.65rem; margin: 0; padding: 0; border: 0; }
  .business-kit-component__choices legend { margin-block-end: 0.5rem; font-weight: 700; }
  .business-kit-component__choices label { display: flex; gap: 0.75rem; align-items: flex-start; min-height: 44px; padding: 0.85rem; border: 1px solid #d7dce3; border-radius: 0.55rem; cursor: pointer; }
  .business-kit-component__choices label:focus-within { border-color: #384862; outline: 3px solid color-mix(in srgb, #ffa665 65%, transparent); outline-offset: 2px; }
  .business-kit-component__choices input { margin-block-start: 0.25rem; }
  .business-kit-component__choices span { display: grid; gap: 0.2rem; }
  .business-kit-component__choices small, .business-kit-component__panel p { color: #56657b; }
  .business-kit-component__panel { display: grid; gap: 0.45rem; padding: 1rem; border-left: 4px solid #ffa665; background: #f8f9fb; }
  .business-kit-component__panel[hidden] { display: none; }
  .business-kit-component__panel input { width: 100%; padding: 0.75rem; border: 1px solid #8792a3; border-radius: 0.35rem; color: #1c2636; background: #fff; }
  .tracked-print-controls__group { display: grid; gap: 0.65rem; margin: 0; padding: 0; border: 0; }
  .tracked-print-controls__group legend { margin-block-end: 0.5rem; font-weight: 700; }
  .tracked-print-controls__group label { display: flex; gap: 0.75rem; align-items: flex-start; min-height: 44px; padding: 0.85rem; border: 1px solid #d7dce3; border-radius: 0.55rem; cursor: pointer; }
  .tracked-print-controls__group label:focus-within { border-color: #384862; outline: 3px solid color-mix(in srgb, #ffa665 65%, transparent); outline-offset: 2px; }
  .tracked-print-controls__choice--secondary { background: #f8f9fb; }
  .tracked-print-controls__group input { margin-block-start: 0.25rem; }
  .tracked-print-controls__group span { display: grid; gap: 0.2rem; }
  .tracked-print-controls__group small, .tracked-print-controls__panel p { color: #56657b; }
  .tracked-print-controls__panel h4 { margin: 0; color: #384862; }
  .tracked-print-controls__panel { display: grid; gap: 0.45rem; padding: 1rem; border-left: 4px solid #ffa665; background: #f8f9fb; }
  .tracked-print-controls__panel[hidden] { display: none; }
  .tracked-print-controls__panel input, .tracked-print-controls__panel textarea { width: 100%; padding: 0.75rem; border: 1px solid #8792a3; border-radius: 0.35rem; color: #1c2636; background: #fff; }
  .tracked-print-controls__errors { padding: 1rem; border: 2px solid #a52626; border-radius: 0.5rem; background: #fff2f2; color: #701b1b; }
  .tracked-print-controls__errors ul { margin-block-end: 0; }
  @media screen and (max-width: 749px) { .tracked-print-controls { padding: 1rem; } }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('tracked-print-controls')) {
    customElements.define('tracked-print-controls', class extends HTMLElement {
      connectedCallback() {
        if (this.dataset.initialized === 'true') return;
        this.dataset.initialized = 'true';
        this.form = this.closest('form');
        if (!this.form) return;
        this.errors = this.querySelector('[data-tracked-print-errors]');
        this.addEventListener('change', () => this.sync());
        this.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter' || event.isComposing) return;
          if (!(event.target instanceof HTMLInputElement) || !['text', 'url'].includes(event.target.type)) return;
          event.preventDefault();
          this.form.requestSubmit();
        });
        this.form.addEventListener('submit', (event) => {
          const validator = window.ClutchTrackedPrintValidation?.validateTrackedPrintProductForm;
          if (!validator) {
            event.preventDefault();
            event.stopImmediatePropagation();
            return;
          }
          validator(this.form, event);
        }, true);
        this.sync();
      }

      selected(name) {
        return this.querySelector(`[name="properties[${name}]"]:checked`)?.value || '';
      }

      activate(container, active) {
        if (!container) return;
        container.hidden = !active;
        container.querySelectorAll('input, textarea, select').forEach((field) => { field.disabled = !active; });
      }

      sync() {
        const tracking = this.selected('Tracking Mode');
        const artwork = this.selected('Artwork Method');
        this.querySelectorAll('[data-tracked-print-panel]').forEach((panel) => this.activate(panel, panel.dataset.trackedPrintPanel === tracking));
        const placement = this.querySelector('[data-tracked-print-placement]');
        this.activate(placement, tracking !== 'none');
        this.querySelectorAll('[data-artwork-panel]').forEach((panel) => this.activate(panel, panel.dataset.artworkPanel === artwork));
        const access = this.querySelector('[data-clutch-codes-access-property]');
        if (access) access.value = tracking === 'new_included_code' ? 'included_90_days' : 'none';
        this.querySelectorAll('[data-business-kit-component]').forEach((component) => {
          const componentTracking = this.selected(component.dataset.trackingProperty);
          component.querySelectorAll('[data-business-kit-panel]').forEach((panel) => {
            this.activate(panel, panel.dataset.businessKitPanel === componentTracking);
          });
        });
      }

    });
  }
{% endjavascript %}
